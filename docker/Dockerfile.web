# Build estático Astro (pnpm + lockfile) + Nginx con proxy /api → metrics
FROM node:22-bookworm-slim AS build

WORKDIR /app

RUN corepack enable

ARG PUBLIC_BICHI_APP_NAME=Bichipishi
ARG PUBLIC_BICHI_AVATAR_URL=
ENV PUBLIC_BICHI_APP_NAME=$PUBLIC_BICHI_APP_NAME
ENV PUBLIC_BICHI_AVATAR_URL=$PUBLIC_BICHI_AVATAR_URL

COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

COPY astro.config.mjs tsconfig.json ./
COPY public ./public
COPY src ./src

RUN pnpm run build

FROM nginx:1.27-alpine

RUN apk add --no-cache jq gettext

COPY --from=build /app/dist /usr/share/nginx/html
COPY docker/nginx/host-api.conf.template docker/nginx/docker-api.conf.template /etc/nginx/bichi-templates/
COPY docker/docker-entrypoint-bichi-nginx.sh /docker-entrypoint.d/35-bichi-nginx.sh
COPY docker/docker-entrypoint-bichi-brand.sh /docker-entrypoint.d/40-bichi-brand.sh
RUN chmod +x /docker-entrypoint.d/35-bichi-nginx.sh /docker-entrypoint.d/40-bichi-brand.sh

EXPOSE 80
