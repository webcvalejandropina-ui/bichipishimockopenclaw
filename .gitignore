# Raíz: bun.lock y pnpm-lock.yaml (Bun / pnpm); no uses npm en los flujos del repo (ver docs/PAQUETES.md).

# build output (web estática servida por metrics-api)
dist/

# generated types
.astro/

# dependencies
node_modules/

# salida de procesos en segundo plano (no subir)
nohup.out
**/nohup.out

# archivos comprimidos sueltos en la raíz (copias locales)
/*.zip

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
bun-debug.log*

# environment variables
.env
.env.production

metrics-api/pnpm-lock.yaml
metrics-api/package-lock.json

# Datos persistentes (raíz del repo; SQLite + ajustes)
/data/settings.json
/data/perf.sqlite
/data/perf.sqlite-shm
/data/perf.sqlite-wal

# Ubicación antigua (migración automática en deploy)
metrics-api/data/

# macOS-specific files
.DS_Store

# jetbrains setting folder
.idea/
