# Nombres que Nginx acepta en server_name (varios separados por espacio).
# Por defecto bichipishi.home: al usar scripts/bichi-docker-up.sh se actualiza solo /etc/hosts
# (bloque entre # >>> bichipishi-hosts y # <<< bichipishi-hosts).
# Sin tocar hosts: usa p. ej. bichipishi.127.0.0.1.nip.io
#
#   BICHI_SITE_HOST=bichipishi.home
#   BICHI_SITE_HOST=bichipishi.127.0.0.1.nip.io

BICHI_SITE_HOST=bichipishi.home
