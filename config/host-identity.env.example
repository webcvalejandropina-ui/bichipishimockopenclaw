# Variables opcionales para forzar texto de equipo/SO/RAM en la API si la detección automática falla.
# Cópialas a .env en la raíz del repo solo si las necesitas.

# BICHI_HOST_HOSTNAME=nombre-red
# BICHI_HOST_DEVICE_NAME=Mi equipo
# BICHI_HOST_OS=Windows 11
# BICHI_MEM_TOTAL_GIB=16
# BICHI_MEM_USED_GIB=8
# BICHI_HOST_UPTIME_SEC=86400
# BICHI_HOST_CPU_MODEL=Intel Core i5
# BICHI_HOST_CPU_CORES=4
