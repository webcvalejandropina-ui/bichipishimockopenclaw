# Copia estas variables a tu archivo .env en la raíz del repo (junto a docker-compose.yml).
# Docker Compose las inyecta en el servicio metrics → nombre del equipo, SO y RAM coherentes con tu PC.
#
# En macOS: nombre del equipo en Ajustes → General → Información; hostname en Ajustes → General → Compartir.

BICHI_HOST_HOSTNAME=mi-mac.local
BICHI_HOST_DEVICE_NAME=Mi Mac
BICHI_HOST_OS=macOS 15
BICHI_MEM_TOTAL_GIB=16
BICHI_MEM_USED_GIB=8

# Opcional:
# BICHI_HOST_UPTIME_SEC=86400
# BICHI_HOST_CPU_MODEL=Apple M1
# BICHI_HOST_CPU_CORES=8
