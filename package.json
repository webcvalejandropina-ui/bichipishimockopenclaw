{
  "name": "bichipishimockopenclaw",
  "version": "1.1.0",
  "private": true,
  "description": "Bichipishi — dashboard de métricas del sistema (Astro + API Node/Bun). Repo público.",
  "repository": {
    "type": "git",
    "url": "https://github.com/webcvalejandropina-ui/bichipishimockopenclaw.git"
  },
  "bugs": {
    "url": "https://github.com/webcvalejandropina-ui/bichipishimockopenclaw/issues"
  },
  "homepage": "https://github.com/webcvalejandropina-ui/bichipishimockopenclaw#readme",
  "packageManager": "pnpm@9.15.4",
  "workspaces": ["metrics-api"],
  "engines": {
    "node": ">=18.20.8"
  },
  "scripts": {
    "deploy": "bun scripts/deploy.mjs",
    "deploy:node": "node scripts/deploy.mjs",
    "deploy:bun": "bun scripts/deploy.mjs",
    "start": "cd metrics-api && bun server.js",
    "start:node": "cd metrics-api && node server.js",
    "dev": "bun scripts/dev.mjs",
    "dev:node": "node scripts/dev.mjs",
    "dev:api": "cd metrics-api && bun server.js",
    "dev:astro": "bun ./node_modules/astro/astro.js dev --host",
    "docker:up": "bun scripts/docker-local.mjs up production",
    "docker:up:local": "bun scripts/docker-local.mjs up local",
    "docker:up:prod": "bun scripts/docker-local.mjs up production",
    "docker:up:tunnel": "bun scripts/docker-local.mjs up production tunnel",
    "docker:up:local:tunnel": "bun scripts/docker-local.mjs up local tunnel",
    "docker:down": "bun scripts/docker-local.mjs down",
    "docker:logs": "bun scripts/docker-local.mjs logs production",
    "docker:logs:local": "bun scripts/docker-local.mjs logs local",
    "docker:build": "bun scripts/docker-local.mjs build production",
    "docker:build:local": "bun scripts/docker-local.mjs build local",
    "hosts:check": "bun scripts/check-bichipishi-host.mjs",
    "build:astro": "bun ./node_modules/astro/astro.js build",
    "build:astro:node": "node ./node_modules/astro/astro.js build",
    "build": "bun run build:astro && cd metrics-api && bun server.js",
    "build:node": "bun run build:astro && cd metrics-api && node server.js",
    "preview": "bun run build:astro && cd metrics-api && bun server.js"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^5.0.0",
    "chart.js": "^4.4.0",
    "lucide": "^1.7.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "dotenv": "^16.6.1"
  }
}
