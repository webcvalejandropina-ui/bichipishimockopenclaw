{
  "name": "bichipishimockopenclaw",
  "version": "1.0.1",
  "private": true,
  "description": "Bichipishi — dashboard de métricas del sistema (Astro + API Node/Bun). Repo público.",
  "repository": {
    "type": "git",
    "url": "https://github.com/webcvalejandropina-ui/bichipishimockopenclaw.git"
  },
  "bugs": {
    "url": "https://github.com/webcvalejandropina-ui/bichipishimockopenclaw/issues"
  },
  "homepage": "https://github.com/webcvalejandropina-ui/bichipishimockopenclaw#readme",
  "workspaces": ["metrics-api"],
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "deploy": "node scripts/deploy.mjs",
    "deploy:bun": "bun scripts/deploy.mjs",
    "start": "bun metrics-api/server.js",
    "start:node": "node metrics-api/server.js",
    "dev": "bun scripts/dev.mjs",
    "dev:node": "node scripts/dev.mjs",
    "dev:api": "bun metrics-api/server.js",
    "dev:astro": "astro dev --host",
    "hosts:check": "node scripts/check-bichipishi-host.mjs",
    "proxy:dev": "caddy run --config ./config/caddy-bichipishi-dev.caddyfile",
    "proxy:prod": "caddy run --config ./config/caddy-bichipishi-prod.caddyfile",
    "build:astro": "astro build",
    "build": "astro build && bun metrics-api/server.js",
    "build:node": "astro build && node metrics-api/server.js",
    "preview": "astro build && bun metrics-api/server.js"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^5.0.0",
    "chart.js": "^4.4.0",
    "lucide": "^1.7.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "dotenv": "^16.6.1"
  }
}
