# ─── Marca (opcional; en build y SSR) ───
# Nombre en cabecera y título. Por defecto: Bichipishi.
PUBLIC_BICHI_APP_NAME=Bichipishi
# Imagen del perfil (URL https o ruta /ruta/en/tu/servidor.png). Vacío = piña por defecto.
# PUBLIC_BICHI_AVATAR_URL=https://ejemplo.com/mascota.png
# También puedes fijar marca en runtime: public/bichi-brand.js (window.__BICHI_BRAND__)
# o en Configuración → Marca (se guarda en data/settings.json y se sincroniza a .env vía API).

# ─── Bloque auto-generado por Configuración (no edites entre marcas) ───
# La API escribe # <<<BICHI_UI_CONFIG_START>>> … # <<<BICHI_UI_CONFIG_END>>> en .env con:
# PUBLIC_BICHI_APP_NAME, PUBLIC_BICHI_AVATAR_URL, BICHI_THRESHOLD_*, BICHI_ALERT_*,
# BICHI_SMTP_*, BICHI_MAIL_*, BICHI_LOG_STREAMS_JSON (JSON de streams extra en /logs).
# Tras guardar: por defecto la API se reinicia sola (proceso único: bun start / deploy).
# En `bun run dev` (concurrently) no se auto-reinicia; vuelve a lanzar dev para PUBLIC_*.
# BICHI_RESTART_ON_SETTINGS_SAVE=0  → no reiniciar proceso tras guardar
# BICHI_RESTART_CMD=…             → comando shell opcional (p. ej. systemctl restart …)

# ─── Servidor único: web (dist/) + API en el mismo puerto ───
BICHI_API_PORT=3001
PUBLIC_BICHI_API_PORT=3001
# Opcional: otro hostname en /etc/hosts (solo afecta al log de la API y allowedHosts de Vite)
# BICHI_PUBLIC_HOST=midominio.local
# HMR: por defecto 127.0.0.1:4322 (mismo puerto que Astro). Override si hace falta:
# BICHI_HMR_HOST=127.0.0.1
# BICHI_HMR_CLIENT_PORT=4322
# Sitio canónico (sitemap, etc.); en local suele bastar el valor por defecto del repo
# PUBLIC_BICHI_SITE_URL=http://127.0.0.1:4322

# ─── Datos persistentes (SQLite rendimiento + settings.json) ───
# Por defecto: carpeta data/ en la raíz del repo (misma en cada deploy).
# BICHI_DATA_DIR=/ruta/personalizada/data

# ─── Producción / seguridad ───
# BICHI_CORS_ORIGIN=https://tu-dominio.com
# PUBLIC_BICHI_API_URL=https://api.tu-dominio.com
# BICHI_DISABLE_SETTINGS_WRITE=1
# BICHI_SETTINGS_TOKEN=secreto
# BICHI_SKIP_PUBLIC_IP=1

# ─── Cron extra (opcional; ruta relativa = raíz del repo, no el cwd) ───
# CRON_EXTRA_FILE=config/cron.extra
# Si no defines CRON_EXTRA_FILE y existe config/cron.extra, la API lo lee igual.

# ─── OpenClaw (opcional; en otra máquina sin CLI no pasa nada) ───
# OPENCLAW_BIN=/ruta/al/bin/openclaw   # si el binario no está en el PATH de la API
# OPENCLAW_LOG_PATH=/ruta/al/log       # si existe, el panel puede activarse sin CLI
# OPENCLAW_FORCE=0                     # fuerza "no disponible" en métricas (cabecera sin depender de sondas)
# OPENCLAW_FORCE=1                     # fuerza disponible (solo si sabes lo que haces)
# OPENCLAW_FS_DISABLE=1                # no leer rutas en disco desde la API

# ─── Overrides manuales del host (casi nunca hace falta; la API lee el sistema) ───
# Ver config/host-identity.env.example

# ─── Docker Compose (opcional; experimental, ver README) ───
# Opcional: con esto, `docker compose up -d --build` (sin --profile) también levanta el stack de DESARROLLO.
# En servidor solo-producción, comenta o borra COMPOSE_PROFILES.
COMPOSE_PROFILES=local
#
# Desarrollo en Docker (recomendado; no depende de la línea anterior):
#   bun run docker:dev   |   make dev-docker
# Producción:
#   bun run docker:up    |   make docker-up
#   + Cloudflare Tunnel:               bun run docker:up:tunnel | bun run docker:up:local:tunnel
#     (los scripts ponen por defecto puerto 8080 en el host si no defines BICHI_PUBLISH / BICHI_DEV_API)
# Perfiles: production | web-only | local | full-host | tunnel
# TUNNEL_TOKEN=                    # Zero Trust → Tunnels (perfil tunnel)
#
# Puertos Docker (léeme si usas túnel):
# - En Cloudflare el origen suele ser http://bichipishi:3001 (red interna), NO el puerto del host.
# - Con bun run docker:up:tunnel el script usa 8080 EN EL HOST por defecto (BICHI_PUBLISH / BICHI_DEV_API)
#   si no defines nada — solo convención; cámbialo aquí (ej. BICHI_PUBLISH=9090).
# BICHI_PUBLISH=3001             # sin túnel: suele ser 3001. Con túnel y sin variable → script usa 8080
# BICHI_DEV_ASTRO=4322           # puerto host → Astro dev (perfil local)
# BICHI_DEV_API=3001             # sin túnel: suele 3001. Con túnel y sin variable → script usa 8080
# PUBLIC_BICHI_SITE_URL_DEV=http://127.0.0.1:4322  # canónico para Astro dev en Docker (perfil local)
