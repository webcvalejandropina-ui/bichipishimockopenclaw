# ─── Marca (opcional) ───
PUBLIC_BICHI_APP_NAME=Bichipishi
# PUBLIC_BICHI_AVATAR_URL=https://ejemplo.com/mascota.png

# ─── Dominio de la UI (Nginx) ───
# Edita config/site.env → BICHI_SITE_HOST (defecto bichipishi.home). /etc/hosts lo sincroniza bichi-docker-up.sh (scripts/bichi-ensure-hosts.sh).
# Puerto 80 por defecto; si ocupado: BICHI_WEB_PORT=8080

# ─── Docker: identidad de TU PC (obligatorio si no quieres datos del contenedor Linux) ───
# Plantilla con valores de ejemplo: config/host-identity.env.example → cópialas aquí descomentadas.
BICHI_HOST_HOSTNAME=mi-equipo
BICHI_HOST_DEVICE_NAME=Mi equipo
BICHI_HOST_OS=macOS 15
BICHI_MEM_TOTAL_GIB=16
BICHI_MEM_USED_GIB=8
# BICHI_HOST_UPTIME_SEC=86400
# BICHI_HOST_CPU_MODEL=Apple M1
# BICHI_HOST_CPU_CORES=8
# Montajes Linux opcionales en compose: /host/etc/os-release, /host/etc/hostname
# BICHI_HOST_OS_RELEASE_FILE=/host/etc/os-release
# BICHI_HOST_HOSTNAME_FILE=/host/etc/hostname

# ─── OpenClaw: log del host montado en el contenedor ───
# OPENCLAW_LOG_PATH=/ruta/en/contenedor/al/archivo.log
# OPENCLAW_FORCE=1

# ─── Dev local (Astro + API en el host) ───
BICHI_API_PORT=3001
PUBLIC_BICHI_API_PORT=3001
# PUBLIC_BICHI_API_URL=https://api.ejemplo.com
# BICHI_CORS_ORIGIN=...
# BICHI_DISABLE_SETTINGS_WRITE=1
# BICHI_SKIP_PUBLIC_IP=1
# CRON_EXTRA_FILE=config/cron.extra
