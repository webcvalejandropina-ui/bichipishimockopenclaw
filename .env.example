# ─── Marca (opcional) ───
PUBLIC_BICHI_APP_NAME=Bichipishi
# PUBLIC_BICHI_AVATAR_URL=https://ejemplo.com/mascota.png

# ─── Servidor único: web (dist/) + API en el mismo puerto ───
BICHI_API_PORT=3001
PUBLIC_BICHI_API_PORT=3001
# Dominio local (hosts + Caddy :80 -> sin puerto en la URL; ver config/bichipishi.hosts)
BICHI_PUBLIC_HOST=bichipishi.home
# HMR de Vite: 80 con Caddy; si entras solo por http://127.0.0.1:4322 pon 4322
BICHI_HMR_CLIENT_PORT=80

# ─── Datos persistentes (SQLite rendimiento + settings.json) ───
# Por defecto: carpeta data/ en la raíz del repo (misma en cada deploy).
# BICHI_DATA_DIR=/ruta/personalizada/data

# ─── Producción / seguridad ───
# BICHI_CORS_ORIGIN=https://tu-dominio.com
# PUBLIC_BICHI_API_URL=https://api.tu-dominio.com
# BICHI_DISABLE_SETTINGS_WRITE=1
# BICHI_SETTINGS_TOKEN=secreto
# BICHI_SKIP_PUBLIC_IP=1

# ─── Cron extra (opcional; ruta relativa = raíz del repo, no el cwd) ───
# CRON_EXTRA_FILE=config/cron.extra
# Si no defines CRON_EXTRA_FILE y existe config/cron.extra, la API lo lee igual.

# ─── OpenClaw (opcional) ───
# OPENCLAW_LOG_PATH=/ruta/al/log
# OPENCLAW_FORCE=1

# ─── Overrides manuales del host (casi nunca hace falta; la API lee el sistema) ───
# Ver config/host-identity.env.example
