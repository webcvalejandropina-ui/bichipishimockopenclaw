# Puerto de metrics-api (mismo valor en ambas líneas para dev local).
# El proxy de Astro (Vite) y el cliente usan PUBLIC_BICHI_API_PORT en los fallbacks.
BICHI_API_PORT=3001
PUBLIC_BICHI_API_PORT=3001

# Solo si la web estática y la API están en distintos orígenes HTTPS:
# PUBLIC_BICHI_API_URL=https://api.ejemplo.com

# API en red abierta (opcional, ver README del servidor):
# BICHI_CORS_ORIGIN=...
# BICHI_DISABLE_SETTINGS_WRITE=1

# Cron adicional (fichero estilo crontab). La API también lee crontab -l y /etc/crontab cuando existen.
# Ruta relativa al directorio desde el que arrancas `node metrics-api/server.js` (suele ser la raíz del repo).
# CRON_EXTRA_FILE=config/cron.extra
