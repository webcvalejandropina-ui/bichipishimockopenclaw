# ─── Marca (opcional; por defecto: nombre Bichipishi y piña integrada) ───
# Nombre en cabecera, título del navegador, asuntos de correo de la API y textos relacionados.
PUBLIC_BICHI_APP_NAME=Bichipishi
# URL de imagen del avatar del dashboard (sustituye la piña). Debe ser accesible desde el navegador (HTTPS recomendado).
# PUBLIC_BICHI_AVATAR_URL=https://ejemplo.com/mi-mascota.png

# Puerto de metrics-api (mismo valor en ambas líneas para dev local).
# El proxy de Astro (Vite) y el cliente usan PUBLIC_BICHI_API_PORT en los fallbacks.
BICHI_API_PORT=3001
PUBLIC_BICHI_API_PORT=3001

# Solo si la web estática y la API están en distintos orígenes HTTPS:
# PUBLIC_BICHI_API_URL=https://api.ejemplo.com

# API en red abierta (opcional, ver README del servidor):
# BICHI_CORS_ORIGIN=...
# BICHI_DISABLE_SETTINGS_WRITE=1

# Si la API corre en Docker y la RAM total no coincide con el host (cgroup), fija el total en GiB (p. ej. 8).
# BICHI_MEM_TOTAL_GIB=8

# No consultar IP pública (ipify / similares); menos latencia y sin salida a Internet.
# BICHI_SKIP_PUBLIC_IP=1

# Cron adicional (fichero estilo crontab). La API también lee crontab -l y /etc/crontab cuando existen.
# Ruta relativa al directorio desde el que arrancas `node metrics-api/server.js` (suele ser la raíz del repo).
# CRON_EXTRA_FILE=config/cron.extra
