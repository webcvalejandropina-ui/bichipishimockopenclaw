# ─── Marca (opcional) ───
PUBLIC_BICHI_APP_NAME=Bichipishi
# PUBLIC_BICHI_AVATAR_URL=https://ejemplo.com/mascota.png

# ─── Puerto de la web en Docker (evita choques con otras apps) ───
BICHI_WEB_PORT=8080

# ─── Nombre de host en el navegador (recomendado) ───
# 1) Edita el archivo "hosts" del sistema y añade una línea:
#    127.0.0.1 bichipishi.local
#    Windows: C:\Windows\System32\drivers\etc\hosts  (Bloc de notas como admin)
#    Mac/Linux: /etc/hosts
# 2) Abre: http://bichipishi.local:8080  (o el puerto de BICHI_WEB_PORT)

# ─── En Docker: tu PC REAL (sin esto verás datos del contenedor Linux) ───
# Copia los valores de tu sistema (nombre del equipo, SO, RAM…).
# BICHI_HOST_HOSTNAME=DESKTOP-ABC
# BICHI_HOST_DEVICE_NAME=Mi PC
# BICHI_HOST_OS=Windows 11
# BICHI_MEM_TOTAL_GIB=16
# BICHI_MEM_USED_GIB=9.2
# BICHI_HOST_UPTIME_SEC=86400
# BICHI_HOST_CPU_MODEL=AMD Ryzen 5
# BICHI_HOST_CPU_CORES=12
# Rutas dentro del contenedor si montas os-release/hostname del anfitrión:
# BICHI_HOST_OS_RELEASE_FILE=/host/etc/os-release
# BICHI_HOST_HOSTNAME_FILE=/host/etc/hostname

# ─── OpenClaw: log del host montado en el contenedor ───
# OPENCLAW_LOG_PATH=/ruta/en/contenedor/al/archivo.log
# OPENCLAW_FORCE=1

# ─── Dev local (Astro + API en el host) ───
BICHI_API_PORT=3001
PUBLIC_BICHI_API_PORT=3001
# PUBLIC_BICHI_API_URL=https://api.ejemplo.com
# BICHI_CORS_ORIGIN=...
# BICHI_DISABLE_SETTINGS_WRITE=1
# BICHI_SKIP_PUBLIC_IP=1
# CRON_EXTRA_FILE=config/cron.extra
