---
import Layout from '../layouts/Layout.astro';
import SistemaSectionTabs from '../components/SistemaSectionTabs.astro';
import { iconToSvg } from '../lib/lucide-svg-string';
import { Cpu, MemoryStick, HardDrive, Clock, Monitor, RefreshCw, CircuitBoard, Copy, Info } from 'lucide';

const iPageTitle = iconToSvg(Monitor, { width: 22, height: 22 });
const icons = {
  cpu: iconToSvg(Cpu, { width: 18, height: 18 }),
  mem: iconToSvg(MemoryStick, { width: 18, height: 18 }),
  disk: iconToSvg(HardDrive, { width: 18, height: 18 }),
  gpu: iconToSvg(CircuitBoard, { width: 18, height: 18 }),
  clock: iconToSvg(Clock, { width: 18, height: 18 }),
  monitor: iconToSvg(Monitor, { width: 18, height: 18 }),
  /** Marcas de agua en tarjetas Sistema (esquina superior derecha, criterio Docker .info-card--svc::before) */
  monitorBg: iconToSvg(Monitor, { width: 200, height: 200, 'stroke-width': 1.35 }),
  cpuBg: iconToSvg(Cpu, { width: 200, height: 200, 'stroke-width': 1.35 }),
  memBg: iconToSvg(MemoryStick, { width: 200, height: 200, 'stroke-width': 1.35 }),
  diskBg: iconToSvg(HardDrive, { width: 200, height: 200, 'stroke-width': 1.35 }),
  gpuBg: iconToSvg(CircuitBoard, { width: 200, height: 200, 'stroke-width': 1.35 }),
  clockBg: iconToSvg(Clock, { width: 200, height: 200, 'stroke-width': 1.35 }),
  refresh: iconToSvg(RefreshCw, { width: 16, height: 16 }),
  copy: iconToSvg(Copy, { width: 14, height: 14 }),
  info: iconToSvg(Info, { width: 16, height: 16 }),
};
---
<Layout activePage="sistema">
  <div class="wrapper dk-page sistema-page sys-page">
    <span class="page-header__watermark" set:html={iPageTitle} aria-hidden="true" />
    <div class="page-header">
      <div class="dk-page-title-row">
        <div>
          <h2 class="page-title">Sistema</h2>
          <p class="page-desc">Hardware, uso de recursos y tiempo de actividad del host que ejecuta la API.</p>
        </div>
      </div>
    </div>

    <SistemaSectionTabs active="sistema" />

    <div class="sys-top-row">
      <button
        type="button"
        class="page-icon-btn sys-refresh-btn"
        id="sys-refresh"
        aria-label="Actualizar métricas del host"
        title="Volver a pedir datos a la API"
      >
        <span set:html={icons.refresh} aria-hidden="true" />
      </button>
      <div class="sys-feedback sys-feedback--inline" id="sys-feedback" aria-live="polite">
        <span class="sys-feedback__status" id="sys-feedback-text">Sincronizando con la API…</span>
        <span class="sys-feedback__meta" id="sys-feedback-meta"></span>
      </div>
    </div>

    <p class="sys-page-results" id="sys-results">Cargando…</p>

    <div class="page-stat-strip sys-stat-strip" id="sys-stat-strip" aria-label="Resumen rápido">
      <div class="page-stat dashboard-stat-chip" data-metric="cpu">
        <span class="info-card-icon blue" set:html={icons.cpu} aria-hidden="true" />
        <span class="dashboard-stat-chip__pair">
          <span class="page-stat-value skeleton" id="st-cpu">—</span>
          <span class="page-stat-label">CPU</span>
        </span>
      </div>
      <div class="page-stat dashboard-stat-chip dashboard-stat-chip--accent" data-metric="mem">
        <span class="info-card-icon gold" set:html={icons.mem} aria-hidden="true" />
        <span class="dashboard-stat-chip__pair">
          <span class="page-stat-value skeleton" id="st-mem">—</span>
          <span class="page-stat-label">RAM</span>
        </span>
      </div>
      <div class="page-stat dashboard-stat-chip" data-metric="disk">
        <span class="info-card-icon yellow" set:html={icons.disk} aria-hidden="true" />
        <span class="dashboard-stat-chip__pair">
          <span class="page-stat-value skeleton" id="st-disk">—</span>
          <span class="page-stat-label">Disco</span>
        </span>
      </div>
      <div class="page-stat dashboard-stat-chip" data-metric="gpu">
        <span class="info-card-icon green" set:html={icons.gpu} aria-hidden="true" />
        <span class="dashboard-stat-chip__pair">
          <span class="page-stat-value skeleton" id="st-gpu">—</span>
          <span class="page-stat-label">GPU</span>
        </span>
      </div>
      <div class="page-stat dashboard-stat-chip" data-metric="uptime">
        <span class="info-card-icon blue" set:html={icons.clock} aria-hidden="true" />
        <span class="dashboard-stat-chip__pair">
          <span class="page-stat-value page-stat-value--uptime skeleton" id="st-uptime">—</span>
          <span class="page-stat-label">Uptime</span>
        </span>
      </div>
    </div>

    <div class="sys-panel-grid" id="sys-panels">
      <div class="sys-panel sys-panel--dk-watermark">
        <span class="sys-panel-bg-icon" aria-hidden="true" set:html={icons.monitorBg} />
        <div class="info-card-header sys-panel-heading sys-panel-heading--title-only">
          <h3 class="info-card-title sys-panel-title">Información del sistema</h3>
        </div>
        <div class="sys-grid sys-grid--dense">
          <div class="sys-item sys-item--full">
            <span class="sys-key">Nombre del equipo</span>
            <div class="sys-item-value dk-field-row">
              <span class="sys-val skeleton sys-val--wrap dk-field-row__text" id="si-device">—</span>
              <button type="button" class="dk-copy-btn" data-si-copy-target="si-device" aria-label="Copiar nombre del equipo" title="Copiar">
                <span set:html={icons.copy} aria-hidden="true" />
              </button>
            </div>
          </div>
          <div class="sys-item sys-item--full">
            <span class="sys-key">Hostname</span>
            <div class="sys-item-value dk-field-row">
              <span class="sys-val skeleton sys-val--wrap dk-field-row__text" id="si-host">—</span>
              <button type="button" class="dk-copy-btn" data-si-copy-target="si-host" aria-label="Copiar hostname" title="Copiar">
                <span set:html={icons.copy} aria-hidden="true" />
              </button>
            </div>
          </div>
          <div class="sys-item sys-item--full">
            <span class="sys-key">Sistema operativo</span>
            <div class="sys-item-value dk-field-row">
              <span class="sys-val skeleton sys-val--wrap dk-field-row__text" id="si-platform">—</span>
              <button type="button" class="dk-copy-btn" data-si-copy-target="si-platform" aria-label="Copiar sistema operativo" title="Copiar">
                <span set:html={icons.copy} aria-hidden="true" />
              </button>
            </div>
          </div>
          <div class="sys-item sys-item--full">
            <span class="sys-key">Red (IPv4)</span>
            <div class="sys-item-value dk-field-row">
              <span class="sys-val skeleton sys-val--wrap dk-field-row__text" id="si-ipv4">—</span>
              <button type="button" class="dk-copy-btn" data-si-copy-target="si-ipv4" aria-label="Copiar direcciones IPv4" title="Copiar">
                <span set:html={icons.copy} aria-hidden="true" />
              </button>
            </div>
          </div>
          <div class="sys-item sys-item--full">
            <span class="sys-key">Última lectura</span>
            <div class="sys-item-value dk-field-row">
              <span class="sys-val skeleton dk-field-row__text" id="si-updated">—</span>
              <button type="button" class="dk-copy-btn" data-si-copy-target="si-updated" aria-label="Copiar fecha de lectura" title="Copiar">
                <span set:html={icons.copy} aria-hidden="true" />
              </button>
            </div>
          </div>
        </div>
        <p class="sys-mem-note sys-panel-footnote" id="si-host-note" hidden>
          <span class="info-card-icon gold sys-panel-footnote__ico" aria-hidden="true" set:html={icons.info} />
          <span class="sys-panel-footnote__text"></span>
        </p>
        <button type="button" class="sistema-copy-summary" id="si-copy-summary">Copiar resumen de esta tarjeta</button>
      </div>

      <div class="sys-panel sys-panel--dk-watermark">
        <span class="sys-panel-bg-icon" aria-hidden="true" set:html={icons.cpuBg} />
        <div class="info-card-header sys-panel-heading sys-panel-heading--title-only">
          <h3 class="info-card-title sys-panel-title">Procesador</h3>
        </div>
        <div class="sys-grid sys-grid--dense">
          <div class="sys-item sys-item--full">
            <span class="sys-key">Modelo</span>
            <div class="sys-item-value dk-field-row">
              <span class="sys-val skeleton sys-val--wrap dk-field-row__text" id="si-cpu-model">—</span>
              <button type="button" class="dk-copy-btn" data-si-copy-target="si-cpu-model" aria-label="Copiar modelo de CPU" title="Copiar">
                <span set:html={icons.copy} aria-hidden="true" />
              </button>
            </div>
          </div>
          <div class="sys-item">
            <span class="sys-key">Núcleos</span>
            <div class="sys-item-value dk-field-row">
              <span class="sys-val skeleton dk-field-row__text" id="si-cpu-cores">—</span>
              <button type="button" class="dk-copy-btn" data-si-copy-target="si-cpu-cores" aria-label="Copiar número de núcleos" title="Copiar">
                <span set:html={icons.copy} aria-hidden="true" />
              </button>
            </div>
          </div>
          <div class="sys-item"><span class="sys-key">Uso</span><span class="sys-val skeleton" id="si-cpu-pct">—</span></div>
          <div class="sys-item sys-item--full">
            <span class="sys-key">Carga</span>
            <div class="sys-item-value dk-field-row">
              <span class="sys-val skeleton sys-val--wrap dk-field-row__text" id="si-load">—</span>
              <button type="button" class="dk-copy-btn" data-si-copy-target="si-load" aria-label="Copiar carga media" title="Copiar">
                <span set:html={icons.copy} aria-hidden="true" />
              </button>
            </div>
          </div>
        </div>
      </div>

      <div class="sys-panel sys-panel--dk-watermark">
        <span class="sys-panel-bg-icon" aria-hidden="true" set:html={icons.memBg} />
        <div class="info-card-header sys-panel-heading sys-panel-heading--title-only">
          <h3 class="info-card-title sys-panel-title">Memoria RAM</h3>
        </div>
        <div class="sys-grid sys-grid--dense">
          <div class="sys-item">
            <span class="sys-key">Total</span>
            <div class="sys-item-value dk-field-row">
              <span class="sys-val skeleton dk-field-row__text" id="si-mem-total">—</span>
              <button type="button" class="dk-copy-btn" data-si-copy-target="si-mem-total" aria-label="Copiar RAM total" title="Copiar">
                <span set:html={icons.copy} aria-hidden="true" />
              </button>
            </div>
          </div>
          <div class="sys-item">
            <span class="sys-key">Usado</span>
            <div class="sys-item-value dk-field-row">
              <span class="sys-val skeleton dk-field-row__text" id="si-mem-used">—</span>
              <button type="button" class="dk-copy-btn" data-si-copy-target="si-mem-used" aria-label="Copiar RAM usada" title="Copiar">
                <span set:html={icons.copy} aria-hidden="true" />
              </button>
            </div>
          </div>
          <div class="sys-item"><span class="sys-key">Uso</span><span class="sys-val skeleton" id="si-mem-pct">—</span></div>
        </div>
        <div class="sys-meter">
          <div class="sys-meter-track"><div class="sys-meter-fill" id="si-mem-bar" style="width:0%"></div></div>
          <div class="sys-meter-foot"><span>0%</span><span id="si-mem-foot">100%</span></div>
        </div>
        <p class="sys-mem-note sys-panel-footnote" id="si-mem-note" hidden>
          <span class="info-card-icon gold sys-panel-footnote__ico" aria-hidden="true" set:html={icons.info} />
          <span class="sys-panel-footnote__text"></span>
        </p>
      </div>

      <div class="sys-panel sys-panel--dk-watermark sys-panel--disk">
        <span class="sys-panel-bg-icon" aria-hidden="true" set:html={icons.diskBg} />
        <div class="info-card-header sys-panel-heading sys-panel-heading--title-only">
          <h3 class="info-card-title sys-panel-title">Disco principal</h3>
        </div>
        <div class="sys-grid sys-grid--dense">
          <div class="sys-item">
            <span class="sys-key">Total</span>
            <div class="sys-item-value dk-field-row">
              <span class="sys-val skeleton sys-val--wrap dk-field-row__text" id="si-disk-total">—</span>
              <button type="button" class="dk-copy-btn" data-si-copy-target="si-disk-total" aria-label="Copiar tamaño total" title="Copiar">
                <span set:html={icons.copy} aria-hidden="true" />
              </button>
            </div>
          </div>
          <div class="sys-item">
            <span class="sys-key">Libre</span>
            <div class="sys-item-value dk-field-row">
              <span class="sys-val skeleton sys-val--wrap dk-field-row__text" id="si-disk-free">—</span>
              <button type="button" class="dk-copy-btn" data-si-copy-target="si-disk-free" aria-label="Copiar espacio libre" title="Copiar">
                <span set:html={icons.copy} aria-hidden="true" />
              </button>
            </div>
          </div>
          <div class="sys-item">
            <span class="sys-key">Usado</span>
            <div class="sys-item-value dk-field-row">
              <span class="sys-val skeleton sys-val--wrap dk-field-row__text" id="si-disk-used">—</span>
              <button type="button" class="dk-copy-btn" data-si-copy-target="si-disk-used" aria-label="Copiar espacio usado" title="Copiar">
                <span set:html={icons.copy} aria-hidden="true" />
              </button>
            </div>
          </div>
          <div class="sys-item"><span class="sys-key">Uso</span><span class="sys-val skeleton" id="si-disk-pct">—</span></div>
        </div>
        <div class="sys-meter">
          <div class="sys-meter-track"><div class="sys-meter-fill sys-meter-fill--disk" id="si-disk-bar" style="width:0%"></div></div>
          <div class="sys-meter-foot"><span>0%</span><span id="si-disk-foot">100%</span></div>
        </div>
        <p class="sys-mem-note sys-panel-footnote" id="si-disk-note" hidden>
          <span class="info-card-icon yellow sys-panel-footnote__ico" aria-hidden="true" set:html={icons.info} />
          <span class="sys-panel-footnote__text"></span>
        </p>
      </div>

      <div class="sys-panel sys-panel--dk-watermark">
        <span class="sys-panel-bg-icon" aria-hidden="true" set:html={icons.gpuBg} />
        <div class="info-card-header sys-panel-heading sys-panel-heading--title-only">
          <h3 class="info-card-title sys-panel-title">GPU</h3>
        </div>
        <div class="sys-grid sys-grid--dense">
          <div class="sys-item sys-item--full">
            <span class="sys-key">Modelo</span>
            <div class="sys-item-value dk-field-row">
              <span class="sys-val skeleton sys-val--wrap dk-field-row__text" id="si-gpu-model">—</span>
              <button type="button" class="dk-copy-btn" data-si-copy-target="si-gpu-model" aria-label="Copiar modelo de GPU" title="Copiar">
                <span set:html={icons.copy} aria-hidden="true" />
              </button>
            </div>
          </div>
          <div class="sys-item">
            <span class="sys-key">VRAM</span>
            <div class="sys-item-value dk-field-row">
              <span class="sys-val skeleton dk-field-row__text" id="si-gpu-vram">—</span>
              <button type="button" class="dk-copy-btn" data-si-copy-target="si-gpu-vram" aria-label="Copiar VRAM" title="Copiar">
                <span set:html={icons.copy} aria-hidden="true" />
              </button>
            </div>
          </div>
          <div class="sys-item"><span class="sys-key">Uso</span><span class="sys-val skeleton" id="si-gpu-pct">—</span></div>
        </div>
        <div class="sys-meter">
          <div class="sys-meter-track"><div class="sys-meter-fill" id="si-gpu-bar" style="width:0%"></div></div>
          <div class="sys-meter-foot"><span>0%</span><span id="si-gpu-foot">100%</span></div>
        </div>
        <p class="sys-mem-note sys-panel-footnote" id="si-gpu-note" hidden>
          <span class="info-card-icon yellow sys-panel-footnote__ico" aria-hidden="true" set:html={icons.info} />
          <span class="sys-panel-footnote__text"></span>
        </p>
      </div>

      <div class="sys-panel sys-panel--dk-watermark">
        <span class="sys-panel-bg-icon" aria-hidden="true" set:html={icons.clockBg} />
        <div class="info-card-header sys-panel-heading sys-panel-heading--title-only">
          <h3 class="info-card-title sys-panel-title">Tiempo</h3>
        </div>
        <div class="sys-grid sys-grid--dense">
          <div class="sys-item">
            <span class="sys-key">Uptime</span>
            <div class="sys-item-value dk-field-row">
              <span class="sys-val skeleton dk-field-row__text" id="si-uptime">—</span>
              <button type="button" class="dk-copy-btn" data-si-copy-target="si-uptime" aria-label="Copiar uptime" title="Copiar">
                <span set:html={icons.copy} aria-hidden="true" />
              </button>
            </div>
          </div>
          <div class="sys-item">
            <span class="sys-key">Hora</span>
            <div class="sys-item-value dk-field-row">
              <span class="sys-val dk-field-row__text" id="si-time">—</span>
              <button type="button" class="dk-copy-btn" data-si-copy-target="si-time" aria-label="Copiar hora" title="Copiar">
                <span set:html={icons.copy} aria-hidden="true" />
              </button>
            </div>
          </div>
          <div class="sys-item sys-item--full">
            <span class="sys-key">Fecha</span>
            <div class="sys-item-value dk-field-row">
              <span class="sys-val sys-val--wrap dk-field-row__text" id="si-date">—</span>
              <button type="button" class="dk-copy-btn" data-si-copy-target="si-date" aria-label="Copiar fecha" title="Copiar">
                <span set:html={icons.copy} aria-hidden="true" />
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    import {
      fetchMetrics,
      updateHeader,
      fmtUptime,
      statusColor,
      metricsRepresentHost,
      hasValidSystemUptime,
      healthLevel,
    } from '../lib/metrics';
    import { copyTextToClipboard } from '../lib/copy-field';

    const $ = (id: string) => document.getElementById(id)!;

    function setSiField(id: string, display: string, copyOverride?: string) {
      const el = document.getElementById(id) as HTMLElement | null;
      if (!el) return;
      el.textContent = display;
      el.classList.remove('skeleton');
      const forClip = (copyOverride !== undefined ? copyOverride : display).trim();
      if (forClip && forClip !== '—') el.dataset.copyText = forClip;
      else delete el.dataset.copyText;
    }

    /** Nota al pie con icono tipo Docker (badge + texto) */
    function setSysFootnote(wrapperId: string, text: string, multiline = false) {
      const wrap = document.getElementById(wrapperId);
      const textEl = wrap?.querySelector('.sys-panel-footnote__text');
      if (!wrap || !textEl) return;
      const t = text.trim();
      if (t) {
        textEl.textContent = t;
        if (multiline) (textEl as HTMLElement).style.whiteSpace = 'pre-line';
        else (textEl as HTMLElement).style.removeProperty('white-space');
        wrap.removeAttribute('hidden');
      } else {
        textEl.textContent = '';
        (textEl as HTMLElement).style.removeProperty('white-space');
        wrap.setAttribute('hidden', '');
      }
    }

    function wireSistemaCopyButtons() {
      const panels = document.getElementById('sys-panels');
      if (!panels || (panels as HTMLElement & { _bichiSiCopy?: boolean })._bichiSiCopy) return;
      (panels as HTMLElement & { _bichiSiCopy?: boolean })._bichiSiCopy = true;
      panels.addEventListener('click', (ev) => {
        const btn = (ev.target as HTMLElement).closest('[data-si-copy-target]') as HTMLButtonElement | null;
        if (!btn || !panels.contains(btn)) return;
        const tid = btn.dataset.siCopyTarget;
        if (!tid) return;
        const el = document.getElementById(tid);
        const raw = (el as HTMLElement | null)?.dataset.copyText ?? el?.textContent?.trim() ?? '';
        void copyTextToClipboard(raw).then((ok) => {
          if (ok) {
            btn.classList.add('is-copied');
            window.setTimeout(() => btn.classList.remove('is-copied'), 1200);
          }
        });
      });

      const SI_SUMMARY_LABELS: [string, string][] = [
        ['Nombre del equipo', 'si-device'],
        ['Hostname', 'si-host'],
        ['Sistema operativo', 'si-platform'],
        ['Red (IPv4)', 'si-ipv4'],
        ['Última lectura', 'si-updated'],
      ];
      const summaryBtn = document.getElementById('si-copy-summary');
      summaryBtn?.addEventListener('click', () => {
        const lines = SI_SUMMARY_LABELS.map(([label, id]) => {
          const el = document.getElementById(id);
          const v = ((el as HTMLElement | null)?.dataset.copyText ?? el?.textContent ?? '').trim() || '—';
          return `${label}: ${v}`;
        });
        void copyTextToClipboard(lines.join('\n')).then((ok) => {
          if (ok && summaryBtn) {
            summaryBtn.classList.add('is-copied');
            window.setTimeout(() => summaryBtn.classList.remove('is-copied'), 1200);
          }
        });
      });
    }

    function updateTime() {
      const now = new Date();
      $('si-time').textContent = now.toLocaleTimeString('es-ES');
      $('si-date').textContent = now.toLocaleDateString('es-ES', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
    }
    updateTime();
    setInterval(updateTime, 1000);

    function normalizeGpuLabel(s: string): string {
      return s.replace(/\bApple\s+Apple\b/gi, 'Apple').trim();
    }

    function pickGpuModel(d: any): string {
      const direct = typeof d.gpuModel === 'string' && d.gpuModel.trim() ? d.gpuModel.trim() : '';
      if (direct) return normalizeGpuLabel(direct);
      const ctrls = Array.isArray(d.gpuControllers) ? d.gpuControllers : [];
      for (const c of ctrls) {
        const s = [c.vendor, c.model]
          .filter((x: unknown) => typeof x === 'string' && String(x).trim())
          .join(' ')
          .trim();
        if (s) return normalizeGpuLabel(s);
      }
      return '';
    }

    function setSysResults(text: string) {
      const el = document.getElementById('sys-results');
      if (el) el.textContent = text;
    }

    function setSysFeedback(status: string, meta = '') {
      $('sys-feedback-text').textContent = status;
      $('sys-feedback-meta').textContent = meta;
    }

    function fmtClock(ts: number) {
      try {
        return new Date(ts).toLocaleTimeString('es-ES', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
      } catch {
        return '—';
      }
    }

    async function load() {
      try {
        setSysFeedback('Actualizando…', '/api/metrics');
        const d = await fetchMetrics();
        updateHeader(d);
        const hostOk = metricsRepresentHost(d);

        const set = (id: string, v: string) => {
          const e = $(id);
          e.textContent = v;
          e.classList.remove('skeleton');
        };

        const pct = (v: unknown) => (hostOk && v != null && Number.isFinite(Number(v)) ? `${Math.round(Number(v))}%` : '—');
        set('st-cpu', pct(d.cpu));
        set('st-mem', pct(d.mem));
        set('st-disk', pct(d.disk));
        const gpuU = hostOk && d.gpu != null ? Number(d.gpu) : NaN;
        const gpuModelStr = pickGpuModel(d);
        if (Number.isFinite(gpuU)) set('st-gpu', pct(d.gpu));
        else if (gpuModelStr) {
          const short = gpuModelStr.length > 26 ? `${gpuModelStr.slice(0, 24)}…` : gpuModelStr;
          set('st-gpu', short);
        } else set('st-gpu', '—');
        set('st-uptime', hostOk && hasValidSystemUptime(d.uptime) ? fmtUptime(d.uptime) : '—');

        const cpuN = hostOk && d.cpu != null ? Number(d.cpu) : NaN;
        const memN = hostOk && d.mem != null ? Number(d.mem) : NaN;
        const diskN = hostOk && d.disk != null ? Number(d.disk) : NaN;
        const hl =
          hostOk && Number.isFinite(cpuN) && Number.isFinite(memN) && Number.isFinite(diskN)
            ? healthLevel(cpuN, memN, diskN)
            : 'ok';
        const hlLabel: Record<string, string> = { ok: 'Estable', warn: 'Atención', crit: 'Crítico' };
        setSysResults('Mismo origen que el panel principal: API en el host.');
        setSysFeedback(
          hostOk
            ? `Salud: ${hlLabel[hl] ?? hl} · ${Number.isFinite(cpuN) ? `${Math.round(cpuN)}%` : '—'} CPU`
            : 'Sin métricas del PC (API en contenedor)',
          `${fmtClock(d.timestamp)} · auto 12s`,
        );

        const hostOs = typeof d.hostOs === 'string' && d.hostOs.trim() ? d.hostOs.trim() : '—';
        const devName = typeof d.deviceName === 'string' && d.deviceName.trim() ? d.deviceName.trim() : '';
        const ips = Array.isArray(d.hostIpv4) ? d.hostIpv4.filter((x: unknown) => typeof x === 'string' && x.trim()) : [];
        const locals = ips.length ? ips.join(', ') : '';
        const pub = String(d.publicIp || '').trim();
        const ipv4Str =
          pub && locals
            ? `${pub} · ${locals}`
            : pub || locals || '—';
        const ipv4Fly =
          pub && locals
            ? `Pública: ${pub}\nLocales: ${locals}`
            : pub
              ? `Pública: ${pub}`
              : locals || '—';
        const updatedStr = new Date(d.timestamp).toLocaleString('es-ES', { dateStyle: 'short', timeStyle: 'medium' });
        setSiField('si-device', devName || d.hostname || '—');
        setSiField('si-host', d.hostname || '—');
        setSiField('si-platform', hostOs);
        setSiField('si-ipv4', ipv4Str, ipv4Fly);
        setSiField('si-updated', updatedStr);

        setSiField('si-cpu-model', d.cpuModel || '—');
        setSiField('si-cpu-cores', String(d.cpuCores ?? '—'));
        set('si-cpu-pct', pct(d.cpu));
        ($('si-cpu-pct') as HTMLElement).style.color =
          hostOk && d.cpu != null ? statusColor(Number(d.cpu), 'cpu') : 'var(--muted)';
        setSiField(
          'si-load',
          hostOk && Array.isArray(d.load) && d.load.length ? d.load.map((l: number) => l.toFixed(2)).join(' / ') : '—',
        );

        setSiField('si-mem-total', d.memTotal != null ? `${d.memTotal} GiB` : '—');
        setSiField('si-mem-used', d.memUsed != null ? `${d.memUsed} GiB` : '—');
        set('si-mem-pct', pct(d.mem));
        ($('si-mem-pct') as HTMLElement).style.color =
          hostOk && d.mem != null ? statusColor(Number(d.mem), 'mem') : 'var(--muted)';
        const memPct = hostOk && d.mem != null ? Math.min(100, Math.max(0, Number(d.mem))) : 0;
        ($('si-mem-bar') as HTMLElement).style.width = `${memPct}%`;
        ($('si-mem-bar') as HTMLElement).style.background =
          hostOk && d.mem != null ? statusColor(Number(d.mem), 'mem') : 'var(--bar-bg)';
        $('si-mem-foot').textContent = hostOk && d.mem != null ? `${Math.round(memPct)}%` : '—';

        const note = typeof d.memNote === 'string' ? d.memNote.trim() : '';
        setSysFootnote('si-mem-note', note, false);

        const hnote =
          typeof (d as { hostMetricsNote?: string }).hostMetricsNote === 'string'
            ? String((d as { hostMetricsNote?: string }).hostMetricsNote).trim()
            : '';
        setSysFootnote('si-host-note', hnote, true);

        const diskTotal = typeof d.diskTotal === 'number' && d.diskTotal > 0 ? d.diskTotal : null;
        setSiField('si-disk-total', diskTotal != null ? `${diskTotal} GiB` : '—');
        setSiField(
          'si-disk-free',
          d.diskFree != null && Number.isFinite(Number(d.diskFree)) ? `${d.diskFree} GiB` : '—',
        );
        setSiField('si-disk-used', d.diskUsed != null ? `${d.diskUsed} GiB` : '—');
        set('si-disk-pct', pct(d.disk));
        ($('si-disk-pct') as HTMLElement).style.color =
          hostOk && d.disk != null ? statusColor(Number(d.disk), 'disk') : 'var(--muted)';
        const diskPct = hostOk && d.disk != null ? Math.min(100, Math.max(0, Number(d.disk))) : 0;
        ($('si-disk-bar') as HTMLElement).style.width = `${diskPct}%`;
        ($('si-disk-bar') as HTMLElement).style.background =
          hostOk && d.disk != null ? statusColor(Number(d.disk), 'disk') : 'var(--bar-bg)';
        $('si-disk-foot').textContent = hostOk && d.disk != null ? `${Math.round(diskPct)}%` : '—';

        const dnote = typeof (d as { diskNote?: string }).diskNote === 'string' ? String((d as { diskNote?: string }).diskNote).trim() : '';
        const dmount =
          typeof (d as { diskMount?: string }).diskMount === 'string' ? String((d as { diskMount?: string }).diskMount).trim() : '';
        const diskFoot = [dmount && `Montaje: ${dmount}`, dnote].filter(Boolean).join('\n');
        setSysFootnote('si-disk-note', diskFoot, true);

        setSiField('si-gpu-model', gpuModelStr ? gpuModelStr : '—');
        const vramMb = typeof d.gpuVramMb === 'number' && d.gpuVramMb > 0 ? d.gpuVramMb : null;
        setSiField('si-gpu-vram', vramMb != null ? `${vramMb} MB` : '—');
        set('si-gpu-pct', pct(d.gpu));
        ($('si-gpu-pct') as HTMLElement).style.color =
          hostOk && Number.isFinite(gpuU) ? statusColor(gpuU, 'gpu') : 'var(--muted)';
        const gpuBarPct = hostOk && Number.isFinite(gpuU) ? Math.min(100, Math.max(0, gpuU)) : 0;
        ($('si-gpu-bar') as HTMLElement).style.width = `${gpuBarPct}%`;
        ($('si-gpu-bar') as HTMLElement).style.background =
          hostOk && Number.isFinite(gpuU) ? statusColor(gpuU, 'gpu') : 'var(--bar-bg)';
        $('si-gpu-foot').textContent = hostOk && Number.isFinite(gpuU) ? `${Math.round(gpuBarPct)}%` : '—';
        if (hostOk && gpuModelStr && !Number.isFinite(gpuU)) {
          setSysFootnote(
            'si-gpu-note',
            'El porcentaje de uso no está disponible en este sistema o GPU (p. ej. integradas Apple/AMD sin nvidia-smi). El modelo sigue siendo informativo.',
            false,
          );
        } else {
          setSysFootnote('si-gpu-note', '', false);
        }

        setSiField('si-uptime', hasValidSystemUptime(d.uptime) ? fmtUptime(d.uptime) : '—');
      } catch (e) {
        console.error(e);
        setSysResults('No se pudieron cargar los datos del host.');
        setSysFeedback('Error al cargar', '¿API en marcha? Pulsa ⟳');
      }
    }

    wireSistemaCopyButtons();

    $('sys-refresh').addEventListener('click', load);
    load();
    setInterval(load, 12000);
  </script>
</Layout>
