---
import Layout from '../layouts/Layout.astro';
import { iconToSvg } from '../lib/lucide-svg-string';
import { Cpu, MemoryStick, HardDrive, Clock, Monitor, RefreshCw } from 'lucide';

const icons = {
  cpu: iconToSvg(Cpu, { width: 18, height: 18 }),
  mem: iconToSvg(MemoryStick, { width: 18, height: 18 }),
  disk: iconToSvg(HardDrive, { width: 18, height: 18 }),
  clock: iconToSvg(Clock, { width: 18, height: 18 }),
  monitor: iconToSvg(Monitor, { width: 18, height: 18 }),
  refresh: iconToSvg(RefreshCw, { width: 16, height: 16 }),
};
---
<Layout activePage="sistema">
  <div class="wrapper sistema-page">
    <div class="sistema-top">
      <div class="page-header sistema-page-header">
        <h2 class="page-title">Sistema</h2>
        <p class="page-desc">Hardware, uso de recursos y tiempo de actividad del host que ejecuta la API.</p>
      </div>
      <button type="button" class="page-filter-btn sistema-refresh" id="sys-refresh">
        <span class="sistema-refresh-inner">
          <span set:html={icons.refresh} />
          <span>Actualizar</span>
        </span>
      </button>
    </div>

    <div class="sistema-hero" aria-label="Resumen de recursos">
      <div class="sistema-stat-card" data-metric="cpu">
        <span class="sistema-stat-value skeleton" id="st-cpu">—%</span>
        <span class="sistema-stat-label">CPU</span>
      </div>
      <div class="sistema-stat-card" data-metric="mem">
        <span class="sistema-stat-value skeleton" id="st-mem">—%</span>
        <span class="sistema-stat-label">RAM</span>
      </div>
      <div class="sistema-stat-card" data-metric="disk">
        <span class="sistema-stat-value skeleton" id="st-disk">—%</span>
        <span class="sistema-stat-label">Disco</span>
      </div>
      <div class="sistema-stat-card" data-metric="uptime">
        <span class="sistema-stat-value skeleton sistema-stat-value--wide" id="st-uptime">—</span>
        <span class="sistema-stat-label">Uptime</span>
      </div>
    </div>

    <div class="sys-panel-grid" id="sys-panels">
      <div class="sys-panel">
        <div class="sys-panel-heading">
          <span class="sys-panel-icon" aria-hidden="true" set:html={icons.monitor} />
          <h3 class="sys-panel-title">Host</h3>
        </div>
        <div class="sys-grid sys-grid--dense">
          <div class="sys-item"><span class="sys-key">Hostname</span><span class="sys-val skeleton" id="si-host">—</span></div>
          <div class="sys-item"><span class="sys-key">Sistema</span><span class="sys-val skeleton" id="si-platform">—</span></div>
          <div class="sys-item sys-item--full"><span class="sys-key">Última lectura</span><span class="sys-val skeleton" id="si-updated">—</span></div>
        </div>
      </div>

      <div class="sys-panel">
        <div class="sys-panel-heading">
          <span class="sys-panel-icon" aria-hidden="true" set:html={icons.cpu} />
          <h3 class="sys-panel-title">Procesador</h3>
        </div>
        <div class="sys-grid sys-grid--dense">
          <div class="sys-item sys-item--full">
            <span class="sys-key">Modelo</span>
            <span class="sys-val skeleton sys-val--wrap" id="si-cpu-model">—</span>
          </div>
          <div class="sys-item"><span class="sys-key">Núcleos</span><span class="sys-val skeleton" id="si-cpu-cores">—</span></div>
          <div class="sys-item"><span class="sys-key">Uso</span><span class="sys-val skeleton" id="si-cpu-pct">—</span></div>
          <div class="sys-item sys-item--full"><span class="sys-key">Carga</span><span class="sys-val skeleton sys-val--wrap" id="si-load">—</span></div>
        </div>
      </div>

      <div class="sys-panel">
        <div class="sys-panel-heading">
          <span class="sys-panel-icon sys-panel-icon--mem" aria-hidden="true" set:html={icons.mem} />
          <h3 class="sys-panel-title">Memoria RAM</h3>
        </div>
        <div class="sys-grid sys-grid--dense">
          <div class="sys-item"><span class="sys-key">Total</span><span class="sys-val skeleton" id="si-mem-total">—</span></div>
          <div class="sys-item"><span class="sys-key">Usado</span><span class="sys-val skeleton" id="si-mem-used">—</span></div>
          <div class="sys-item"><span class="sys-key">Uso</span><span class="sys-val skeleton" id="si-mem-pct">—</span></div>
        </div>
        <div class="sys-meter">
          <div class="sys-meter-track"><div class="sys-meter-fill" id="si-mem-bar" style="width:0%"></div></div>
          <div class="sys-meter-foot"><span>0%</span><span id="si-mem-foot">100%</span></div>
        </div>
      </div>

      <div class="sys-panel">
        <div class="sys-panel-heading">
          <span class="sys-panel-icon sys-panel-icon--disk" aria-hidden="true" set:html={icons.disk} />
          <h3 class="sys-panel-title">Disco principal</h3>
        </div>
        <div class="sys-grid sys-grid--dense">
          <div class="sys-item"><span class="sys-key">Usado</span><span class="sys-val skeleton" id="si-disk-used">—</span></div>
          <div class="sys-item"><span class="sys-key">Total</span><span class="sys-val skeleton" id="si-disk-total">—</span></div>
          <div class="sys-item"><span class="sys-key">Uso</span><span class="sys-val skeleton" id="si-disk-pct">—</span></div>
        </div>
        <div class="sys-meter">
          <div class="sys-meter-track"><div class="sys-meter-fill sys-meter-fill--disk" id="si-disk-bar" style="width:0%"></div></div>
          <div class="sys-meter-foot"><span>0%</span><span id="si-disk-foot">100%</span></div>
        </div>
      </div>

      <div class="sys-panel sys-panel--wide">
        <div class="sys-panel-heading">
          <span class="sys-panel-icon sys-panel-icon--clock" aria-hidden="true" set:html={icons.clock} />
          <h3 class="sys-panel-title">Tiempo</h3>
        </div>
        <div class="sys-grid sys-grid--dense">
          <div class="sys-item"><span class="sys-key">Uptime</span><span class="sys-val skeleton" id="si-uptime">—</span></div>
          <div class="sys-item"><span class="sys-key">Hora</span><span class="sys-val" id="si-time">—</span></div>
          <div class="sys-item sys-item--full"><span class="sys-key">Fecha</span><span class="sys-val sys-val--wrap" id="si-date">—</span></div>
        </div>
      </div>
    </div>
  </div>

  <script>
    import { fetchMetrics, updateHeader, fmtUptime, statusColor } from '../lib/metrics';

    const $ = (id: string) => document.getElementById(id)!;

    function updateTime() {
      const now = new Date();
      $('si-time').textContent = now.toLocaleTimeString('es-ES');
      $('si-date').textContent = now.toLocaleDateString('es-ES', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
    }
    updateTime();
    setInterval(updateTime, 1000);

    function setHeroMetric(card: HTMLElement | null, pct: number, type: 'cpu' | 'mem' | 'disk') {
      if (!card) return;
      const c = statusColor(pct, type);
      card.style.setProperty('--hero-accent', c);
    }

    async function load() {
      try {
        const d = await fetchMetrics();
        updateHeader(d);

        const set = (id: string, v: string) => {
          const e = $(id);
          e.textContent = v;
          e.classList.remove('skeleton');
        };

        set('st-cpu', `${Math.round(d.cpu)}%`);
        set('st-mem', `${Math.round(d.mem)}%`);
        set('st-disk', `${Math.round(d.disk)}%`);
        set('st-uptime', fmtUptime(d.uptime));

        setHeroMetric(document.querySelector('.sistema-stat-card[data-metric="cpu"]'), d.cpu, 'cpu');
        setHeroMetric(document.querySelector('.sistema-stat-card[data-metric="mem"]'), d.mem, 'mem');
        setHeroMetric(document.querySelector('.sistema-stat-card[data-metric="disk"]'), d.disk, 'disk');

        const hostOs = typeof d.hostOs === 'string' && d.hostOs.trim() ? d.hostOs.trim() : '—';
        set('si-host', d.hostname || '—');
        set('si-platform', hostOs);
        set('si-updated', new Date(d.timestamp).toLocaleString('es-ES', { dateStyle: 'short', timeStyle: 'medium' }));

        set('si-cpu-model', d.cpuModel || '—');
        set('si-cpu-cores', String(d.cpuCores ?? '—'));
        set('si-cpu-pct', `${Math.round(d.cpu)}%`);
        ($('si-cpu-pct') as HTMLElement).style.color = statusColor(d.cpu, 'cpu');
        set('si-load', d.load ? d.load.map((l: number) => l.toFixed(2)).join(' / ') : '—');

        set('si-mem-total', `${d.memTotal} GB`);
        set('si-mem-used', `${d.memUsed} GB`);
        set('si-mem-pct', `${Math.round(d.mem)}%`);
        ($('si-mem-pct') as HTMLElement).style.color = statusColor(d.mem, 'mem');
        const memPct = Math.min(100, Math.max(0, d.mem));
        ($('si-mem-bar') as HTMLElement).style.width = `${memPct}%`;
        ($('si-mem-bar') as HTMLElement).style.background = statusColor(d.mem, 'mem');
        $('si-mem-foot').textContent = `${Math.round(memPct)}%`;

        const diskTotal = typeof d.diskTotal === 'number' && d.diskTotal > 0 ? d.diskTotal : null;
        set('si-disk-used', `${Math.round(d.diskUsed || 0)} GB`);
        set('si-disk-total', diskTotal != null ? `${diskTotal} GB` : '—');
        set('si-disk-pct', `${Math.round(d.disk)}%`);
        ($('si-disk-pct') as HTMLElement).style.color = statusColor(d.disk, 'disk');
        const diskPct = Math.min(100, Math.max(0, d.disk));
        ($('si-disk-bar') as HTMLElement).style.width = `${diskPct}%`;
        ($('si-disk-bar') as HTMLElement).style.background = statusColor(d.disk, 'disk');
        $('si-disk-foot').textContent = `${Math.round(diskPct)}%`;

        set('si-uptime', fmtUptime(d.uptime));
      } catch (e) {
        console.error(e);
      }
    }

    $('sys-refresh').addEventListener('click', load);
    load();
    setInterval(load, 12000);
  </script>
</Layout>
