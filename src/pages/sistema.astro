---
import Layout from '../layouts/Layout.astro';
import { iconToSvg } from '../lib/lucide-svg-string';
import { Cpu, MemoryStick, HardDrive, Clock, Monitor, RefreshCw } from 'lucide';

const icons = {
  cpu: iconToSvg(Cpu, { width: 18, height: 18 }),
  mem: iconToSvg(MemoryStick, { width: 18, height: 18 }),
  disk: iconToSvg(HardDrive, { width: 18, height: 18 }),
  clock: iconToSvg(Clock, { width: 18, height: 18 }),
  monitor: iconToSvg(Monitor, { width: 18, height: 18 }),
  refresh: iconToSvg(RefreshCw, { width: 16, height: 16 }),
};
---
<Layout activePage="sistema">
  <div class="wrapper sistema-page">
    <div class="sistema-top">
      <div class="page-header sistema-page-header">
        <h2 class="page-title">Sistema</h2>
        <p class="page-desc">Hardware, uso de recursos y tiempo de actividad del host que ejecuta la API.</p>
      </div>
      <button type="button" class="page-filter-btn sistema-refresh" id="sys-refresh">
        <span class="sistema-refresh-inner">
          <span set:html={icons.refresh} />
          <span>Actualizar</span>
        </span>
      </button>
    </div>

    <div class="sistema-hero" aria-label="Resumen de recursos">
      <div class="sistema-stat-card" data-metric="cpu">
        <span class="sistema-stat-value skeleton" id="st-cpu">—%</span>
        <span class="sistema-stat-label">CPU</span>
      </div>
      <div class="sistema-stat-card" data-metric="mem">
        <span class="sistema-stat-value skeleton" id="st-mem">—%</span>
        <span class="sistema-stat-label">RAM</span>
      </div>
      <div class="sistema-stat-card" data-metric="disk">
        <span class="sistema-stat-value skeleton" id="st-disk">—%</span>
        <span class="sistema-stat-label">Disco</span>
      </div>
      <div class="sistema-stat-card" data-metric="uptime">
        <span class="sistema-stat-value skeleton sistema-stat-value--wide" id="st-uptime">—</span>
        <span class="sistema-stat-label">Uptime</span>
      </div>
    </div>

    <div class="sys-panel-grid" id="sys-panels">
      <div class="sys-panel sys-panel--with-flyout" id="si-info-anchor">
        <aside class="sysinfo-flyout sysinfo-flyout--panel" id="si-flyout" aria-hidden="true">
          <p class="sysinfo-flyout-lede">Detalle completo y copiar al pasar el cursor por esta tarjeta</p>
          <dl class="sysinfo-flyout-dl">
            <div class="sysinfo-flyout-row">
              <dt>Equipo</dt>
              <dd><code class="sysinfo-flyout-code" id="si-fly-device"></code><button type="button" class="sysinfo-flyout-copy" data-sifly="device">Copiar</button></dd>
            </div>
            <div class="sysinfo-flyout-row">
              <dt>Hostname</dt>
              <dd><code class="sysinfo-flyout-code" id="si-fly-host"></code><button type="button" class="sysinfo-flyout-copy" data-sifly="host">Copiar</button></dd>
            </div>
            <div class="sysinfo-flyout-row">
              <dt>Sistema</dt>
              <dd><code class="sysinfo-flyout-code" id="si-fly-os"></code><button type="button" class="sysinfo-flyout-copy" data-sifly="os">Copiar</button></dd>
            </div>
            <div class="sysinfo-flyout-row">
              <dt>Red</dt>
              <dd><code class="sysinfo-flyout-code" id="si-fly-ipv4"></code><button type="button" class="sysinfo-flyout-copy" data-sifly="ipv4">Copiar</button></dd>
            </div>
            <div class="sysinfo-flyout-row">
              <dt>Lectura</dt>
              <dd><code class="sysinfo-flyout-code" id="si-fly-updated"></code><button type="button" class="sysinfo-flyout-copy" data-sifly="updated">Copiar</button></dd>
            </div>
          </dl>
          <button type="button" class="sysinfo-flyout-copyall" id="si-fly-copyall">Copiar resumen completo</button>
        </aside>
        <div class="sys-panel-heading si-info-heading">
          <span class="sys-panel-icon" aria-hidden="true" set:html={icons.monitor} />
          <h3 class="sys-panel-title">Información del sistema</h3>
          <span class="sysinfo-summary-badge">Hover ↑</span>
        </div>
        <div class="sys-grid sys-grid--dense">
          <div class="sys-item sys-item--full"><span class="sys-key">Nombre del equipo</span><span class="sys-val skeleton sys-val--wrap" id="si-device">—</span></div>
          <div class="sys-item sys-item--full"><span class="sys-key">Hostname</span><span class="sys-val skeleton sys-val--wrap" id="si-host">—</span></div>
          <div class="sys-item sys-item--full"><span class="sys-key">Sistema operativo</span><span class="sys-val skeleton sys-val--wrap" id="si-platform">—</span></div>
          <div class="sys-item sys-item--full"><span class="sys-key">Red (IPv4)</span><span class="sys-val skeleton sys-val--wrap" id="si-ipv4">—</span></div>
          <div class="sys-item sys-item--full"><span class="sys-key">Última lectura</span><span class="sys-val skeleton" id="si-updated">—</span></div>
        </div>
        <p class="sys-mem-note" id="si-host-note" hidden></p>
      </div>

      <div class="sys-panel">
        <div class="sys-panel-heading">
          <span class="sys-panel-icon" aria-hidden="true" set:html={icons.cpu} />
          <h3 class="sys-panel-title">Procesador</h3>
        </div>
        <div class="sys-grid sys-grid--dense">
          <div class="sys-item sys-item--full">
            <span class="sys-key">Modelo</span>
            <span class="sys-val skeleton sys-val--wrap js-copy-val" id="si-cpu-model">—</span>
          </div>
          <div class="sys-item"><span class="sys-key">Núcleos</span><span class="sys-val skeleton js-copy-val" id="si-cpu-cores">—</span></div>
          <div class="sys-item"><span class="sys-key">Uso</span><span class="sys-val skeleton" id="si-cpu-pct">—</span></div>
          <div class="sys-item sys-item--full"><span class="sys-key">Carga</span><span class="sys-val skeleton sys-val--wrap js-copy-val" id="si-load">—</span></div>
        </div>
      </div>

      <div class="sys-panel">
        <div class="sys-panel-heading">
          <span class="sys-panel-icon sys-panel-icon--mem" aria-hidden="true" set:html={icons.mem} />
          <h3 class="sys-panel-title">Memoria RAM</h3>
        </div>
        <div class="sys-grid sys-grid--dense">
          <div class="sys-item"><span class="sys-key">Total</span><span class="sys-val skeleton js-copy-val" id="si-mem-total">—</span></div>
          <div class="sys-item"><span class="sys-key">Usado</span><span class="sys-val skeleton js-copy-val" id="si-mem-used">—</span></div>
          <div class="sys-item"><span class="sys-key">Uso</span><span class="sys-val skeleton" id="si-mem-pct">—</span></div>
        </div>
        <div class="sys-meter">
          <div class="sys-meter-track"><div class="sys-meter-fill" id="si-mem-bar" style="width:0%"></div></div>
          <div class="sys-meter-foot"><span>0%</span><span id="si-mem-foot">100%</span></div>
        </div>
        <p class="sys-mem-note" id="si-mem-note" hidden></p>
      </div>

      <div class="sys-panel">
        <div class="sys-panel-heading">
          <span class="sys-panel-icon sys-panel-icon--disk" aria-hidden="true" set:html={icons.disk} />
          <h3 class="sys-panel-title">Disco principal</h3>
        </div>
        <div class="sys-grid sys-grid--dense">
          <div class="sys-item"><span class="sys-key">Usado</span><span class="sys-val skeleton js-copy-val" id="si-disk-used">—</span></div>
          <div class="sys-item"><span class="sys-key">Total</span><span class="sys-val skeleton js-copy-val" id="si-disk-total">—</span></div>
          <div class="sys-item"><span class="sys-key">Uso</span><span class="sys-val skeleton" id="si-disk-pct">—</span></div>
        </div>
        <div class="sys-meter">
          <div class="sys-meter-track"><div class="sys-meter-fill sys-meter-fill--disk" id="si-disk-bar" style="width:0%"></div></div>
          <div class="sys-meter-foot"><span>0%</span><span id="si-disk-foot">100%</span></div>
        </div>
      </div>

      <div class="sys-panel sys-panel--wide">
        <div class="sys-panel-heading">
          <span class="sys-panel-icon sys-panel-icon--clock" aria-hidden="true" set:html={icons.clock} />
          <h3 class="sys-panel-title">Tiempo</h3>
        </div>
        <div class="sys-grid sys-grid--dense">
          <div class="sys-item"><span class="sys-key">Uptime</span><span class="sys-val skeleton js-copy-val" id="si-uptime">—</span></div>
          <div class="sys-item"><span class="sys-key">Hora</span><span class="sys-val" id="si-time">—</span></div>
          <div class="sys-item sys-item--full"><span class="sys-key">Fecha</span><span class="sys-val sys-val--wrap" id="si-date">—</span></div>
        </div>
      </div>
    </div>
  </div>

  <script>
    import { fetchMetrics, updateHeader, fmtUptime, statusColor } from '../lib/metrics';
    import { initCopyableValues } from '../lib/copy-field';

    const $ = (id: string) => document.getElementById(id)!;

    const SI_FLY_LABELS: Record<string, string> = {
      device: 'Equipo',
      host: 'Hostname',
      os: 'Sistema operativo',
      ipv4: 'Red (IPv4)',
      updated: 'Última lectura',
    };
    const SI_FLY_KEYS = ['device', 'host', 'os', 'ipv4', 'updated'] as const;

    let siFlyoutWired = false;
    function wireSistemaSysinfoFlyout() {
      if (siFlyoutWired) return;
      siFlyoutWired = true;
      const anchor = document.getElementById('si-info-anchor');
      const fly = document.getElementById('si-flyout');
      if (!anchor || !fly) return;
      let hideT: ReturnType<typeof setTimeout> | undefined;
      const show = () => {
        if (hideT) clearTimeout(hideT);
        fly.classList.add('is-visible');
        fly.setAttribute('aria-hidden', 'false');
      };
      const hide = () => {
        hideT = window.setTimeout(() => {
          fly.classList.remove('is-visible');
          fly.setAttribute('aria-hidden', 'true');
        }, 200);
      };
      anchor.addEventListener('mouseenter', show);
      anchor.addEventListener('mouseleave', hide);
      fly.addEventListener('mouseenter', show);
      fly.addEventListener('mouseleave', hide);
      fly.querySelectorAll<HTMLButtonElement>('[data-sifly]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const k = btn.dataset.sifly;
          if (!k) return;
          const t = document.getElementById(`si-fly-${k}`)?.textContent?.trim();
          if (t) navigator.clipboard.writeText(t).catch(() => {});
        });
      });
      document.getElementById('si-fly-copyall')?.addEventListener('click', () => {
        const lines = SI_FLY_KEYS.map((k) => {
          const v = document.getElementById(`si-fly-${k}`)?.textContent?.trim() || '—';
          return `${SI_FLY_LABELS[k]}: ${v}`;
        });
        navigator.clipboard.writeText(lines.join('\n')).catch(() => {});
      });
    }

    function updateTime() {
      const now = new Date();
      $('si-time').textContent = now.toLocaleTimeString('es-ES');
      $('si-date').textContent = now.toLocaleDateString('es-ES', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
    }
    updateTime();
    setInterval(updateTime, 1000);

    function setHeroMetric(card: HTMLElement | null, pct: number, type: 'cpu' | 'mem' | 'disk') {
      if (!card) return;
      const c = statusColor(pct, type);
      card.style.setProperty('--hero-accent', c);
    }

    async function load() {
      try {
        const d = await fetchMetrics();
        updateHeader(d);

        const set = (id: string, v: string) => {
          const e = $(id);
          e.textContent = v;
          e.classList.remove('skeleton');
        };

        function setCopyable(id: string, v: string) {
          const e = $(id) as HTMLElement;
          e.textContent = v;
          e.classList.remove('skeleton');
          if (v && v !== '—') {
            e.classList.add('js-copy-val');
            e.dataset.copyText = v;
            e.title = `Clic para copiar · ${v}`;
          } else {
            e.classList.remove('js-copy-val');
            delete e.dataset.copyText;
            e.removeAttribute('title');
          }
        }

        set('st-cpu', `${Math.round(d.cpu)}%`);
        set('st-mem', `${Math.round(d.mem)}%`);
        set('st-disk', `${Math.round(d.disk)}%`);
        set('st-uptime', fmtUptime(d.uptime));

        setHeroMetric(document.querySelector('.sistema-stat-card[data-metric="cpu"]'), d.cpu, 'cpu');
        setHeroMetric(document.querySelector('.sistema-stat-card[data-metric="mem"]'), d.mem, 'mem');
        setHeroMetric(document.querySelector('.sistema-stat-card[data-metric="disk"]'), d.disk, 'disk');

        const hostOs = typeof d.hostOs === 'string' && d.hostOs.trim() ? d.hostOs.trim() : '—';
        const devName = typeof d.deviceName === 'string' && d.deviceName.trim() ? d.deviceName.trim() : '';
        const ips = Array.isArray(d.hostIpv4) ? d.hostIpv4.filter((x: unknown) => typeof x === 'string' && x.trim()) : [];
        const locals = ips.length ? ips.join(', ') : '';
        const pub = String(d.publicIp || '').trim();
        const ipv4Str =
          pub && locals
            ? `${pub} · ${locals}`
            : pub || locals || '—';
        const ipv4Fly =
          pub && locals
            ? `Pública: ${pub}\nLocales: ${locals}`
            : pub
              ? `Pública: ${pub}`
              : locals || '—';
        const updatedStr = new Date(d.timestamp).toLocaleString('es-ES', { dateStyle: 'short', timeStyle: 'medium' });
        set('si-device', devName || d.hostname || '—');
        set('si-host', d.hostname || '—');
        set('si-platform', hostOs);
        set('si-ipv4', ipv4Str);
        set('si-updated', updatedStr);

        const siFlyMap: Record<string, string> = {
          device: devName || d.hostname || '—',
          host: d.hostname || '—',
          os: hostOs,
          ipv4: ipv4Fly,
          updated: updatedStr,
        };
        for (const k of Object.keys(siFlyMap)) {
          const el = document.getElementById(`si-fly-${k}`);
          if (el) el.textContent = siFlyMap[k];
        }

        setCopyable('si-cpu-model', d.cpuModel || '—');
        setCopyable('si-cpu-cores', String(d.cpuCores ?? '—'));
        set('si-cpu-pct', `${Math.round(d.cpu)}%`);
        ($('si-cpu-pct') as HTMLElement).style.color = statusColor(d.cpu, 'cpu');
        setCopyable('si-load', d.load ? d.load.map((l: number) => l.toFixed(2)).join(' / ') : '—');

        setCopyable('si-mem-total', `${d.memTotal} GiB`);
        setCopyable('si-mem-used', `${d.memUsed} GiB`);
        set('si-mem-pct', `${Math.round(d.mem)}%`);
        ($('si-mem-pct') as HTMLElement).style.color = statusColor(d.mem, 'mem');
        const memPct = Math.min(100, Math.max(0, d.mem));
        ($('si-mem-bar') as HTMLElement).style.width = `${memPct}%`;
        ($('si-mem-bar') as HTMLElement).style.background = statusColor(d.mem, 'mem');
        $('si-mem-foot').textContent = `${Math.round(memPct)}%`;

        const memNoteEl = document.getElementById('si-mem-note');
        if (memNoteEl) {
          const note = typeof d.memNote === 'string' ? d.memNote.trim() : '';
          if (note) {
            memNoteEl.textContent = note;
            memNoteEl.removeAttribute('hidden');
          } else {
            memNoteEl.textContent = '';
            memNoteEl.setAttribute('hidden', '');
          }
        }

        const hostNoteEl = document.getElementById('si-host-note');
        if (hostNoteEl) {
          const hnote =
            typeof (d as { hostMetricsNote?: string }).hostMetricsNote === 'string'
              ? String((d as { hostMetricsNote?: string }).hostMetricsNote).trim()
              : '';
          if (hnote) {
            hostNoteEl.textContent = hnote;
            (hostNoteEl as HTMLElement).style.whiteSpace = 'pre-line';
            hostNoteEl.removeAttribute('hidden');
          } else {
            hostNoteEl.textContent = '';
            hostNoteEl.setAttribute('hidden', '');
          }
        }

        const diskTotal = typeof d.diskTotal === 'number' && d.diskTotal > 0 ? d.diskTotal : null;
        setCopyable('si-disk-used', `${d.diskUsed} GiB`);
        setCopyable('si-disk-total', diskTotal != null ? `${diskTotal} GiB` : '—');
        set('si-disk-pct', `${Math.round(d.disk)}%`);
        ($('si-disk-pct') as HTMLElement).style.color = statusColor(d.disk, 'disk');
        const diskPct = Math.min(100, Math.max(0, d.disk));
        ($('si-disk-bar') as HTMLElement).style.width = `${diskPct}%`;
        ($('si-disk-bar') as HTMLElement).style.background = statusColor(d.disk, 'disk');
        $('si-disk-foot').textContent = `${Math.round(diskPct)}%`;

        setCopyable('si-uptime', fmtUptime(d.uptime));
      } catch (e) {
        console.error(e);
      }
    }

    wireSistemaSysinfoFlyout();
    const panels = document.getElementById('sys-panels');
    if (panels) initCopyableValues(panels);

    $('sys-refresh').addEventListener('click', load);
    load();
    setInterval(load, 12000);
  </script>
</Layout>
