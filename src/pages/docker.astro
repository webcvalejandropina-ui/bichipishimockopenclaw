  <script>
    import {
      apiPostDockerCtnr,
      apiPostDockerImgDelete,
      apiPostDockerVolDelete,
      fetchMetrics,
      updateHeader,
    } from '../lib/metrics';
    import { iconToSvg } from '../lib/lucide-svg-string';
    import {
      Play,
      Square,
      RotateCw,
      Trash2,
      Copy,
      Terminal,
      Info,
      ChevronDown,
      Activity,
      CircleDot,
      Circle,
    } from 'lucide';
    import { escHtml } from '../lib/process-hints';

    const iSvcRun = iconToSvg(Activity, { width: 12, height: 12, 'stroke-width': 2 });
    const iSvcStopped = iconToSvg(Square, { width: 10, height: 10, 'stroke-width': 2 });
    const iSvcActiveOn = iconToSvg(CircleDot, { width: 10, height: 10, 'stroke-width': 2 });
    const iSvcActiveOff = iconToSvg(Circle, { width: 10, height: 10, 'stroke-width': 1.65 });
    const iChevDown = iconToSvg(ChevronDown, { width: 14, height: 14, 'stroke-width': 2 });
    const iPlay = iconToSvg(Play, { width: 15, height: 15 });
    const iStop = iconToSvg(Square, { width: 15, height: 15 });
    const iRestart = iconToSvg(RotateCw, { width: 15, height: 15 });
    const iTrash = iconToSvg(Trash2, { width: 15, height: 15 });
    const iTerminal = iconToSvg(Terminal, { width: 15, height: 15 });
    const iInfo = iconToSvg(Info, { width: 12, height: 12, 'stroke-width': 2 });
    const iCopyCli = iconToSvg(Copy, { width: 15, height: 15 });

    const $ = (id: string) => document.getElementById(id)!;

    function handleDkCliToggle(ev: MouseEvent): boolean {
      const btn = (ev.target as HTMLElement).closest<HTMLButtonElement>('[data-dk-cli-toggle]');
      if (!btn || actionInFlight) return false;
      ev.preventDefault();
      const card = btn.closest('.info-card--svc');
      const panel = card?.querySelector<HTMLElement>('[data-dk-cli-panel]');
      if (!panel) return false;
      const willOpen = panel.hidden;
      panel.hidden = !willOpen;
      btn.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
      btn.classList.toggle('is-open', willOpen);
      btn.setAttribute(
        'aria-label',
        willOpen ? 'Ocultar comandos de referencia' : 'Mostrar comandos de referencia',
      );
      return true;
    }

    let dockerModalResolve: ((v: 'confirm' | 'cancel') => void) | null = null;
    let dockerModalPrevFocus: HTMLElement | null = null;
    let dockerModalKeyHandler: ((e: KeyboardEvent) => void) | null = null;

    function dockerModalDetachKeys() {
      if (dockerModalKeyHandler) {
        document.removeEventListener('keydown', dockerModalKeyHandler);
        dockerModalKeyHandler = null;
      }
    }

    function dockerModalClose(result: 'confirm' | 'cancel') {
      const root = $('dk-modal');
      root.hidden = true;
      root.setAttribute('aria-hidden', 'true');
      document.body.classList.remove('dk-modal-open');
      dockerModalDetachKeys();
      const r = dockerModalResolve;
      dockerModalResolve = null;
      try {
        dockerModalPrevFocus?.focus();
      } catch {
        /* ignore */
      }
      dockerModalPrevFocus = null;
      r?.(result);
    }

    function initDockerModal() {
      const root = $('dk-modal');
      if ((root as HTMLElement & { _dkModalInit?: boolean })._dkModalInit) return;
      (root as HTMLElement & { _dkModalInit?: boolean })._dkModalInit = true;
      $('dk-modal-confirm').addEventListener('click', () => dockerModalClose('confirm'));
      $('dk-modal-cancel').addEventListener('click', () => dockerModalClose('cancel'));
      root.querySelector('.dk-modal__backdrop')?.addEventListener('click', () => {
        const mode = root.dataset.mode;
        dockerModalClose(mode === 'alert' ? 'confirm' : 'cancel');
      });
    }

    function dockerModalOpen(opts: {
      mode: 'confirm' | 'alert';
      title: string;
      body: string;
      detail?: string;
      variant?: 'default' | 'danger';
      confirmLabel?: string;
      cancelLabel?: string;
    }): Promise<'confirm' | 'cancel'> {
      initDockerModal();
      return new Promise((resolve) => {
        dockerModalResolve = resolve;
        dockerModalPrevFocus = document.activeElement as HTMLElement;
        const root = $('dk-modal');
        root.dataset.mode = opts.mode;
        root.dataset.variant = opts.variant || 'default';
        $('dk-modal-title').textContent = opts.title;
        $('dk-modal-body').textContent = opts.body;
        const det = $('dk-modal-detail');
        if (opts.detail) {
          det.textContent = opts.detail;
          det.hidden = false;
        } else {
          det.textContent = '';
          det.hidden = true;
        }
        const cancelBtn = $('dk-modal-cancel') as HTMLButtonElement;
        const confirmBtn = $('dk-modal-confirm') as HTMLButtonElement;
        cancelBtn.hidden = opts.mode === 'alert';
        confirmBtn.textContent = opts.confirmLabel || (opts.mode === 'alert' ? 'Entendido' : 'Confirmar');
        cancelBtn.textContent = opts.cancelLabel || 'Cancelar';
        root.hidden = false;
        root.setAttribute('aria-hidden', 'false');
        document.body.classList.add('dk-modal-open');
        dockerModalKeyHandler = (ev: KeyboardEvent) => {
          if (ev.key !== 'Escape') return;
          ev.preventDefault();
          dockerModalClose(opts.mode === 'alert' ? 'confirm' : 'cancel');
        };
        document.addEventListener('keydown', dockerModalKeyHandler);
        confirmBtn.focus();
      });
    }

    async function dockerModalConfirm(opts: {
      title: string;
      body: string;
      detail?: string;
      variant?: 'default' | 'danger';
      confirmLabel?: string;
      cancelLabel?: string;
    }): Promise<boolean> {
      const r = await dockerModalOpen({ ...opts, mode: 'confirm' });
      return r === 'confirm';
    }

    async function dockerModalAlert(opts: { title: string; body: string; detail?: string }) {
      await dockerModalOpen({
        mode: 'alert',
        variant: 'default',
        title: opts.title,
        body: opts.body,
        detail: opts.detail,
        confirmLabel: 'Entendido',
      });
    }

    function dockerActionVerbEs(action: string): string {
      const m: Record<string, string> = {
        start: 'Iniciar',
        stop: 'Detener',
        restart: 'Reiniciar',
        delete: 'Eliminar',
      };
      return m[action] || action;
    }

    let allCtrs: any[] = [];
    let allImgs: any[] = [];
    let allVols: any[] = [];
    let filter = 'all';
    let tab: 'ctnr' | 'img' | 'vol' = 'ctnr';
    let dataLoaded = false;
    let actionInFlight = false;
    let lastLoadedAt = 0;
    let autoRefreshEnabled = true;
    let hiddenAutoPause = false;
    let sortBy: 'status' | 'cpu' | 'mem' | 'name' | 'ports' | 'created' | 'size' = 'status';
    const storageKey = 'bichipishi:docker:view';
    const staleRefreshMs = 30000;
    const defaultTab: 'ctnr' | 'img' | 'vol' = 'ctnr';
    const defaultFilter = 'all';

    function currentSearchValue() {
      return (($('dk-search') as HTMLInputElement)?.value || '').trim();
    }

    function viewStateToQueryString() {
      const params = new URLSearchParams();
      const search = currentSearchValue();
      const defaultSort = defaultSortForTab(tab);
      if (tab !== defaultTab) params.set('t', tab);
      if (tab === 'ctnr' && filter !== defaultFilter) params.set('f', filter);
      if (sortBy !== defaultSort) params.set('s', sortBy);
      if (search) params.set('q', search);
      if (!autoRefreshEnabled) params.set('auto', 'off');
      return params.toString();
    }

    function syncViewUrl() {
      if (typeof window === 'undefined') return;
      try {
        const qs = viewStateToQueryString();
        const next = `${window.location.pathname}${qs ? `?${qs}` : ''}${window.location.hash || ''}`;
        window.history.replaceState(null, '', next);
      } catch {
        // ignore URL sync failures
      }
    }

    function defaultSortForTab(nextTab: 'ctnr' | 'img' | 'vol') {
      return nextTab === 'ctnr' ? 'status' : nextTab === 'img' ? 'created' : 'name';
    }

    function saveViewState() {
      try {
        localStorage.setItem(
          storageKey,
          JSON.stringify({
            filter,
            tab,
            autoRefreshEnabled,
            sortBy,
            search: ($('dk-search') as HTMLInputElement)?.value || '',
          }),
        );
      } catch {
        // ignore storage failures
      }
      syncViewUrl();
    }

    function applyViewState(state: Record<string, unknown>) {
      if (state.tab === 'ctnr' || state.tab === 'img' || state.tab === 'vol') {
        tab = state.tab;
      }
      if (['all', 'up', 'down', 'ports', 'issues', 'hot'].includes(String(state.filter || ''))) {
        filter = String(state.filter);
      }
      if (typeof state.autoRefreshEnabled === 'boolean') {
        autoRefreshEnabled = state.autoRefreshEnabled;
      }
      if (['status', 'cpu', 'mem', 'name', 'ports', 'created', 'size'].includes(String(state.sortBy || ''))) {
        sortBy = String(state.sortBy) as typeof sortBy;
      }
      if (typeof state.search === 'string') {
        ($('dk-search') as HTMLInputElement).value = state.search;
      }
    }

    function restoreViewState() {
      try {
        const params = new URLSearchParams(window.location.search);
        const hasQueryState = ['t', 'f', 's', 'q', 'auto'].some((key) => params.has(key));
        if (hasQueryState) {
          applyViewState({
            tab: params.get('t') || undefined,
            filter: params.get('f') || undefined,
            sortBy: params.get('s') || undefined,
            search: params.get('q') || '',
            autoRefreshEnabled: params.get('auto') === 'off' ? false : undefined,
          });
          syncViewUrl();
          return;
        }
      } catch {
        // ignore malformed URL state
      }
      try {
        const raw = localStorage.getItem(storageKey);
        if (!raw) return;
        applyViewState(JSON.parse(raw));
      } catch {
        // ignore malformed storage
      }
      syncViewUrl();
    }

    function fmtBytes(n: number) {
      if (n == null || !Number.isFinite(n) || n <= 0) return '—';
      let v = n;
      const u = ['B', 'KB', 'MB', 'GB', 'TB'];
      let i = 0;
      while (v >= 1024 && i < u.length - 1) {
        v /= 1024;
        i += 1;
      }
      return i === 0 ? `${Math.round(v)} ${u[i]}` : `${v < 10 ? v.toFixed(1) : Math.round(v)} ${u[i]}`;
    }

    function fmtTs(sec: number) {
      if (!sec) return '—';
      try {
        return new Date(sec * 1000).toLocaleString('es-ES', {
          dateStyle: 'short',
          timeStyle: 'short',
        });
      } catch {
        return '—';
      }
    }

    function fmtClock(ts: number) {
      if (!ts) return '—';
      try {
        return new Date(ts).toLocaleTimeString('es-ES', {
          hour: '2-digit',
          minute: '2-digit',
          second: '2-digit',
        });
      } catch {
        return '—';
      }
    }

    function fmtAge(ms: number) {
      if (!Number.isFinite(ms) || ms < 0) return 'ahora';
      const sec = Math.floor(ms / 1000);
      if (sec < 5) return 'ahora';
      if (sec < 60) return `hace ${sec}s`;
      const min = Math.floor(sec / 60);
      if (min < 60) return `hace ${min} min`;
      const hr = Math.floor(min / 60);
      return `hace ${hr} h`;
    }

    /** Parsea "Up 2 hours" o "Up 2 hours (unhealthy)" y devuelve "2h 30m" o "2d". */
    function fmtContainerDuration(status: string): string {
      if (!status) return '';
      const lower = status.toLowerCase();
      if (!lower.startsWith('up ')) return '';
      // Extrae la parte antes de paréntesis
      const main = lower.split('(')[0].trim(); // "up 2 hours"
      const match = main.match(/up\s+(?:(\d+)\s*d(?:ays?)?)?\s*(?:(\d+)\s*h(?:(?:ou)?rs?)?)?\s*(?:(\d+)\s*m(?:in(?:ute)?s?)?)?/i);
      if (!match) return '';
      const [, days, hours, mins] = match;
      const d = days ? parseInt(days) : 0;
      const h = hours ? parseInt(hours) : 0;
      const m = mins ? parseInt(mins) : 0;
      if (d > 0) return `${d}d`;
      if (h > 0 && m > 0) return `${h}h ${m}m`;
      if (h > 0) return `${h}h`;
      if (m > 0) return `${m}m`;
      return '';
    }

    function updateFreshnessState() {
      const box = $('dk-feedback');
      if (!lastLoadedAt) {
        delete box.dataset.freshness;
        return;
      }
      const ageMs = Date.now() - lastLoadedAt;
      if (!autoRefreshEnabled) {
        box.dataset.freshness = 'paused';
        const pauseReason = hiddenAutoPause ? 'pausado por pestaña oculta' : 'auto-refresh desactivado';
        $('dk-feedback-meta').textContent = `Datos congelados ${fmtAge(ageMs)} · ${pauseReason} · última actualización ${fmtClock(lastLoadedAt)}`;
        return;
      }
      box.dataset.freshness = ageMs >= 45000 ? 'stale' : 'fresh';
      $('dk-feedback-meta').textContent = `Última actualización ${fmtClock(lastLoadedAt)} · ${fmtAge(ageMs)}`;
    }

    function updateViewHelpers() {
      syncSearchUi();
      syncFilterButtons();
      syncSortUi();
      syncAutoRefreshUi();
      syncResetViewUi();
      syncPresetUi();
      updateActiveViewChips();
    }

    function setFeedback(status: string, meta = '') {
      $('dk-feedback-text').textContent = status;
      $('dk-feedback-meta').textContent = meta;
      if (!meta) {
        delete $('dk-feedback').dataset.freshness;
      }
    }

    function setResults(html: string) {
      $('dk-results').innerHTML = html;
    }

    function setSummary(
      chips: Array<{ label: string; value: string | number; tone?: 'ok' | 'crit' | 'warn' | 'info'; filterKey?: string }>,
    ) {
      const box = $('dk-summary');
      if (!chips.length) {
        box.hidden = true;
        box.innerHTML = '';
        return;
      }
      box.hidden = false;
      box.innerHTML = chips
        .map((chip) => {
          const tone = chip.tone || 'info';
          const active = chip.filterKey && chip.filterKey === filter ? 'true' : 'false';
          if (chip.filterKey) {
            return `<button type="button" class="dk-summary-chip" data-tone="${tone}" data-summary-filter="${escHtml(chip.filterKey)}" data-active="${active}" title="Filtrar por ${escHtml(chip.label)}"><span class="dk-summary-chip__value">${escHtml(String(chip.value))}</span><span class="dk-summary-chip__label">${escHtml(chip.label)}</span></button>`;
          }
          return `<span class="dk-summary-chip" data-tone="${tone}"><span class="dk-summary-chip__value">${escHtml(String(chip.value))}</span><span class="dk-summary-chip__label">${escHtml(chip.label)}</span></span>`;
        })
        .join('');
    }

    function updateActiveViewChips() {
      const box = $('dk-active-view');
      const chips: Array<{ key: string; label: string; value: string }> = [];
      const search = (($('dk-search') as HTMLInputElement)?.value || '').trim();
      chips.push({
        key: 'tab',
        label: 'Vista',
        value: tab === 'ctnr' ? 'Contenedores' : tab === 'img' ? 'Imágenes' : 'Volúmenes',
      });
      if (tab === 'ctnr' && filter !== 'all') {
        const filterLabels: Record<string, string> = {
          up: 'En marcha',
          down: 'Detenidos',
          ports: 'Con puertos',
          issues: 'Con incidencias',
          hot: 'Calientes',
        };
        chips.push({ key: 'filter', label: 'Filtro', value: filterLabels[filter] || filter });
      }
      if (search) chips.push({ key: 'search', label: 'Búsqueda', value: search });
      if (sortBy !== defaultSortForTab(tab)) {
        const sortLabels: Record<string, string> = {
          status: 'Estado',
          cpu: 'CPU ↓',
          mem: 'RAM ↓',
          name: 'Nombre A-Z',
          ports: 'Puertos',
          created: 'Fecha ↓',
          size: 'Tamaño ↓',
        };
        chips.push({ key: 'sort', label: 'Orden', value: sortLabels[sortBy] || sortBy });
      }
      if (!autoRefreshEnabled) chips.push({ key: 'auto', label: 'Auto', value: hiddenAutoPause ? 'Pausado por pestaña oculta' : 'OFF' });

      if (chips.length <= 1) {
        box.hidden = true;
        box.innerHTML = '';
        return;
      }

      box.hidden = false;
      box.innerHTML = chips
        .map((chip) => {
          if (chip.key === 'tab') {
            return `<span class="dk-active-pill"><span class="dk-active-pill__label">${escHtml(chip.label)}</span><span class="dk-active-pill__value">${escHtml(chip.value)}</span></span>`;
          }
          return `<span class="dk-active-pill"><span class="dk-active-pill__label">${escHtml(chip.label)}</span><span class="dk-active-pill__value">${escHtml(chip.value)}</span><button type="button" class="dk-active-pill__close" data-dk-dismiss-view="${escHtml(chip.key)}" aria-label="Quitar ${escHtml(chip.label.toLowerCase())}" title="Quitar ${escHtml(chip.label.toLowerCase())}">×</button></span>`;
        })
        .join('');
    }

    function syncAutoRefreshUi() {
      const btn = $('dk-autorefresh') as HTMLButtonElement;
      btn.textContent = `Auto: ${autoRefreshEnabled ? 'ON' : 'OFF'}`;
      btn.setAttribute('aria-pressed', autoRefreshEnabled ? 'true' : 'false');
      btn.classList.toggle('active', autoRefreshEnabled);
      btn.title = autoRefreshEnabled
        ? 'La vista se actualiza sola cada 15 segundos'
        : 'La vista no se actualizará sola hasta reactivarlo';
      const dot = $('dk-autorefresh-dot');
      dot.hidden = false;
      dot.dataset.loading = 'false';
    }

    function getRecoverCommand() {
      return [
        'cd /home/openclaw_vps/.openclaw/workspace/bichipishimockopenclaw',
        "pkill -f 'bun metrics-api/server.js' || true",
        "pkill -f 'python3 proxy-server.py' || true",
        'nohup bun metrics-api/server.js > .run/bun-start.out 2>&1 & echo $! > .run/bun-start.pid',
        'nohup python3 proxy-server.py > .run/proxy-server.out 2>&1 & echo $! > .run/proxy-server.pid',
        'sleep 2',
        'curl -fsS http://127.0.0.1:3001/api/metrics >/dev/null && curl -fsS http://127.0.0.1:8080/api/metrics >/dev/null && echo OK || echo FAIL',
      ].join(' && ');
    }

    function getQuickCommands() {
      if (tab === 'img') {
        return {
          listLabel: 'Copiar listado de imágenes',
          listCommand: 'docker image ls --format "table {{.Repository}}\t{{.Tag}}\t{{.Size}}\t{{.CreatedSince}}"',
          diagLabel: 'Copiar uso en disco de Docker',
          diagCommand: 'docker system df -v',
          recoverLabel: 'Copiar rearme local de Bun + proxy',
          recoverCommand: getRecoverCommand(),
        };
      }
      if (tab === 'vol') {
        return {
          listLabel: 'Copiar listado de volúmenes',
          listCommand: 'docker volume ls --format "table {{.Name}}\t{{.Driver}}\t{{.Scope}}"',
          diagLabel: 'Copiar inspección de uso de Docker',
          diagCommand: 'docker system df -v',
          recoverLabel: 'Copiar rearme local de Bun + proxy',
          recoverCommand: getRecoverCommand(),
        };
      }
      return {
        listLabel: 'Copiar listado de contenedores',
