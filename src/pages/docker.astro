    function getContainerIssueSignals(item: any, opts?: { omitLoadHints?: boolean }) {
      const status = String(item?.status || '').toLowerCase();
      const cpu = Number(item?.cpu) || 0;
      const mem = Number(item?.mem) || 0;
      const signals: Array<{ label: string; tone: 'crit' | 'warn' | 'info' }> = [];

      if (!status.includes('up') && !/(exit|dead|stopped|created)/.test(status)) {
        signals.push({ label: 'Detenido', tone: 'crit' });
      }
      if (status.includes('unhealthy')) signals.push({ label: 'Unhealthy', tone: 'crit' });
      if (status.includes('restarting')) signals.push({ label: 'Reiniciando', tone: 'warn' });
      if (status.includes('dead') || status.includes('failed') || status.includes('exit')) signals.push({ label: 'Fallo reciente', tone: 'crit' });
      if (!opts?.omitLoadHints) {
        if (cpu >= 70) signals.push({ label: 'CPU alta', tone: 'warn' });
        if (mem >= 80) signals.push({ label: 'RAM alta', tone: 'warn' });
      }

      return signals.slice(0, 4);
    }

    function hasContainerIssues(item: any) {
      return getContainerIssueSignals(item).some((signal) => signal.tone !== 'info');
    }

    function updateContainerFilterCounts(items: any[]) {
      const counts = {
        all: items.length,
        up: items.filter((c: any) => String(c.status || '').toLowerCase().includes('up')).length,
        down: items.filter((c: any) => !String(c.status || '').toLowerCase().includes('up')).length,
        ports: items.filter((c: any) => {
          const ports = String(c.ports || '').trim().toLowerCase();
          return ports && ports !== '—' && ports !== 'sin puertos expuestos';
        }).length,
        issues: items.filter((c: any) => hasContainerIssues(c)).length,
        hot: items.filter((c: any) => Number(c.cpu) >= 50 || Number(c.mem) >= 50).length,
      };
      document.querySelectorAll<HTMLElement>('[data-filter-count]').forEach((node) => {
        const key = node.dataset.filterCount as keyof typeof counts | undefined;
        if (!key) return;
        const value = counts[key];
        node.textContent = String(value);
        node.parentElement?.setAttribute('title', `${value} contenedores para este filtro`);
      });
    }

    document.querySelectorAll<HTMLButtonElement>('.dk-page .logs-tab').forEach((b) => {
      b.addEventListener('click', () => {
        const k = b.getAttribute('data-dk') as 'ctnr' | 'img' | 'vol' | null;
        if (k) showTab(k);
      });
    });

    async function load(fromAction = false) {
      try {
        if (!fromAction) {
          $('dk-autorefresh-dot').dataset.loading = 'true';
          setFeedback('Actualizando estado Docker…', actionInFlight ? 'Hay una acción en curso' : 'Consultando API local');
        }
        const d = await fetchMetrics();
        updateHeader(d);
        allCtrs = Array.isArray(d.containers) ? d.containers : [];
        allImgs = Array.isArray(d.dockerImages) ? d.dockerImages : [];
        allVols = Array.isArray(d.dockerVolumes) ? d.dockerVolumes : [];

        const ups = allCtrs.filter((c: any) => c.status?.toLowerCase().includes('up'));
        setStat('ds-total', String(allCtrs.length));
        setStat('ds-up', String(ups.length));
        setStat('ds-down', String(allCtrs.length - ups.length));
        setTabCount('dk-tab-count-ctnr', allCtrs.length);
        updateContainerFilterCounts(allCtrs);

        const totalBytes = Number(d.dockerImagesTotalBytes) || 0;
        const dangling = allImgs.filter((im: any) => im.repo === '<sin etiqueta>').length;
        const imgsInUse = allImgs.filter((im: any) => im.inUse).length;
        setStat('is-total', String(allImgs.length));
        setStat('is-inuse', String(imgsInUse));
        setStat('is-size', fmtBytes(totalBytes));
        setStat('is-dangling', String(dangling));
        setTabCount('dk-tab-count-img', allImgs.length);

        const drivers = [...new Set(allVols.map((v: any) => v.driver || 'local'))];
        const volsInUse = allVols.filter((v: any) => v.inUse).length;
        setStat('vs-total', String(allVols.length));
        setStat('vs-inuse', String(volsInUse));
        setStat('vs-drivers', drivers.length ? drivers.slice(0, 3).join(', ') + (drivers.length > 3 ? '…' : '') : '—');
        setTabCount('dk-tab-count-vol', allVols.length);

        lastLoadedAt = Date.now();
        dataLoaded = true;
        $('dk-autorefresh-dot').dataset.loading = 'false';
        setFeedback(
          `Estado Docker al día · ${allCtrs.filter((c: any) => c.status?.toLowerCase().includes('up')).length}/${allCtrs.length} contenedores activos`,
          `Última actualización ${fmtClock(lastLoadedAt)}`,
        );
        updateFreshnessState();
        render();
      } catch (e) {
        console.error(e);
        setFeedback('No se pudieron cargar datos Docker', 'Comprueba daemon/API y vuelve a intentar');
        ['ctnr-grid', 'img-grid', 'vol-grid'].forEach((gid) => {
          const g = $(gid);
          g.removeAttribute('aria-busy');
          g.innerHTML =
            '<div class="page-empty" style="grid-column:1/-1">No se pudieron cargar datos Docker (¿daemon en marcha y API actualizada?).</div>';
        });
      }
    }

    function matchesAllTerms(haystack: string, query: string) {
      if (!query) return true;
      const terms = query
        .split(/\s+/)
        .map((term) => term.trim().toLowerCase())
        .filter(Boolean);
      if (!terms.length) return true;
      return terms.every((term) => haystack.includes(term));
    }

    function matchesContainerSearch(item: any, query: string) {
      if (!query) return true;
      const hay = [
        item?.name,
        item?.status,
        item?.ports,
        item?.cpu != null ? `${item.cpu}% cpu` : '',
        item?.mem != null ? `${item.mem}% ram` : '',
      ]
        .map((value) => String(value || '').toLowerCase())
        .join(' ');
      const terms = query
        .split(/\s+/)
        .map((term) => term.trim().toLowerCase())
        .filter(Boolean);
      if (!terms.length) return true;
      const status = String(item?.status || '').toLowerCase();
      const ports = String(item?.ports || '').toLowerCase();
      const cpu = Number(item?.cpu || 0);
      const mem = Number(item?.mem || 0);
      const hasIssues = hasContainerIssues(item);
      const isUp = status.includes('up');
      const hasPublishedPorts = Boolean(ports && ports !== '—' && ports !== 'sin puertos expuestos');

      return terms.every((term) => {
        if (term === 'up' || term === 'running') return isUp;
        if (term === 'down' || term === 'stopped' || term === 'detenido') return !isUp;
        if (term === 'issue:true' || term === 'issues:true' || term === 'incidencia' || term === 'incidencias') return hasIssues;
        if (term === 'hot:true' || term === 'caliente') return cpu >= 50 || mem >= 50;
        if (term === 'ports:true' || term === 'con-puertos') return hasPublishedPorts;
        if (term.startsWith('status:')) {
          const wanted = term.slice(7);
          if (wanted === 'up' || wanted === 'running') return isUp;
          if (wanted === 'down' || wanted === 'stopped') return !isUp;
          return status.includes(wanted);
        }
        if (term.startsWith('port:')) {
          const wanted = term.slice(5);
          return wanted ? ports.includes(wanted) : true;
        }
        const cpuMatch = term.match(/^cpu(>=|<=|>|<|=)(\d+(?:\.\d+)?)$/);
        if (cpuMatch) {
          const [, op, raw] = cpuMatch;
          const limit = Number(raw);
          return op === '>' ? cpu > limit : op === '<' ? cpu < limit : op === '>=' ? cpu >= limit : op === '<=' ? cpu <= limit : cpu === limit;
        }
        const memMatch = term.match(/^(?:mem|ram)(>=|<=|>|<|=)(\d+(?:\.\d+)?)$/);
        if (memMatch) {
          const [, op, raw] = memMatch;
          const limit = Number(raw);
          return op === '>' ? mem > limit : op === '<' ? mem < limit : op === '>=' ? mem >= limit : op === '<=' ? mem <= limit : mem === limit;
        }
        return hay.includes(term);
      });
    }

    function matchesImageSearch(item: any, query: string) {
      if (!query) return true;
      const tags = Array.isArray(item?.tags) ? item.tags : [];
      const hay = [item?.repo, item?.id, item?.sizeLabel, ...tags].map((value) => String(value || '').toLowerCase()).join(' ');
      const terms = query
        .split(/\s+/)
        .map((term) => term.trim().toLowerCase())
        .filter(Boolean);
      if (!terms.length) return true;
      const repo = String(item?.repo || '').toLowerCase();
      const id = String(item?.id || '').toLowerCase();
      const inUse = Boolean(item?.inUse);
      const dangling = repo === '<sin etiqueta>';

      return terms.every((term) => {
        if (term === 'inuse' || term === 'in-use' || term === 'en-uso') return inUse;
        if (term === 'unused' || term === 'sin-uso' || term === 'libre') return !inUse;
        if (term === 'dangling' || term === 'untagged' || term === 'sin-etiqueta') return dangling;
        if (term.startsWith('repo:')) return repo.includes(term.slice(5));
        if (term.startsWith('id:')) return id.includes(term.slice(3));
        if (term.startsWith('tag:')) {
          const wanted = term.slice(4);
          return wanted ? tags.some((tag: string) => String(tag || '').toLowerCase().includes(wanted)) : true;
        }
        return hay.includes(term);
      });
    }

    function matchesVolumeSearch(item: any, query: string) {
      if (!query) return true;
      const hay = [item?.name, item?.driver, item?.mountpoint].map((value) => String(value || '').toLowerCase()).join(' ');
      const terms = query
        .split(/\s+/)
        .map((term) => term.trim().toLowerCase())
        .filter(Boolean);
      if (!terms.length) return true;
      const driver = String(item?.driver || '').toLowerCase();
      const mountpoint = String(item?.mountpoint || '').toLowerCase();
      const inUse = Boolean(item?.inUse);

      return terms.every((term) => {
        if (term === 'inuse' || term === 'in-use' || term === 'en-uso') return inUse;
        if (term === 'unused' || term === 'sin-uso' || term === 'libre') return !inUse;
        if (term.startsWith('driver:')) return driver.includes(term.slice(7));
        if (term.startsWith('mount:')) return mountpoint.includes(term.slice(6));
        return hay.includes(term);
      });
    }

    function render() {
      if (!dataLoaded) return;
      const q = ($('dk-search') as HTMLInputElement).value.toLowerCase().trim();

      if (tab === 'ctnr') {
        const grid = $('ctnr-grid');
        grid.removeAttribute('aria-busy');
        let filtered = allCtrs.filter((c: any) => matchesContainerSearch(c, q));
        if (filter === 'up') filtered = filtered.filter((c: any) => c.status?.toLowerCase().includes('up'));
        if (filter === 'down') filtered = filtered.filter((c: any) => !c.status?.toLowerCase().includes('up'));
        if (filter === 'ports') filtered = filtered.filter((c: any) => {
          const ports = String(c.ports || '').trim().toLowerCase();
          return ports && ports !== '—' && ports !== 'sin puertos expuestos';
        });
        if (filter === 'issues') filtered = filtered.filter((c: any) => hasContainerIssues(c));
        if (filter === 'hot') filtered = filtered.filter((c: any) => Number(c.cpu) >= 50 || Number(c.mem) >= 50);
        filtered = sortContainers(filtered);

        const filterLabel =
          filter === 'up'
            ? 'en marcha'
            : filter === 'down'
              ? 'detenidos'
              : filter === 'ports'
                ? 'con puertos expuestos'
                : filter === 'issues'
                  ? 'con incidencias'
                  : filter === 'hot'
                    ? 'calientes (CPU/RAM ≥50%)'
                    : '';
        const sortLabel =
          sortBy === 'cpu'
            ? 'CPU ↓'
            : sortBy === 'mem'
              ? 'RAM ↓'
              : sortBy === 'name'
                ? 'nombre A-Z'
                : sortBy === 'ports'
                  ? 'puertos primero'
                  : 'estado';
        const esc = escHtml;
        setResults(
          `Mostrando <strong>${esc(String(filtered.length))}</strong> de <strong>${esc(String(allCtrs.length))}</strong> contenedores` +
            (filterLabel ? ` · <span class="dk-results-meta">Filtro: ${esc(filterLabel)}</span>` : '') +
            (q ? ` · <span class="dk-results-meta">Búsqueda: «${esc(q)}»</span>` : '') +
            ` · <span class="dk-results-meta">Orden: ${esc(sortLabel)}</span>`,
        );

        const visibleUp = filtered.filter((c: any) => c.status?.toLowerCase().includes('up')).length;
        const visibleDown = filtered.length - visibleUp;
        const visiblePorts = filtered.filter((c: any) => {
          const ports = String(c.ports || '').trim().toLowerCase();
          return ports && ports !== '—' && ports !== 'sin puertos expuestos';
        }).length;
        const visibleIssues = filtered.filter((c: any) => hasContainerIssues(c)).length;
        const visibleHot = filtered.filter((c: any) => Number(c.cpu) >= 50 || Number(c.mem) >= 50).length;
        const avgCpuVisible = filtered.length
          ? Math.round((filtered.reduce((sum: number, c: any) => sum + (Number(c.cpu) || 0), 0) / filtered.length) * 10) / 10
          : 0;
        const avgMemVisible = filtered.length
          ? Math.round((filtered.reduce((sum: number, c: any) => sum + (Number(c.mem) || 0), 0) / filtered.length) * 10) / 10
          : 0;
        setSummary([
          { label: 'en marcha', value: visibleUp, tone: visibleUp ? 'ok' : 'info', filterKey: 'up' },
          { label: 'detenidos', value: visibleDown, tone: visibleDown ? 'crit' : 'info', filterKey: 'down' },
          { label: 'con incidencias', value: visibleIssues, tone: visibleIssues ? 'crit' : 'ok', filterKey: 'issues' },
          { label: 'con puertos', value: visiblePorts, tone: visiblePorts ? 'info' : 'warn', filterKey: 'ports' },
          { label: 'calientes (CPU/RAM ≥50%)', value: visibleHot, tone: visibleHot ? 'warn' : 'ok', filterKey: 'hot' },
          { label: 'CPU media visible', value: `${avgCpuVisible}%`, tone: avgCpuVisible >= 50 ? 'warn' : 'info' },
          { label: 'RAM media visible', value: `${avgMemVisible}%`, tone: avgMemVisible >= 50 ? 'warn' : 'info' },
        ]);

        if (!filtered.length) {
          const emptyMsg =
            filter === 'ports'
              ? 'No hay contenedores con puertos expuestos que coincidan con la búsqueda actual'
              : filter === 'issues'
                ? 'No hay contenedores con incidencias que coincidan con la búsqueda actual'
                : filter === 'hot'
                  ? 'No hay contenedores calientes (CPU/RAM ≥50%) que coincidan con la búsqueda actual'
                  : 'Sin contenedores que coincidan';
          grid.innerHTML = renderEmptyState(emptyMsg);
          return;
        }

        grid.innerHTML = filtered.map((c: any, i: number) => {
          const up = c.status?.toLowerCase().includes('up');
          const dis = actionInFlight ? 'disabled' : '';
          const name = escHtml(c.name);
          const st = String(c.status || '').trim();
          const portsStr = String(c.ports || '').trim();
          const showMetricBars = up && (c.cpu != null || c.mem != null);
          const issueSignals = getContainerIssueSignals(c, { omitLoadHints: showMetricBars });

          const mainParts: string[] = [];
          if (st) mainParts.push(st);
          if (up) {
            const d = fmtContainerDuration(c.status);
            if (d) mainParts.push(d);
          }
          if (portsStr) mainParts.push(portsStr);
          if (!showMetricBars) {
            if (c.cpu != null) mainParts.push(`${c.cpu}% CPU`);
            if (c.mem != null) mainParts.push(`${c.mem}% RAM`);
          }
          const mainLine = mainParts.join(' · ');
          const badgesHtml =
            issueSignals.length > 0
              ? `<div class="dk-svc-meta__badges">${issueSignals
                  .map((s) => `<span class="dk-svc-badge dk-svc-badge--${s.tone}">${escHtml(s.label)}</span>`)
                  .join('')}</div>`
              : '';
          const descBlock =
            mainLine || badgesHtml
              ? `<div class="info-card-svc-desc dk-svc-meta"><span class="info-card-svc-desc__icon" aria-hidden="true">${iInfo}</span><div class="dk-svc-meta__stack">${
                  mainLine ? `<p class="dk-svc-meta__line">${escHtml(mainLine)}</p>` : ''
                }${badgesHtml}</div></div>`
              : `<div class="info-card-svc-desc info-card-svc-desc--empty" role="note" aria-label="Sin detalle"><span class="info-card-svc-desc__icon" aria-hidden="true">${iInfo}</span></div>`;
          const runLabel = up ? 'En marcha' : 'Detenido';
          const runIcon = up ? iSvcRun : iSvcStopped;
          const cliToggleBtn = `<button type="button" class="svc-cli-toggle" data-dk-cli-toggle aria-expanded="false" aria-label="Mostrar comandos de referencia" title="Comando de referencia" ${dis}><span class="svc-cli-toggle__chev" aria-hidden="true">${iChevDown}</span></button>`;
          const portsText = portsStr || 'Sin puertos expuestos';
          const cliPre = `docker logs -f ${c.name || ''}\ndocker inspect ${c.name || ''}\n\n# Puertos\n${portsText}`;
          const cliPanelHtml = `<div class="svc-cli-panel" hidden data-dk-cli-panel>
              <pre class="svc-cli-snippet">${escHtml(cliPre)}</pre>
              <div class="svc-cli-fallback__toolbar">
                <button type="button" class="card-action-btn svc-cli-icon-btn" data-dk-copy="name" data-dk-value="${encodeURIComponent(c.name || '')}" aria-label="Copiar nombre" title="Copiar nombre" ${dis}>${iCopyCli}</button>
                <button type="button" class="card-action-btn svc-cli-icon-btn" data-dk-copy="ports" data-dk-value="${encodeURIComponent(c.ports || '')}" aria-label="Copiar puertos" title="Copiar puertos" ${dis}>${iCopyCli}</button>
                <button type="button" class="card-action-btn svc-cli-icon-btn" data-dk-copy="container-cli" data-dk-value="${encodeURIComponent(`docker logs -f ${c.name || ''}`)}" aria-label="Copiar docker logs" title="docker logs -f" ${dis}>${iTerminal}</button>
                <button type="button" class="card-action-btn svc-cli-icon-btn" data-dk-copy="container-inspect" data-dk-value="${encodeURIComponent(`docker inspect ${c.name || ''}`)}" aria-label="Copiar docker inspect" title="docker inspect" ${dis}>${iCopyCli}</button>
              </div>
            </div>`;
          const metricBars = showMetricBars
              ? `<div class="dk-metric-bars" aria-label="Uso de recursos del contenedor">
              <div class="dk-metric-bars__grid">
              ${c.cpu != null ? `<div class="dk-metric-cell"><div class="dk-metric-cell__head"><span class="dk-metric-cell__k">CPU</span><span class="dk-metric-cell__val">${c.cpu}%</span></div><div class="dk-metric-bar__track"><div class="dk-metric-bar__fill${Number(c.cpu) >= 70 ? ' dk-metric-bar__fill--warn' : Number(c.cpu) >= 50 ? ' dk-metric-bar__fill--mid' : ''}" style="width:${Math.min(Number(c.cpu) || 0, 100)}%"></div></div></div>` : ''}
              ${c.mem != null ? `<div class="dk-metric-cell"><div class="dk-metric-cell__head"><span class="dk-metric-cell__k">RAM</span><span class="dk-metric-cell__val">${c.mem}%</span></div><div class="dk-metric-bar__track"><div class="dk-metric-bar__fill${Number(c.mem) >= 80 ? ' dk-metric-bar__fill--warn' : Number(c.mem) >= 50 ? ' dk-metric-bar__fill--mid' : ''}" style="width:${Math.min(Number(c.mem) || 0, 100)}%"></div></div></div>` : ''}
              </div></div>`
              : '';
          return `<div class="info-card info-card--svc" data-busy="${actionInFlight ? 'true' : 'false'}" style="animation:listSlideIn 0.3s ease ${i * 30}ms both">
            <div class="info-card-header info-card-header--svc">
              <div class="info-card-svc-top">
                <div class="info-card-svc-text">
                  <div class="info-card-title">${name}</div>
                  ${descBlock}
                </div>
                <div class="info-card-svc-meta" role="group" aria-label="${runLabel}">
                  <span class="svc-status-run ${up ? 'svc-status-run--on' : 'svc-status-run--off'}" title="${runLabel}" aria-label="${runLabel}" role="status">${runIcon}</span>
                  ${cliToggleBtn}
                </div>
              </div>
            </div>
            ${cliPanelHtml}
            ${metricBars}
            <div class="info-card-actions dk-card-actions dk-card-actions--split" role="group" aria-label="Acciones del contenedor">
              <div class="dk-card-actions__primary">
              ${up
                ? `<button class="card-action-btn card-action-btn--stop" type="button" title="Detener contenedor" aria-label="Detener contenedor" data-dk-action="stop" data-dk-name="${encodeURIComponent(c.name || '')}" ${dis}>${iStop}</button>
                   <button class="card-action-btn card-action-btn--restart" type="button" title="Reiniciar contenedor" aria-label="Reiniciar contenedor" data-dk-action="restart" data-dk-name="${encodeURIComponent(c.name || '')}" ${dis}>${iRestart}</button>`
                : `<button class="card-action-btn card-action-btn--start" type="button" title="Iniciar contenedor" aria-label="Iniciar contenedor" data-dk-action="start" data-dk-name="${encodeURIComponent(c.name || '')}" ${dis}>${iPlay}</button>`}
              </div>
              <div class="dk-card-actions__danger">
                <button class="card-action-btn card-action-btn--danger" type="button" title="Eliminar contenedor" aria-label="Eliminar contenedor" data-dk-action="delete" data-dk-name="${encodeURIComponent(c.name || '')}" ${dis}>${iTrash}</button>
              </div>
            </div>
          </div>`;
        }).join('');
      }

      if (tab === 'img') {
        const grid = $('img-grid');
        grid.removeAttribute('aria-busy');
        const filtered = sortImages(allImgs.filter((im: any) => matchesImageSearch(im, q)));

        const sortLabel = sortBy === 'size' ? 'tamaño ↓' : sortBy === 'name' ? 'nombre A-Z' : 'fecha ↓';
        const esc = escHtml;
        setResults(
          `Mostrando <strong>${esc(String(filtered.length))}</strong> de <strong>${esc(String(allImgs.length))}</strong> imágenes` +
            (q ? ` · <span class="dk-results-meta">Búsqueda: «${esc(q)}»</span>` : '') +
            ` · <span class="dk-results-meta">Orden: ${esc(sortLabel)}</span>`,
        );
        const danglingCount = filtered.filter((im: any) => im.repo === '<sin etiqueta>').length;
        const imgsInUseVis = filtered.filter((im: any) => im.inUse).length;
        const totalVisibleBytes = filtered.reduce((sum: number, im: any) => sum + (Number(im.size) || 0), 0);
        setSummary([
          { label: 'visibles', value: filtered.length, tone: 'info' },
          { label: 'en uso', value: imgsInUseVis, tone: imgsInUseVis ? 'ok' : 'info' },
          { label: 'sin etiqueta', value: danglingCount, tone: danglingCount ? 'warn' : 'ok' },
          { label: 'tamaño visible', value: fmtBytes(totalVisibleBytes), tone: 'info' },
        ]);

        if (!filtered.length) {
          const msg =
            allImgs.length === 0
              ? 'No hay imágenes en la respuesta de la API (reinicia el servidor y comprueba Docker).'
              : 'Sin imágenes que coincidan';
          grid.innerHTML = renderEmptyState(msg);
          return;
        }

        grid.innerHTML = filtered.map((im: any, i: number) => {
          const dangling = im.repo === '<sin etiqueta>';
          const inUse = Boolean(im.inUse);
          const nCont = Number(im.usedByContainers) || 0;
          const dis = actionInFlight ? 'disabled' : '';
          const useLabel = inUse
            ? nCont > 0
              ? `En uso · ${nCont} ${nCont === 1 ? 'contenedor' : 'contenedores'}`
              : 'En uso'
            : 'Sin usar';
          const bits = [`ID ${im.id || '—'}`, im.sizeLabel || '—', fmtTs(im.created), useLabel];
          if (dangling) bits.push('Sin etiqueta');
          const mergedDesc = bits.join(' · ');
          const descBlock = mergedDesc
            ? `<div class="info-card-svc-desc"><span class="info-card-svc-desc__icon" aria-hidden="true">${iInfo}</span><span class="info-card-svc-desc__txt">${escHtml(mergedDesc)}</span></div>`
            : `<div class="info-card-svc-desc info-card-svc-desc--empty" role="note"><span class="info-card-svc-desc__icon" aria-hidden="true">${iInfo}</span></div>`;
          const actLabel = inUse ? 'Referenciada por contenedores' : 'Sin referencias';
          const activeIcon = inUse ? iSvcActiveOn : iSvcActiveOff;
          const cliToggleBtn = `<button type="button" class="svc-cli-toggle" data-dk-cli-toggle aria-expanded="false" aria-label="Mostrar comandos de referencia" title="Comando de referencia" ${dis}><span class="svc-cli-toggle__chev" aria-hidden="true">${iChevDown}</span></button>`;
          const tagExtra = Array.isArray(im.tags) && im.tags.length > 1 ? im.tags.slice(1).join('\n') : '';
          const cliPre = `docker image inspect ${im.id || ''}${tagExtra ? `\n\n# Etiquetas adicionales\n${tagExtra}` : ''}`;
          const cliPanelHtml = `<div class="svc-cli-panel" hidden data-dk-cli-panel>
              <pre class="svc-cli-snippet">${escHtml(cliPre)}</pre>
              <div class="svc-cli-fallback__toolbar">
                <button type="button" class="card-action-btn svc-cli-icon-btn" data-dk-copy="image-repo" data-dk-value="${encodeURIComponent(im.repo || '')}" aria-label="Copiar repositorio" title="Copiar repositorio" ${dis}>${iCopyCli}</button>
                <button type="button" class="card-action-btn svc-cli-icon-btn" data-dk-copy="image-id" data-dk-value="${encodeURIComponent(im.id || '')}" aria-label="Copiar ID" title="Copiar ID" ${dis}>${iCopyCli}</button>
                <button type="button" class="card-action-btn svc-cli-icon-btn" data-dk-copy="image-cli" data-dk-value="${encodeURIComponent(`docker image inspect ${im.id || ''}`)}" aria-label="Copiar inspect" title="docker image inspect" ${dis}>${iTerminal}</button>
              </div>
            </div>`;
          const extra =
            Array.isArray(im.tags) && im.tags.length > 1
              ? `<div class="info-card-htop">${im.tags.slice(1).map((t: string) => escHtml(t)).join('<br/>')}</div>`
              : '';
          return `<div class="info-card info-card--svc" data-busy="${actionInFlight ? 'true' : 'false'}" style="animation:listSlideIn 0.3s ease ${i * 25}ms both">
            <div class="info-card-header info-card-header--svc">
              <div class="info-card-svc-top">
                <div class="info-card-svc-text">
                  <div class="info-card-title">${escHtml(im.repo || '—')}</div>
                  ${descBlock}
                </div>
                <div class="info-card-svc-meta" role="group" aria-label="${escHtml(actLabel)}">
                  <span class="svc-status-active ${inUse ? 'svc-status-active--on' : 'svc-status-active--off'}" title="${escHtml(actLabel)}" aria-label="${escHtml(actLabel)}" role="status">${activeIcon}</span>
                  ${cliToggleBtn}
                </div>
              </div>
            </div>
            ${cliPanelHtml}
            ${extra}
            <div class="info-card-actions dk-card-actions dk-card-actions--split dk-card-actions--solo-danger" role="group" aria-label="Acciones de la imagen">
              <div class="dk-card-actions__danger">
                <button class="card-action-btn card-action-btn--danger" type="button" title="Eliminar imagen" aria-label="Eliminar imagen de Docker" data-dk-del-img="1" data-dk-img-id="${encodeURIComponent(im.id || '')}" data-dk-img-label="${encodeURIComponent(im.repo || im.id || '')}" ${dis}>${iTrash}</button>
              </div>
            </div>
          </div>`;
        }).join('');
      }

      if (tab === 'vol') {
        const grid = $('vol-grid');
        grid.removeAttribute('aria-busy');
        const filtered = sortVolumes(allVols.filter((v: any) => matchesVolumeSearch(v, q)));

        const sortLabel = sortBy === 'created' ? 'fecha ↓' : 'nombre A-Z';
        const esc = escHtml;
        setResults(
          `Mostrando <strong>${esc(String(filtered.length))}</strong> de <strong>${esc(String(allVols.length))}</strong> volúmenes` +
            (q ? ` · <span class="dk-results-meta">Búsqueda: «${esc(q)}»</span>` : '') +
            ` · <span class="dk-results-meta">Orden: ${esc(sortLabel)}</span>`,
        );
        const visibleDrivers = [...new Set(filtered.map((v: any) => v.driver || 'local'))].length;
        const withMountpoint = filtered.filter((v: any) => String(v.mountpoint || '').trim()).length;
        const volsInUseVis = filtered.filter((v: any) => v.inUse).length;
        setSummary([
          { label: 'visibles', value: filtered.length, tone: 'info' },
          { label: 'en uso', value: volsInUseVis, tone: volsInUseVis ? 'ok' : 'info' },
          { label: 'drivers', value: visibleDrivers, tone: 'info' },
          { label: 'con mountpoint', value: withMountpoint, tone: withMountpoint ? 'ok' : 'warn' },
        ]);

        if (!filtered.length) {
          const msg =
            allVols.length === 0
              ? 'No hay volúmenes en la respuesta de la API (reinicia el servidor y comprueba Docker).'
              : 'Sin volúmenes que coincidan';
          grid.innerHTML = renderEmptyState(msg);
          return;
        }

        grid.innerHTML = filtered.map((v: any, i: number) => {
          const mp = (v.mountpoint || '').trim() || '—';
          const vInUse = Boolean(v.inUse);
          const vn = Number(v.usedByContainers) || 0;
          const dis = actionInFlight ? 'disabled' : '';
          const useLabel = vInUse
            ? vn > 0
              ? `En uso · ${vn} ${vn === 1 ? 'contenedor' : 'contenedores'}`
              : 'En uso'
            : 'Libre';
          const mergedDesc = [`${v.driver || 'local'}${v.scope ? ` · ${v.scope}` : ''}`, fmtTs(v.created), useLabel].join(' · ');
          const descBlock = `<div class="info-card-svc-desc"><span class="info-card-svc-desc__icon" aria-hidden="true">${iInfo}</span><span class="info-card-svc-desc__txt">${escHtml(mergedDesc)}</span></div>`;
          const actLabel = vInUse ? 'En uso' : 'Libre';
          const activeIcon = vInUse ? iSvcActiveOn : iSvcActiveOff;
          const cliToggleBtn = `<button type="button" class="svc-cli-toggle" data-dk-cli-toggle aria-expanded="false" aria-label="Mostrar comandos de referencia" title="Comando de referencia" ${dis}><span class="svc-cli-toggle__chev" aria-hidden="true">${iChevDown}</span></button>`;
          const cliPre = `docker volume inspect ${v.name || ''}\ndocker volume ls --filter name=${v.name || ''}\n\n# Mountpoint\n${mp}`;
          const cliPanelHtml = `<div class="svc-cli-panel" hidden data-dk-cli-panel>
              <pre class="svc-cli-snippet">${escHtml(cliPre)}</pre>
              <div class="svc-cli-fallback__toolbar">
                <button type="button" class="card-action-btn svc-cli-icon-btn" data-dk-copy="volume-name" data-dk-value="${encodeURIComponent(v.name || '')}" aria-label="Copiar nombre" title="Copiar nombre" ${dis}>${iCopyCli}</button>
                <button type="button" class="card-action-btn svc-cli-icon-btn" data-dk-copy="volume-mountpoint" data-dk-value="${encodeURIComponent(v.mountpoint || '')}" aria-label="Copiar mountpoint" title="Copiar mountpoint" ${dis}>${iCopyCli}</button>
                <button type="button" class="card-action-btn svc-cli-icon-btn" data-dk-copy="volume-cli" data-dk-value="${encodeURIComponent(`docker volume inspect ${v.name || ''}`)}" aria-label="Copiar inspect" title="docker volume inspect" ${dis}>${iTerminal}</button>
                <button type="button" class="card-action-btn svc-cli-icon-btn" data-dk-copy="volume-list" data-dk-value="${encodeURIComponent(`docker volume ls --filter name=${v.name || ''}`)}" aria-label="Copiar listado filtrado" title="docker volume ls" ${dis}>${iCopyCli}</button>
              </div>
            </div>`;
          return `<div class="info-card info-card--svc" data-busy="${actionInFlight ? 'true' : 'false'}" style="animation:listSlideIn 0.3s ease ${i * 25}ms both">
            <div class="info-card-header info-card-header--svc">
              <div class="info-card-svc-top">
                <div class="info-card-svc-text">
                  <div class="info-card-title">${escHtml(v.name || '—')}</div>
                  ${descBlock}
                </div>
                <div class="info-card-svc-meta" role="group" aria-label="${escHtml(actLabel)}">
                  <span class="svc-status-active ${vInUse ? 'svc-status-active--on' : 'svc-status-active--off'}" title="${escHtml(actLabel)}" aria-label="${escHtml(actLabel)}" role="status">${activeIcon}</span>
                  ${cliToggleBtn}
                </div>
              </div>
            </div>
            ${cliPanelHtml}
            <div class="info-card-actions dk-card-actions dk-card-actions--split dk-card-actions--solo-danger" role="group" aria-label="Acciones del volumen">
              <div class="dk-card-actions__danger">
                <button class="card-action-btn card-action-btn--danger" type="button" title="Eliminar volumen" aria-label="Eliminar volumen de Docker" data-dk-del-vol="1" data-dk-vol-name="${encodeURIComponent(v.name || '')}" ${dis}>${iTrash}</button>
              </div>
            </div>
          </div>`;
        }).join('');
      }
    }

    function runDockerShortcut(kind: 'search' | 'refresh' | 'clear' | 'tabs' | 'autorefresh' | 'reset') {
      const input = $('dk-search') as HTMLInputElement;
      if (kind === 'search') {
        input.focus();
        input.select();
        setFeedback('Buscador enfocado', 'Escribe para filtrar la vista Docker');
        return;
      }
      if (kind === 'refresh') {
        setFeedback('Actualizando Docker…', lastLoadedAt ? `Última actualización ${fmtClock(lastLoadedAt)}` : 'Consultando API local');
        void load();
        return;
      }
      if (kind === 'tabs') {
        setFeedback('Atajo de pestañas disponible', 'Pulsa 1 = Contenedores · 2 = Imágenes · 3 = Volúmenes');
        return;
      }
      if (kind === 'autorefresh') {
        ($('dk-autorefresh') as HTMLButtonElement).click();
        return;
      }
      if (kind === 'reset') {
        resetView();
        return;
      }
      if (kind === 'clear') {
        if (input.value.trim()) {
          input.value = '';
          syncSearchUi();
          syncResetViewUi();
          updateActiveViewChips();
          saveViewState();
          render();
          setFeedback('Búsqueda limpiada', 'Pulsa / para volver a enfocar el buscador');
          return;
        }
        if (document.activeElement === input) {
          input.blur();
          setFeedback('Listo', 'Atajo Esc: foco fuera del buscador');
        }
      }
    }

    document.querySelector('.dk-page .dk-shortcuts')?.addEventListener('click', (ev) => {
      const btn = (ev.target as HTMLElement).closest<HTMLButtonElement>('[data-dk-shortcut]');
      if (!btn) return;
      const k = btn.dataset.dkShortcut as 'search' | 'refresh' | 'clear' | 'tabs' | 'autorefresh' | 'reset' | undefined;
      if (k === 'search' || k === 'refresh' || k === 'clear' || k === 'tabs' || k === 'autorefresh' || k === 'reset') runDockerShortcut(k);
    });

    document.querySelector('.dk-page .dk-presets')?.addEventListener('click', (ev) => {
      const btn = (ev.target as HTMLElement).closest<HTMLButtonElement>('[data-dk-preset]');
      if (!btn) return;
      if (tab !== 'ctnr') showTab('ctnr');
      const value = String(btn.dataset.dkPreset || '').trim();
      if (!value) return;
      const input = $('dk-search') as HTMLInputElement;
      input.value = value;
      syncSearchUi();
      syncResetViewUi();
      saveViewState();
      render();
      input.focus();
      input.select();
      setFeedback(`Filtro rápido aplicado: ${value}`, 'Pulsa Esc para limpiar o edita la búsqueda');
    });

    $('dk-search').addEventListener('input', () => {
      syncSearchUi();
      syncResetViewUi();
      updateActiveViewChips();
      saveViewState();
      render();
    });
    $('dk-search').addEventListener('keydown', (ev) => {
      if (ev.key !== 'Escape') return;
      ev.preventDefault();
      runDockerShortcut('clear');
    });
    $('dk-search-clear').addEventListener('click', () => {
      const input = $('dk-search') as HTMLInputElement;
      input.value = '';
      syncSearchUi();
      syncResetViewUi();
      updateActiveViewChips();
      saveViewState();
      input.focus();
      setFeedback('Búsqueda limpiada', 'Puedes seguir filtrando o pulsar / para volver rápido');
      render();
    });

    document.addEventListener('keydown', (ev) => {
      const target = ev.target as HTMLElement | null;
      const tagName = target?.tagName || '';
      const isTypingTarget = tagName === 'INPUT' || tagName === 'TEXTAREA' || tagName === 'SELECT' || target?.isContentEditable;
      const input = $('dk-search') as HTMLInputElement;

      if (ev.key === '/' && !isTypingTarget) {
        ev.preventDefault();
        runDockerShortcut('search');
        return;
      }

      if ((ev.key === 'r' || ev.key === 'R') && !isTypingTarget && !ev.ctrlKey && !ev.metaKey && !ev.altKey) {
        ev.preventDefault();
        runDockerShortcut('refresh');
        return;
      }

      if ((ev.key === 'a' || ev.key === 'A') && !isTypingTarget && !ev.ctrlKey && !ev.metaKey && !ev.altKey) {
        ev.preventDefault();
        runDockerShortcut('autorefresh');
        return;
      }

      if (!isTypingTarget && !ev.ctrlKey && !ev.metaKey && !ev.altKey) {
        if (ev.key === '1') {
          ev.preventDefault();
          showTab('ctnr');
          setFeedback('Vista Docker: Contenedores', 'Atajo 1 · 2 = Imágenes · 3 = Volúmenes');
          return;
        }
        if (ev.key === '2') {
          ev.preventDefault();
          showTab('img');
          setFeedback('Vista Docker: Imágenes', 'Atajo 2 · 1 = Contenedores · 3 = Volúmenes');
          return;
        }
        if (ev.key === '3') {
          ev.preventDefault();
          showTab('vol');
          setFeedback('Vista Docker: Volúmenes', 'Atajo 3 · 1 = Contenedores · 2 = Imágenes');
          return;
        }
        if (ev.key === '0') {
          ev.preventDefault();
          runDockerShortcut('reset');
          return;
        }
      }

      if (ev.key === 'Escape' && !isTypingTarget && input.value.trim()) {
        ev.preventDefault();
        runDockerShortcut('clear');
      }
    });
    $('dk-autorefresh').addEventListener('click', () => {
      autoRefreshEnabled = !autoRefreshEnabled;
      hiddenAutoPause = false;
      syncAutoRefreshUi();
      syncResetViewUi();
      updateActiveViewChips();
      saveViewState();
      if (autoRefreshEnabled) {
        setFeedback('Auto-refresh reactivado', lastLoadedAt ? `Última actualización ${fmtClock(lastLoadedAt)}` : 'La próxima actualización será automática');
        if (!actionInFlight && (!lastLoadedAt || Date.now() - lastLoadedAt >= staleRefreshMs)) {
          void load();
        }
      } else {
        setFeedback('Auto-refresh pausado', lastLoadedAt ? `Datos congelados desde ${fmtClock(lastLoadedAt)}` : 'Usa el botón de refrescar para recargar manualmente');
      }
      updateFreshnessState();
    });
    $('dk-sort').addEventListener('change', (ev) => {
      sortBy = (ev.target as HTMLSelectElement).value as typeof sortBy;
      syncSortUi();
      syncResetViewUi();
      updateActiveViewChips();
      saveViewState();
      render();
    });
    $('dk-reset-view').addEventListener('click', resetView);
    $('dk-refresh').addEventListener('click', () => {
      void load();
    });

    $('dk-copy-list').addEventListener('click', () => {
      const cmds = getQuickCommands();
      void copyText(cmds.listCommand, `${cmds.listLabel} copiado`, 'No había comando de listado para copiar');
    });
    $('dk-copy-diagnose').addEventListener('click', () => {
      const cmds = getQuickCommands();
      void copyText(cmds.diagCommand, `${cmds.diagLabel} copiado`, 'No había comando de diagnóstico para copiar');
    });
    $('dk-copy-recover').addEventListener('click', () => {
      const cmds = getQuickCommands();
      void copyText(cmds.recoverCommand, 'Comando de rearme local copiado', 'No se pudo generar el comando de rearme local');
    });
    $('dk-copy-view-link').addEventListener('click', () => {
      const qs = viewStateToQueryString();
      const url = `${window.location.origin}${window.location.pathname}${qs ? `?${qs}` : ''}`;
      void copyText(url, 'Enlace de la vista Docker copiado', 'No se pudo generar un enlace útil para esta vista');
    });

    document.querySelectorAll('#dk-ctnr-filters [data-filter]').forEach((btn) => {
      btn.addEventListener('click', () => {
        filter = (btn as HTMLElement).dataset.filter!;
        syncFilterButtons();
        syncResetViewUi();
        updateActiveViewChips();
        saveViewState();
        render();
      });
    });

    ['ctnr-grid', 'img-grid', 'vol-grid'].forEach((gridId) => {
      $(gridId).addEventListener('click', (ev) => {
        const resetBtn = (ev.target as HTMLElement).closest<HTMLButtonElement>('[data-dk-empty-reset]');
        if (!resetBtn) return;
        resetView();
      });
    });

    function handleCopyClick(ev: Event) {
      const target = ev.target as HTMLElement;
      const copyBtn = target.closest<HTMLButtonElement>('[data-dk-copy]');
      if (!copyBtn) return false;
      const kind = copyBtn.dataset.dkCopy;
      const value = copyBtn.dataset.dkValue ? decodeURIComponent(copyBtn.dataset.dkValue) : '';
      if (kind === 'name') {
        void copyText(value, 'Nombre del contenedor copiado', 'Este contenedor no tiene nombre para copiar');
        return true;
      }
      if (kind === 'ports') {
        void copyText(value, 'Puertos del contenedor copiados', 'Este contenedor no expone puertos');
        return true;
      }
      if (kind === 'image-id') {
        void copyText(value, 'ID de imagen copiado', 'Esta imagen no tiene ID utilizable');
        return true;
      }
      if (kind === 'image-repo') {
        void copyText(value, 'Repositorio de imagen copiado', 'Esta imagen no tiene repositorio utilizable');
        return true;
      }
      if (kind === 'volume-name') {
        void copyText(value, 'Nombre del volumen copiado', 'Este volumen no tiene nombre utilizable');
        return true;
      }
      if (kind === 'volume-mountpoint') {
        void copyText(value, 'Mountpoint del volumen copiado', 'Este volumen no expone mountpoint');
        return true;
      }
      if (kind === 'container-cli') {
        void copyText(value, 'Comando docker logs copiado', 'Este contenedor no tiene un nombre válido para generar el comando');
        return true;
      }
      if (kind === 'container-inspect') {
        void copyText(value, 'Comando docker inspect copiado', 'Este contenedor no tiene un nombre válido para generar el comando');
        return true;
      }
      if (kind === 'image-cli') {
        void copyText(value, 'Comando docker image inspect copiado', 'Esta imagen no tiene un ID válido para generar el comando');
        return true;
      }
      if (kind === 'volume-cli') {
        void copyText(value, 'Comando docker volume inspect copiado', 'Este volumen no tiene un nombre válido para generar el comando');
        return true;
      }
      if (kind === 'volume-list') {
        void copyText(value, 'Comando docker volume ls copiado', 'Este volumen no tiene un nombre válido para generar el comando');
        return true;
      }
      return false;
    }

    $('ctnr-grid').addEventListener('click', (ev) => {
      const target = ev.target as HTMLElement;
      if (handleDkCliToggle(ev)) return;
      if (handleCopyClick(ev)) return;

      const btn = target.closest<HTMLButtonElement>('[data-dk-action]');
      if (!btn) return;
      const action = btn.dataset.dkAction;
      const name = btn.dataset.dkName ? decodeURIComponent(btn.dataset.dkName) : '';
      if (!action || !name) return;
      doAction(name, action);
    });

    $('img-grid').addEventListener('click', (ev) => {
      const target = ev.target as HTMLElement;
      if (handleDkCliToggle(ev)) return;
      if (handleCopyClick(ev)) return;
      const imgDel = target.closest<HTMLButtonElement>('[data-dk-del-img]');
      if (imgDel) {
        const id = imgDel.dataset.dkImgId ? decodeURIComponent(imgDel.dataset.dkImgId) : '';
        const label = imgDel.dataset.dkImgLabel ? decodeURIComponent(imgDel.dataset.dkImgLabel) : id;
        if (id) void deleteDockerImage(id, label);
      }
    });

    $('vol-grid').addEventListener('click', (ev) => {
      const target = ev.target as HTMLElement;
      if (handleDkCliToggle(ev)) return;
      if (handleCopyClick(ev)) return;
      const volDel = target.closest<HTMLButtonElement>('[data-dk-del-vol]');
      if (volDel) {
        const volName = volDel.dataset.dkVolName ? decodeURIComponent(volDel.dataset.dkVolName) : '';
        if (volName) void deleteDockerVolume(volName);
      }
    });

    $('dk-summary').addEventListener('click', (ev) => {
      const btn = (ev.target as HTMLElement).closest<HTMLButtonElement>('[data-summary-filter]');
      if (!btn || tab !== 'ctnr') return;
      const nextFilter = btn.dataset.summaryFilter;
      if (!nextFilter) return;
      filter = nextFilter === filter ? 'all' : nextFilter;
      syncFilterButtons();
      syncResetViewUi();
      updateActiveViewChips();
      saveViewState();
      render();
    });

    $('dk-active-view').addEventListener('click', (ev) => {
      const btn = (ev.target as HTMLElement).closest<HTMLButtonElement>('[data-dk-dismiss-view]');
      if (!btn) return;
      const key = btn.dataset.dkDismissView;
      if (key === 'filter') {
        filter = 'all';
        syncFilterButtons();
      } else if (key === 'search') {
        const input = $('dk-search') as HTMLInputElement;
        input.value = '';
        syncSearchUi();
      } else if (key === 'sort') {
        sortBy = defaultSortForTab(tab);
        syncSortUi();
      } else if (key === 'auto') {
        autoRefreshEnabled = true;
        hiddenAutoPause = false;
        syncAutoRefreshUi();
      }
      syncResetViewUi();
      updateActiveViewChips();
      saveViewState();
      render();
      if (key === 'auto' && !actionInFlight && (!lastLoadedAt || Date.now() - lastLoadedAt >= staleRefreshMs)) {
        void load();
      }
    });

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        if (autoRefreshEnabled) {
          hiddenAutoPause = true;
          autoRefreshEnabled = false;
          syncAutoRefreshUi();
          syncResetViewUi();
          updateActiveViewChips();
          saveViewState();
          updateFreshnessState();
        }
        return;
      }
      if (hiddenAutoPause) {
        hiddenAutoPause = false;
        autoRefreshEnabled = true;
        syncAutoRefreshUi();
        syncResetViewUi();
        updateActiveViewChips();
        saveViewState();
        setFeedback('Auto-refresh reactivado al volver a la pestaña', lastLoadedAt ? `Última actualización ${fmtClock(lastLoadedAt)}` : 'Recargando vista Docker');
        if (!actionInFlight && (!lastLoadedAt || Date.now() - lastLoadedAt >= staleRefreshMs)) {
          void load();
        } else {
          updateFreshnessState();
        }
        return;
      }
      if (!actionInFlight && autoRefreshEnabled && lastLoadedAt && Date.now() - lastLoadedAt >= staleRefreshMs) {
        setFeedback('Pestaña recuperada: refrescando estado Docker…', `Última actualización ${fmtClock(lastLoadedAt)}`);
        void load();
      }
    });

    window.addEventListener('focus', () => {
      if (document.hidden) return;
      if (actionInFlight || !autoRefreshEnabled) return;
      if (!lastLoadedAt || Date.now() - lastLoadedAt < staleRefreshMs) return;
      setFeedback('Ventana activa: refrescando estado Docker…', `Última actualización ${fmtClock(lastLoadedAt)}`);
      void load();
    });

    restoreViewState();
    updateViewHelpers();
    showTab(tab);
    load();
    setInterval(() => {
      updateFreshnessState();
      if (document.hidden || actionInFlight || !autoRefreshEnabled) return;
      load();
    }, 15000);
    setInterval(updateFreshnessState, 1000);
  </script>
</Layout>
