    function syncAutoRefreshUi() {
      const btn = $('dk-autorefresh') as HTMLButtonElement;
      btn.textContent = `Auto: ${autoRefreshEnabled ? 'ON' : 'OFF'}`;
      btn.setAttribute('aria-pressed', autoRefreshEnabled ? 'true' : 'false');
      btn.classList.toggle('active', autoRefreshEnabled);
      btn.title = autoRefreshEnabled
        ? 'La vista se actualiza sola cada 15 segundos'
        : 'La vista no se actualizará sola hasta reactivarlo';
    }

    function syncSearchUi() {
      const hasQuery = Boolean(($('dk-search') as HTMLInputElement).value.trim());
      $('dk-search-clear').hidden = !hasQuery;
    }

    function syncSortUi() {
      const select = $('dk-sort') as HTMLSelectElement;
      if (select.value !== sortBy) {
        select.value = sortBy;
      }
      const hiddenForTab =
        (tab === 'ctnr' && (sortBy === 'created' || sortBy === 'size')) ||
        (tab === 'img' && (sortBy === 'status' || sortBy === 'cpu' || sortBy === 'mem' || sortBy === 'ports')) ||
        (tab === 'vol' && sortBy !== 'name' && sortBy !== 'created');
      select.title = hiddenForTab
        ? 'La ordenación actual no aplica a esta pestaña; usando un criterio compatible.'
        : 'Ordenar elementos visibles';
