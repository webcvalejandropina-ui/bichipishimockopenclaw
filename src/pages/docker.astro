---
import Layout from '../layouts/Layout.astro';
import { iconToSvg } from '../lib/lucide-svg-string';
import { Container, RefreshCw, Play, Square, RotateCw, Trash2, Copy, Terminal } from 'lucide';

const iRefresh = iconToSvg(RefreshCw, { width: 16, height: 16 });
const iTerminal = iconToSvg(Terminal, { width: 16, height: 16 });
const iPageTitle = iconToSvg(Container, { width: 22, height: 22 });
---
<Layout activePage="docker">
  <div class="wrapper dk-page page-docker">
    <span class="page-header__watermark" set:html={iPageTitle} aria-hidden="true" />
    <div class="page-header">
      <div class="dk-page-title-row">
        <div>
          <h2 class="page-title">Docker</h2>
          <p class="page-desc">
            Contenedores, imágenes y volúmenes del daemon Docker del host donde corre la API. Las acciones y el listado dependen de permisos y del socket Docker expuesto a la API.
          </p>
        </div>
      </div>
    </div>

    <div class="logs-tabs" role="tablist" aria-label="Vista Docker">
      <button type="button" class="logs-tab active" data-dk="ctnr" role="tab" aria-selected="true">
        <span>Contenedores</span>
        <span class="dk-tab-count" id="dk-tab-count-ctnr" aria-label="Total de contenedores">—</span>
      </button>
      <button type="button" class="logs-tab" data-dk="img" role="tab" aria-selected="false">
        <span>Imágenes</span>
        <span class="dk-tab-count" id="dk-tab-count-img" aria-label="Total de imágenes">—</span>
      </button>
      <button type="button" class="logs-tab" data-dk="vol" role="tab" aria-selected="false">
        <span>Volúmenes</span>
        <span class="dk-tab-count" id="dk-tab-count-vol" aria-label="Total de volúmenes">—</span>
      </button>
    </div>

    <div class="page-toolbar dk-toolbar">
      <div class="dk-search-wrap">
        <input type="text" class="page-search" id="dk-search" placeholder="Buscar…" title="Soporta varios términos: p. ej. api up, port:8080, cpu>50 o mem>50" />
        <button type="button" class="dk-search-clear" id="dk-search-clear" aria-label="Limpiar búsqueda" title="Limpiar búsqueda" hidden>Limpiar</button>
      </div>
      <div class="dk-ctnr-filters" id="dk-ctnr-filters">
        <button type="button" class="page-filter-btn active" data-filter="all">Todos <span class="dk-filter-count" data-filter-count="all">—</span></button>
        <button type="button" class="page-filter-btn" data-filter="up">En marcha <span class="dk-filter-count" data-filter-count="up">—</span></button>
        <button type="button" class="page-filter-btn" data-filter="down">Detenidos <span class="dk-filter-count" data-filter-count="down">—</span></button>
        <button type="button" class="page-filter-btn" data-filter="ports">Con puertos <span class="dk-filter-count" data-filter-count="ports">—</span></button>
        <button type="button" class="page-filter-btn" data-filter="issues">Con incidencias <span class="dk-filter-count" data-filter-count="issues">—</span></button>
        <button type="button" class="page-filter-btn" data-filter="hot">Calientes <span class="dk-filter-count" data-filter-count="hot">—</span></button>
      </div>
      <label class="dk-sort-wrap" for="dk-sort">
        <span class="dk-sort-label">Orden</span>
        <select id="dk-sort" class="dk-sort-select" aria-label="Ordenar vista Docker">
          <option value="status">Estado</option>
          <option value="cpu">CPU ↓</option>
          <option value="mem">RAM ↓</option>
          <option value="name">Nombre A-Z</option>
          <option value="ports">Puertos</option>
          <option value="created">Fecha ↓</option>
          <option value="size">Tamaño ↓</option>
        </select>
      </label>
      <button type="button" class="page-filter-btn" id="dk-reset-view" hidden>Limpiar vista</button>
      <button type="button" class="page-filter-btn" id="dk-autorefresh" aria-pressed="true">Auto: ON</button>
      <button
        type="button"
        class="page-icon-btn"
        id="dk-refresh"
        aria-label="Actualizar vista Docker"
        title="Actualizar contenedores, imágenes o volúmenes"
      >
        <span set:html={iRefresh} aria-hidden="true" />
      </button>
      <span class="dk-autorefresh-dot" id="dk-autorefresh-dot" aria-hidden="true" hidden></span>
    </div>

    <div class="dk-meta-stack">
      <div class="dk-presets" id="dk-presets" role="toolbar" aria-label="Filtros rápidos de Docker">
        <button type="button" class="dk-preset" data-dk-preset-slot="0">Ver incidencias</button>
        <button type="button" class="dk-preset" data-dk-preset-slot="1">Ver detenidos</button>
        <button type="button" class="dk-preset" data-dk-preset-slot="2">Puerto 8080</button>
        <button type="button" class="dk-preset" data-dk-preset-slot="3">CPU alta</button>
        <button type="button" class="dk-preset" data-dk-preset-slot="4">RAM alta</button>
      </div>
      <div class="dk-shortcuts" role="toolbar" aria-label="Atajos de teclado de Docker">
        <button
          type="button"
          class="dk-shortcut"
          data-dk-shortcut="search"
          title="Enfocar búsqueda (tecla /)"
        >
          <kbd>/</kbd><span class="dk-shortcut__text">buscar</span>
        </button>
        <button
          type="button"
          class="dk-shortcut"
          data-dk-shortcut="refresh"
          title="Refrescar vista Docker (tecla R)"
        >
          <kbd>R</kbd><span class="dk-shortcut__text">refrescar</span>
        </button>
        <button
          type="button"
          class="dk-shortcut"
          data-dk-shortcut="tabs"
          title="Cambiar entre Contenedores, Imágenes y Volúmenes (teclas 1, 2 y 3)"
        >
          <kbd>1</kbd><kbd>2</kbd><kbd>3</kbd><span class="dk-shortcut__text">cambiar pestaña</span>
        </button>
        <button
          type="button"
          class="dk-shortcut"
          data-dk-shortcut="autorefresh"
          title="Pausar o reactivar el auto-refresh (tecla A)"
        >
          <kbd>A</kbd><span class="dk-shortcut__text">auto-refresh</span>
        </button>
        <button
          type="button"
          class="dk-shortcut"
          data-dk-shortcut="reset"
          title="Restablecer la vista y filtros (tecla 0)"
        >
          <kbd>0</kbd><span class="dk-shortcut__text">reset vista</span>
        </button>
        <button
          type="button"
          class="dk-shortcut"
          data-dk-shortcut="clear"
          title="Limpiar búsqueda o quitar foco (Escape)"
        >
          <kbd>Esc</kbd><span class="dk-shortcut__text">limpiar / salir</span>
        </button>
      </div>
      <section class="dk-context" aria-label="Resumen de la vista actual">
        <p class="dk-results" id="dk-results">Cargando vista…</p>
        <div class="dk-active-view" id="dk-active-view" aria-live="polite" hidden></div>
        <div class="dk-summary" id="dk-summary" aria-live="polite" hidden></div>
      </section>
      <div class="dk-quick-actions" role="toolbar" aria-label="Comandos rápidos de Docker">
        <button type="button" class="page-filter-btn" id="dk-copy-list" title="Copiar comando CLI de la vista actual">Copiar listado CLI</button>
        <button type="button" class="page-filter-btn" id="dk-copy-diagnose" title="Copiar comando de diagnóstico de Docker">Copiar diagnóstico</button>
        <button type="button" class="page-filter-btn" id="dk-copy-recover" title="Copiar comando para rearmar API Bun y proxy 8080">Copiar rearme local</button>
        <button type="button" class="page-filter-btn" id="dk-copy-view-link" title="Copiar enlace con la vista actual de Docker">Copiar enlace vista</button>
      </div>
    </div>

    <div class="page-stat-strip" id="dk-stats-ctnr">
      <div class="page-stat"><span class="page-stat-value skeleton" id="ds-total">—</span><span class="page-stat-label">Contenedores</span></div>
      <div class="page-stat"><span class="page-stat-value skeleton" id="ds-up">—</span><span class="page-stat-label">En marcha</span></div>
      <div class="page-stat"><span class="page-stat-value skeleton" id="ds-down">—</span><span class="page-stat-label">Detenidos</span></div>
    </div>

    <div class="page-stat-strip dk-stats-panel" id="dk-stats-img" hidden>
      <div class="page-stat"><span class="page-stat-value skeleton" id="is-total">—</span><span class="page-stat-label">Imágenes</span></div>
      <div class="page-stat"><span class="page-stat-value skeleton" id="is-inuse">—</span><span class="page-stat-label">En uso</span></div>
      <div class="page-stat"><span class="page-stat-value skeleton" id="is-size">—</span><span class="page-stat-label">Tamaño en disco</span></div>
      <div class="page-stat"><span class="page-stat-value skeleton" id="is-dangling">—</span><span class="page-stat-label">Sin etiqueta</span></div>
    </div>

    <div class="page-stat-strip dk-stats-panel" id="dk-stats-vol" hidden>
      <div class="page-stat"><span class="page-stat-value skeleton" id="vs-total">—</span><span class="page-stat-label">Volúmenes</span></div>
      <div class="page-stat"><span class="page-stat-value skeleton" id="vs-inuse">—</span><span class="page-stat-label">En uso</span></div>
      <div class="page-stat"><span class="page-stat-value skeleton" id="vs-drivers">—</span><span class="page-stat-label">Drivers</span></div>
    </div>

    <div class="dk-feedback" id="dk-feedback" aria-live="polite">
      <span class="dk-feedback__status" id="dk-feedback-text">Cargando estado Docker…</span>
      <span class="dk-feedback__meta" id="dk-feedback-meta"></span>
    </div>

    <div class="logs-panel active" id="dk-panel-ctnr" role="tabpanel">
      <div class="card-grid card-grid--svc" id="ctnr-grid" aria-busy="true">
        <span class="sr-only">Cargando contenedores</span>
        {[1, 2, 3, 4].map(() => (
          <div class="info-card info-card--skel" aria-hidden="true">
            <div class="info-card-header">
              <span class="skeleton info-card-skel-icon">&nbsp;</span>
              <div class="info-card-skel-lines">
                <span class="skeleton info-card-skel-line">&nbsp;</span>
                <span class="skeleton info-card-skel-line info-card-skel-line--sm">&nbsp;</span>
              </div>
            </div>
            <span class="skeleton info-card-skel-body">&nbsp;</span>
            <div class="info-card-skel-pills">
              <span class="skeleton info-card-skel-pill">&nbsp;</span>
              <span class="skeleton info-card-skel-pill">&nbsp;</span>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="logs-panel" id="dk-panel-img" role="tabpanel">
      <div class="card-grid card-grid--svc" id="img-grid" aria-busy="true">
        <span class="sr-only">Cargando imágenes</span>
        {[1, 2, 3].map(() => (
          <div class="info-card info-card--skel" aria-hidden="true">
            <div class="info-card-header">
              <span class="skeleton info-card-skel-icon">&nbsp;</span>
              <div class="info-card-skel-lines">
                <span class="skeleton info-card-skel-line">&nbsp;</span>
                <span class="skeleton info-card-skel-line info-card-skel-line--sm">&nbsp;</span>
              </div>
            </div>
            <span class="skeleton info-card-skel-body">&nbsp;</span>
          </div>
        ))}
      </div>
    </div>

    <div class="logs-panel" id="dk-panel-vol" role="tabpanel">
      <div class="card-grid card-grid--svc" id="vol-grid" aria-busy="true">
        <span class="sr-only">Cargando volúmenes</span>
        {[1, 2, 3].map(() => (
          <div class="info-card info-card--skel" aria-hidden="true">
            <div class="info-card-header">
              <span class="skeleton info-card-skel-icon">&nbsp;</span>
              <div class="info-card-skel-lines">
                <span class="skeleton info-card-skel-line">&nbsp;</span>
                <span class="skeleton info-card-skel-line info-card-skel-line--sm">&nbsp;</span>
              </div>
            </div>
            <span class="skeleton info-card-skel-body">&nbsp;</span>
          </div>
        ))}
      </div>
    </div>

    <div
      class="dk-modal"
      id="dk-modal"
      role="dialog"
      aria-modal="true"
      aria-labelledby="dk-modal-title"
      aria-hidden="true"
      hidden
    >
      <div class="dk-modal__backdrop" data-dk-modal-dismiss tabindex="-1" aria-hidden="true"></div>
      <div class="dk-modal__panel">
        <h3 class="dk-modal__title" id="dk-modal-title"></h3>
        <p class="dk-modal__body" id="dk-modal-body"></p>
        <pre class="dk-modal__detail" id="dk-modal-detail" hidden></pre>
        <div class="dk-modal__actions">
          <button type="button" class="dk-modal__btn dk-modal__btn--ghost" id="dk-modal-cancel">Cancelar</button>
          <button type="button" class="dk-modal__btn dk-modal__btn--primary" id="dk-modal-confirm">Confirmar</button>
        </div>
      </div>
    </div>
  </div>

  <style>
    .dk-toolbar .dk-ctnr-filters {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 8px;
    }
    .dk-sort-wrap {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      min-height: 32px;
      padding: 0 10px;
      border: 1px solid var(--border);
      border-radius: 999px;
      background: var(--bg-card);
      color: var(--text-soft);
      font-size: 11px;
      font-weight: 600;
      font-family: var(--font-display);
    }
    .dk-filter-count {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 22px;
      padding: 0 6px;
      height: 20px;
      margin-left: 6px;
      border-radius: 999px;
      background: color-mix(in srgb, var(--text) 8%, transparent);
      color: var(--text-soft);
      font-size: 11px;
      font-weight: 800;
      font-variant-numeric: tabular-nums;
      line-height: 1;
    }
    .dk-tab-count {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 24px;
      height: 20px;
      padding: 0 7px;
      margin-left: 8px;
      border-radius: 999px;
      background: color-mix(in srgb, var(--text) 9%, transparent);
      color: inherit;
      font-size: 11px;
      font-weight: 800;
      font-variant-numeric: tabular-nums;
      line-height: 1;
      opacity: 0.92;
    }
    .logs-tab.active .dk-tab-count {
      background: color-mix(in srgb, currentColor 14%, transparent);
    }
    .dk-sort-label {
      color: var(--muted);
      white-space: nowrap;
    }
    .dk-sort-select {
      border: 0;
      background: transparent;
      color: var(--text);
      font: inherit;
      font-weight: 600;
      min-width: 96px;
      outline: none;
      cursor: pointer;
    }
    .dk-search-wrap {
      position: relative;
      flex: 1 1 260px;
      min-width: min(100%, 240px);
      display: flex;
      align-items: center;
    }
    .dk-search-wrap .page-search {
      width: 100%;
      min-width: 0;
      padding-right: 82px;
    }
    .dk-search-clear {
      position: absolute;
      right: 8px;
      top: 50%;
      transform: translateY(-50%);
      border: 1px solid var(--border);
      background: var(--bg-card);
      color: var(--muted);
      border-radius: 999px;
      padding: 4px 10px;
      font-size: 11px;
      font-weight: 800;
      font-family: var(--font-display);
      cursor: pointer;
      transition: background 0.15s, color 0.15s, border-color 0.15s;
    }
    .dk-search-clear:hover {
      background: var(--bg-hover);
      color: var(--text);
    }
    .dk-meta-stack {
      display: flex;
      flex-direction: column;
      gap: 12px;
      margin: 4px 0 14px;
    }
    .dk-presets,
    .dk-shortcuts {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      align-items: center;
    }
    .dk-preset {
      min-height: 30px;
      padding: 0 10px;
      border-radius: 999px;
      border: 1px solid var(--border);
      background: color-mix(in srgb, var(--accent) 8%, var(--bg-card));
      color: var(--text-soft);
      font: inherit;
      font-size: 11px;
      font-weight: 600;
      font-family: var(--font-display);
      letter-spacing: 0.02em;
      cursor: pointer;
      transition:
        background 0.15s ease,
        border-color 0.15s ease,
        color 0.15s ease,
        transform 0.12s ease;
    }
    .dk-preset:hover {
      background: color-mix(in srgb, var(--accent) 16%, var(--bg-card));
      border-color: color-mix(in srgb, var(--accent) 34%, var(--border));
      color: var(--text);
    }
    .dk-preset:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }
    .dk-preset:active {
      transform: scale(0.98);
    }
    .dk-shortcut {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 5px 10px;
      margin: 0;
      border-radius: 999px;
      border: 1px solid var(--border);
      background: var(--bg-card);
      color: var(--text-soft);
      font-size: 11px;
      font-weight: 600;
      font-family: var(--font-display);
      letter-spacing: 0.02em;
      box-shadow: var(--shadow-card);
      cursor: pointer;
      transition:
        background 0.15s ease,
        border-color 0.15s ease,
        color 0.15s ease,
        transform 0.12s ease;
    }
    .dk-shortcut:hover {
      background: var(--bg-card-hover, var(--bg-subtle));
      border-color: color-mix(in srgb, var(--accent) 28%, var(--border));
      color: var(--text);
    }
    .dk-shortcut:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }
    .dk-shortcut:active {
      transform: scale(0.98);
    }
    .dk-shortcut__text {
      color: var(--muted);
      font-weight: 600;
    }
    .dk-shortcut:hover .dk-shortcut__text {
      color: var(--text-soft);
    }
    .dk-shortcut kbd {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 24px;
      height: 24px;
      padding: 0 7px;
      border-radius: 8px;
      border: 1px solid var(--border);
      background: var(--bg-secondary);
      color: var(--text);
      font: inherit;
      font-size: 11px;
      font-weight: 800;
      font-variant-numeric: tabular-nums;
      box-shadow: inset 0 -1px 0 color-mix(in srgb, var(--text) 10%, transparent);
    }
    .dk-quick-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      align-items: center;
      justify-content: flex-end;
    }
    .dk-quick-actions .page-filter-btn {
      min-height: 32px;
    }
    .dk-context {
      padding: 14px 16px;
      border-radius: 14px;
      border: 1px solid var(--border);
      background: var(--bg-card);
      box-shadow: var(--shadow-card);
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .dk-active-view {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      align-items: center;
    }
    .dk-active-pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      max-width: 100%;
      min-height: 28px;
      padding: 0 6px 0 10px;
      border-radius: 999px;
      border: 1px solid color-mix(in srgb, var(--accent) 24%, var(--border));
      background: color-mix(in srgb, var(--accent) 10%, var(--bg-card));
      color: var(--text-soft);
      font-size: 11px;
      font-weight: 600;
      font-family: var(--font-display);
      letter-spacing: 0.01em;
    }
    .dk-active-pill__label {
      color: var(--muted);
      font-weight: 600;
    }
    .dk-active-pill__value {
      min-width: 0;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .dk-active-pill__close {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 22px;
      height: 22px;
      border: 0;
      border-radius: 999px;
      background: color-mix(in srgb, var(--text) 10%, transparent);
      color: var(--text);
      font: inherit;
      font-size: 14px;
      font-weight: 800;
      line-height: 1;
      cursor: pointer;
      transition: background 0.15s ease, transform 0.12s ease;
    }
    .dk-active-pill__close:hover {
      background: color-mix(in srgb, var(--text) 16%, transparent);
    }
    .dk-active-pill__close:active {
      transform: scale(0.96);
    }
    .dk-page .logs-panel:not(.active) {
      display: none;
    }
    .dk-page .logs-panel.active {
      display: block;
    }
    .dk-feedback {
      display: flex;
      flex-wrap: wrap;
      align-items: flex-start;
      justify-content: space-between;
      gap: 8px 14px;
      margin: 0 0 16px;
      padding: 14px 16px;
      border: 1px solid var(--border);
      border-radius: 14px;
      background: var(--bg-card);
      box-shadow: var(--shadow-card);
      color: var(--muted);
      font-size: 13px;
      transition: border-color 0.2s ease, background 0.2s ease, color 0.2s ease;
    }
    /* Sin flex-grow: si no, en columna (móvil) los hijos estiran altura y queda un bloque vacío enorme */
    .dk-feedback__status {
      color: var(--text);
      font-weight: 700;
      font-family: var(--font-display);
      line-height: 1.4;
      flex: 0 1 auto;
      min-width: 0;
      max-width: 100%;
    }
    .dk-feedback__meta {
      font-variant-numeric: tabular-nums;
      font-size: 12px;
      font-weight: 600;
      line-height: 1.45;
      text-align: right;
      flex: 0 1 auto;
      min-width: 0;
      max-width: min(100%, 380px);
      color: var(--muted);
    }
    @media (max-width: 640px) {
      .dk-feedback {
        flex-direction: column;
        align-items: stretch;
        align-content: flex-start;
        gap: 6px;
        padding: 10px 12px;
        margin-bottom: 12px;
      }
      .dk-feedback__status {
        flex: 0 0 auto;
        width: 100%;
        font-size: 13px;
        line-height: 1.35;
      }
      .dk-feedback__meta {
        flex: 0 0 auto;
        width: 100%;
        max-width: none;
        text-align: left;
        font-size: 11px;
        line-height: 1.4;
        margin-top: 2px;
        padding-top: 8px;
        border-top: 1px solid color-mix(in srgb, var(--border) 85%, transparent);
      }
    }
    .dk-feedback[data-freshness='stale'] {
      border-color: color-mix(in srgb, var(--warn) 45%, var(--border));
      background: color-mix(in srgb, var(--warn) 10%, var(--bg-card));
    }
