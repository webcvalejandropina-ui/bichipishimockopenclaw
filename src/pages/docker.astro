---
import Layout from '../layouts/Layout.astro';
import { iconToSvg } from '../lib/lucide-svg-string';
import { Package, RefreshCw, Play, Square, RotateCw, Trash2, Copy } from 'lucide';

const iRefresh = iconToSvg(RefreshCw, { width: 16, height: 16 });
---
<Layout activePage="docker">
  <div class="wrapper dk-page">
    <div class="page-header">
      <h2 class="page-title">Docker</h2>
      <p class="page-desc">Contenedores, imágenes y volúmenes del daemon Docker del host donde corre la API.</p>
    </div>

    <div class="logs-tabs" role="tablist" aria-label="Vista Docker">
      <button type="button" class="logs-tab active" data-dk="ctnr" role="tab" aria-selected="true">Contenedores</button>
      <button type="button" class="logs-tab" data-dk="img" role="tab" aria-selected="false">Imágenes</button>
      <button type="button" class="logs-tab" data-dk="vol" role="tab" aria-selected="false">Volúmenes</button>
    </div>

    <div class="page-toolbar dk-toolbar">
      <div class="dk-search-wrap">
        <input type="text" class="page-search" id="dk-search" placeholder="Buscar…" />
        <button type="button" class="dk-search-clear" id="dk-search-clear" aria-label="Limpiar búsqueda" title="Limpiar búsqueda" hidden>Limpiar</button>
      </div>
      <div class="dk-ctnr-filters" id="dk-ctnr-filters">
        <button type="button" class="page-filter-btn active" data-filter="all">Todos <span class="dk-filter-count" data-filter-count="all">—</span></button>
        <button type="button" class="page-filter-btn" data-filter="up">En marcha <span class="dk-filter-count" data-filter-count="up">—</span></button>
        <button type="button" class="page-filter-btn" data-filter="down">Detenidos <span class="dk-filter-count" data-filter-count="down">—</span></button>
        <button type="button" class="page-filter-btn" data-filter="ports">Con puertos <span class="dk-filter-count" data-filter-count="ports">—</span></button>
        <button type="button" class="page-filter-btn" data-filter="issues">Con incidencias <span class="dk-filter-count" data-filter-count="issues">—</span></button>
        <button type="button" class="page-filter-btn" data-filter="hot">Calientes <span class="dk-filter-count" data-filter-count="hot">—</span></button>
      </div>
      <label class="dk-sort-wrap" for="dk-sort">
        <span class="dk-sort-label">Orden</span>
        <select id="dk-sort" class="dk-sort-select" aria-label="Ordenar vista Docker">
          <option value="status">Estado</option>
          <option value="cpu">CPU ↓</option>
          <option value="mem">RAM ↓</option>
          <option value="name">Nombre A-Z</option>
          <option value="ports">Puertos</option>
          <option value="created">Fecha ↓</option>
          <option value="size">Tamaño ↓</option>
        </select>
      </label>
      <button type="button" class="page-filter-btn" id="dk-reset-view" hidden>Limpiar vista</button>
      <button type="button" class="page-filter-btn" id="dk-autorefresh" aria-pressed="true">Auto: ON</button>
      <button
        type="button"
        class="page-icon-btn"
        id="dk-refresh"
        aria-label="Actualizar vista Docker"
        title="Actualizar contenedores, imágenes o volúmenes"
      >
        <span set:html={iRefresh} aria-hidden="true" />
      </button>
    </div>

    <div class="dk-meta-stack">
      <div class="dk-shortcuts" role="toolbar" aria-label="Atajos de teclado de Docker">
        <button
          type="button"
          class="dk-shortcut"
          data-dk-shortcut="search"
          title="Enfocar búsqueda (tecla /)"
        >
          <kbd>/</kbd><span class="dk-shortcut__text">buscar</span>
        </button>
        <button
          type="button"
          class="dk-shortcut"
          data-dk-shortcut="refresh"
          title="Refrescar vista Docker (tecla R)"
        >
          <kbd>R</kbd><span class="dk-shortcut__text">refrescar</span>
        </button>
        <button
          type="button"
          class="dk-shortcut"
          data-dk-shortcut="clear"
          title="Limpiar búsqueda o quitar foco (Escape)"
        >
          <kbd>Esc</kbd><span class="dk-shortcut__text">limpiar / salir</span>
        </button>
      </div>
      <section class="dk-context" aria-label="Resumen de la vista actual">
        <p class="dk-results" id="dk-results">Cargando vista…</p>
        <div class="dk-summary" id="dk-summary" aria-live="polite" hidden></div>
      </section>
    </div>

    <div class="page-stat-strip" id="dk-stats-ctnr">
      <div class="page-stat"><span class="page-stat-value skeleton" id="ds-total">—</span><span class="page-stat-label">Contenedores</span></div>
      <div class="page-stat"><span class="page-stat-value skeleton" id="ds-up">—</span><span class="page-stat-label">En marcha</span></div>
      <div class="page-stat"><span class="page-stat-value skeleton" id="ds-down">—</span><span class="page-stat-label">Detenidos</span></div>
    </div>

    <div class="page-stat-strip dk-stats-panel" id="dk-stats-img" hidden>
      <div class="page-stat"><span class="page-stat-value skeleton" id="is-total">—</span><span class="page-stat-label">Imágenes</span></div>
      <div class="page-stat"><span class="page-stat-value skeleton" id="is-inuse">—</span><span class="page-stat-label">En uso</span></div>
      <div class="page-stat"><span class="page-stat-value skeleton" id="is-size">—</span><span class="page-stat-label">Tamaño en disco</span></div>
      <div class="page-stat"><span class="page-stat-value skeleton" id="is-dangling">—</span><span class="page-stat-label">Sin etiqueta</span></div>
    </div>

    <div class="page-stat-strip dk-stats-panel" id="dk-stats-vol" hidden>
      <div class="page-stat"><span class="page-stat-value skeleton" id="vs-total">—</span><span class="page-stat-label">Volúmenes</span></div>
      <div class="page-stat"><span class="page-stat-value skeleton" id="vs-inuse">—</span><span class="page-stat-label">En uso</span></div>
      <div class="page-stat"><span class="page-stat-value skeleton" id="vs-drivers">—</span><span class="page-stat-label">Drivers</span></div>
    </div>

    <div class="dk-feedback" id="dk-feedback" aria-live="polite">
      <span class="dk-feedback__status" id="dk-feedback-text">Cargando estado Docker…</span>
      <span class="dk-feedback__meta" id="dk-feedback-meta"></span>
    </div>

    <div class="logs-panel active" id="dk-panel-ctnr" role="tabpanel">
      <div class="card-grid" id="ctnr-grid" aria-busy="true">
        <span class="sr-only">Cargando contenedores</span>
        {[1, 2, 3, 4].map(() => (
          <div class="info-card info-card--skel" aria-hidden="true">
            <div class="info-card-header">
              <span class="skeleton info-card-skel-icon">&nbsp;</span>
              <div class="info-card-skel-lines">
                <span class="skeleton info-card-skel-line">&nbsp;</span>
                <span class="skeleton info-card-skel-line info-card-skel-line--sm">&nbsp;</span>
              </div>
            </div>
            <span class="skeleton info-card-skel-body">&nbsp;</span>
            <div class="info-card-skel-pills">
              <span class="skeleton info-card-skel-pill">&nbsp;</span>
              <span class="skeleton info-card-skel-pill">&nbsp;</span>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="logs-panel" id="dk-panel-img" role="tabpanel">
      <div class="card-grid" id="img-grid" aria-busy="true">
        <span class="sr-only">Cargando imágenes</span>
        {[1, 2, 3].map(() => (
          <div class="info-card info-card--skel" aria-hidden="true">
            <div class="info-card-header">
              <span class="skeleton info-card-skel-icon">&nbsp;</span>
              <div class="info-card-skel-lines">
                <span class="skeleton info-card-skel-line">&nbsp;</span>
                <span class="skeleton info-card-skel-line info-card-skel-line--sm">&nbsp;</span>
              </div>
            </div>
            <span class="skeleton info-card-skel-body">&nbsp;</span>
          </div>
        ))}
      </div>
    </div>

    <div class="logs-panel" id="dk-panel-vol" role="tabpanel">
      <div class="card-grid" id="vol-grid" aria-busy="true">
        <span class="sr-only">Cargando volúmenes</span>
        {[1, 2, 3].map(() => (
          <div class="info-card info-card--skel" aria-hidden="true">
            <div class="info-card-header">
              <span class="skeleton info-card-skel-icon">&nbsp;</span>
              <div class="info-card-skel-lines">
                <span class="skeleton info-card-skel-line">&nbsp;</span>
                <span class="skeleton info-card-skel-line info-card-skel-line--sm">&nbsp;</span>
              </div>
            </div>
            <span class="skeleton info-card-skel-body">&nbsp;</span>
          </div>
        ))}
      </div>
    </div>

    <div
      class="dk-modal"
      id="dk-modal"
      role="dialog"
      aria-modal="true"
      aria-labelledby="dk-modal-title"
      aria-hidden="true"
      hidden
    >
      <div class="dk-modal__backdrop" data-dk-modal-dismiss tabindex="-1" aria-hidden="true"></div>
      <div class="dk-modal__panel">
        <h3 class="dk-modal__title" id="dk-modal-title"></h3>
        <p class="dk-modal__body" id="dk-modal-body"></p>
        <pre class="dk-modal__detail" id="dk-modal-detail" hidden></pre>
        <div class="dk-modal__actions">
          <button type="button" class="dk-modal__btn dk-modal__btn--ghost" id="dk-modal-cancel">Cancelar</button>
          <button type="button" class="dk-modal__btn dk-modal__btn--primary" id="dk-modal-confirm">Confirmar</button>
        </div>
      </div>
    </div>
  </div>

  <style>
    .dk-toolbar .dk-ctnr-filters {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 8px;
    }
    .dk-sort-wrap {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      min-height: 38px;
      padding: 0 12px;
      border: 1px solid var(--border);
      border-radius: 999px;
      background: var(--bg-card);
      color: var(--text-soft);
      font-size: 12px;
      font-weight: 700;
      font-family: var(--font-display);
    }
    .dk-filter-count {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 22px;
      padding: 0 6px;
      height: 20px;
      margin-left: 6px;
      border-radius: 999px;
      background: color-mix(in srgb, var(--text) 8%, transparent);
      color: var(--text-soft);
      font-size: 11px;
      font-weight: 800;
      font-variant-numeric: tabular-nums;
      line-height: 1;
    }
    .dk-sort-label {
      color: var(--muted);
      white-space: nowrap;
    }
    .dk-sort-select {
      border: 0;
      background: transparent;
      color: var(--text);
      font: inherit;
      font-weight: 800;
      min-width: 96px;
      outline: none;
      cursor: pointer;
    }
    .dk-search-wrap {
      position: relative;
      flex: 1 1 260px;
      min-width: min(100%, 240px);
      display: flex;
      align-items: center;
    }
    .dk-search-wrap .page-search {
      width: 100%;
      min-width: 0;
      padding-right: 82px;
    }
    .dk-search-clear {
      position: absolute;
      right: 8px;
      top: 50%;
      transform: translateY(-50%);
      border: 1px solid var(--border);
      background: var(--bg-card);
      color: var(--muted);
      border-radius: 999px;
      padding: 4px 10px;
      font-size: 11px;
      font-weight: 800;
      font-family: var(--font-display);
      cursor: pointer;
      transition: background 0.15s, color 0.15s, border-color 0.15s;
    }
    .dk-search-clear:hover {
      background: var(--bg-hover);
      color: var(--text);
    }
    .dk-meta-stack {
      display: flex;
      flex-direction: column;
      gap: 12px;
      margin: 4px 0 14px;
    }
    .dk-shortcuts {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      align-items: center;
    }
    .dk-shortcut {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 6px 12px;
      margin: 0;
      border-radius: 999px;
      border: 1px solid var(--border);
      background: var(--bg-card);
      color: var(--text-soft);
      font-size: 12px;
      font-weight: 700;
      font-family: var(--font-display);
      letter-spacing: 0.02em;
      box-shadow: var(--shadow-card);
      cursor: pointer;
      transition:
        background 0.15s ease,
        border-color 0.15s ease,
        color 0.15s ease,
        transform 0.12s ease;
    }
    .dk-shortcut:hover {
      background: var(--bg-card-hover, var(--bg-subtle));
      border-color: color-mix(in srgb, var(--accent) 28%, var(--border));
      color: var(--text);
    }
    .dk-shortcut:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }
    .dk-shortcut:active {
      transform: scale(0.98);
    }
    .dk-shortcut__text {
      color: var(--muted);
      font-weight: 600;
    }
    .dk-shortcut:hover .dk-shortcut__text {
      color: var(--text-soft);
    }
    .dk-shortcut kbd {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 24px;
      height: 24px;
      padding: 0 7px;
      border-radius: 8px;
      border: 1px solid var(--border);
      background: var(--bg-secondary);
      color: var(--text);
      font: inherit;
      font-size: 11px;
      font-weight: 800;
      font-variant-numeric: tabular-nums;
      box-shadow: inset 0 -1px 0 color-mix(in srgb, var(--text) 10%, transparent);
    }
    .dk-context {
      padding: 14px 16px;
      border-radius: 14px;
      border: 1px solid var(--border);
      background: var(--bg-card);
      box-shadow: var(--shadow-card);
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .dk-page .logs-panel:not(.active) {
      display: none;
    }
    .dk-page .logs-panel.active {
      display: block;
    }
    .dk-feedback {
      display: flex;
      flex-wrap: wrap;
      align-items: flex-start;
      justify-content: space-between;
      gap: 8px 14px;
      margin: 0 0 16px;
      padding: 14px 16px;
      border: 1px solid var(--border);
      border-radius: 14px;
      background: var(--bg-card);
      box-shadow: var(--shadow-card);
      color: var(--muted);
      font-size: 13px;
      transition: border-color 0.2s ease, background 0.2s ease, color 0.2s ease;
    }
    /* Sin flex-grow: si no, en columna (móvil) los hijos estiran altura y queda un bloque vacío enorme */
    .dk-feedback__status {
      color: var(--text);
      font-weight: 700;
      font-family: var(--font-display);
      line-height: 1.4;
      flex: 0 1 auto;
      min-width: 0;
      max-width: 100%;
    }
    .dk-feedback__meta {
      font-variant-numeric: tabular-nums;
      font-size: 12px;
      font-weight: 600;
      line-height: 1.45;
      text-align: right;
      flex: 0 1 auto;
      min-width: 0;
      max-width: min(100%, 380px);
      color: var(--muted);
    }
    @media (max-width: 640px) {
      .dk-feedback {
        flex-direction: column;
        align-items: stretch;
        align-content: flex-start;
        gap: 6px;
        padding: 10px 12px;
        margin-bottom: 12px;
      }
      .dk-feedback__status {
        flex: 0 0 auto;
        width: 100%;
        font-size: 13px;
        line-height: 1.35;
      }
      .dk-feedback__meta {
        flex: 0 0 auto;
        width: 100%;
        max-width: none;
        text-align: left;
        font-size: 11px;
        line-height: 1.4;
        margin-top: 2px;
        padding-top: 8px;
        border-top: 1px solid color-mix(in srgb, var(--border) 85%, transparent);
      }
    }
    .dk-feedback[data-freshness='stale'] {
      border-color: color-mix(in srgb, var(--warn) 45%, var(--border));
      background: color-mix(in srgb, var(--warn) 10%, var(--bg-card));
    }
    .dk-feedback[data-freshness='stale'] .dk-feedback__status {
      color: color-mix(in srgb, var(--warn) 75%, var(--text));
    }
    .dk-feedback[data-freshness='paused'] {
      border-color: color-mix(in srgb, var(--blue) 40%, var(--border));
      background: color-mix(in srgb, var(--blue) 8%, var(--bg-card));
    }
    .info-card {
      position: relative;
    }
    .info-card[data-busy='true'] {
      opacity: 0.72;
    }
  </style>

  <script>
    import {
      apiPostDockerCtnr,
      apiPostDockerImgDelete,
      apiPostDockerVolDelete,
      fetchMetrics,
      updateHeader,
    } from '../lib/metrics';
    import { iconToSvg } from '../lib/lucide-svg-string';
    import { Package, Layers, Database, Play, Square, RotateCw, Trash2, Copy } from 'lucide';
    import { escHtml } from '../lib/process-hints';

    const iPkg = iconToSvg(Package, { width: 18, height: 18 });
    const iLayers = iconToSvg(Layers, { width: 18, height: 18 });
    const iVol = iconToSvg(Database, { width: 18, height: 18 });
    const iPlay = iconToSvg(Play, { width: 18, height: 18 });
    const iStop = iconToSvg(Square, { width: 18, height: 18 });
    const iRestart = iconToSvg(RotateCw, { width: 18, height: 18 });
    const iTrash = iconToSvg(Trash2, { width: 18, height: 18 });
    const iCopy = iconToSvg(Copy, { width: 14, height: 14 });

    const $ = (id: string) => document.getElementById(id)!;

    let dockerModalResolve: ((v: 'confirm' | 'cancel') => void) | null = null;
    let dockerModalPrevFocus: HTMLElement | null = null;
    let dockerModalKeyHandler: ((e: KeyboardEvent) => void) | null = null;

    function dockerModalDetachKeys() {
      if (dockerModalKeyHandler) {
        document.removeEventListener('keydown', dockerModalKeyHandler);
        dockerModalKeyHandler = null;
      }
    }

    function dockerModalClose(result: 'confirm' | 'cancel') {
      const root = $('dk-modal');
      root.hidden = true;
      root.setAttribute('aria-hidden', 'true');
      document.body.classList.remove('dk-modal-open');
      dockerModalDetachKeys();
      const r = dockerModalResolve;
      dockerModalResolve = null;
      try {
        dockerModalPrevFocus?.focus();
      } catch {
        /* ignore */
      }
      dockerModalPrevFocus = null;
      r?.(result);
    }

    function initDockerModal() {
      const root = $('dk-modal');
      if ((root as HTMLElement & { _dkModalInit?: boolean })._dkModalInit) return;
      (root as HTMLElement & { _dkModalInit?: boolean })._dkModalInit = true;
      $('dk-modal-confirm').addEventListener('click', () => dockerModalClose('confirm'));
      $('dk-modal-cancel').addEventListener('click', () => dockerModalClose('cancel'));
      root.querySelector('.dk-modal__backdrop')?.addEventListener('click', () => {
        const mode = root.dataset.mode;
        dockerModalClose(mode === 'alert' ? 'confirm' : 'cancel');
      });
    }

    function dockerModalOpen(opts: {
      mode: 'confirm' | 'alert';
      title: string;
      body: string;
      detail?: string;
      variant?: 'default' | 'danger';
      confirmLabel?: string;
      cancelLabel?: string;
    }): Promise<'confirm' | 'cancel'> {
      initDockerModal();
      return new Promise((resolve) => {
        dockerModalResolve = resolve;
        dockerModalPrevFocus = document.activeElement as HTMLElement;
        const root = $('dk-modal');
        root.dataset.mode = opts.mode;
        root.dataset.variant = opts.variant || 'default';
        $('dk-modal-title').textContent = opts.title;
        $('dk-modal-body').textContent = opts.body;
        const det = $('dk-modal-detail');
        if (opts.detail) {
          det.textContent = opts.detail;
          det.hidden = false;
        } else {
          det.textContent = '';
          det.hidden = true;
        }
        const cancelBtn = $('dk-modal-cancel') as HTMLButtonElement;
        const confirmBtn = $('dk-modal-confirm') as HTMLButtonElement;
        cancelBtn.hidden = opts.mode === 'alert';
        confirmBtn.textContent = opts.confirmLabel || (opts.mode === 'alert' ? 'Entendido' : 'Confirmar');
        cancelBtn.textContent = opts.cancelLabel || 'Cancelar';
        root.hidden = false;
        root.setAttribute('aria-hidden', 'false');
        document.body.classList.add('dk-modal-open');
        dockerModalKeyHandler = (ev: KeyboardEvent) => {
          if (ev.key !== 'Escape') return;
          ev.preventDefault();
          dockerModalClose(opts.mode === 'alert' ? 'confirm' : 'cancel');
        };
        document.addEventListener('keydown', dockerModalKeyHandler);
        confirmBtn.focus();
      });
    }

    async function dockerModalConfirm(opts: {
      title: string;
      body: string;
      detail?: string;
      variant?: 'default' | 'danger';
      confirmLabel?: string;
      cancelLabel?: string;
    }): Promise<boolean> {
      const r = await dockerModalOpen({ ...opts, mode: 'confirm' });
      return r === 'confirm';
    }

    async function dockerModalAlert(opts: { title: string; body: string; detail?: string }) {
      await dockerModalOpen({
        mode: 'alert',
        variant: 'default',
        title: opts.title,
        body: opts.body,
        detail: opts.detail,
        confirmLabel: 'Entendido',
      });
    }

    function dockerActionVerbEs(action: string): string {
      const m: Record<string, string> = {
        start: 'Iniciar',
        stop: 'Detener',
        restart: 'Reiniciar',
        delete: 'Eliminar',
      };
      return m[action] || action;
    }

    let allCtrs: any[] = [];
    let allImgs: any[] = [];
    let allVols: any[] = [];
    let filter = 'all';
    let tab: 'ctnr' | 'img' | 'vol' = 'ctnr';
    let dataLoaded = false;
    let actionInFlight = false;
    let lastLoadedAt = 0;
    let autoRefreshEnabled = true;
    let hiddenAutoPause = false;
    let sortBy: 'status' | 'cpu' | 'mem' | 'name' | 'ports' | 'created' | 'size' = 'status';
    const storageKey = 'bichipishi:docker:view';
    const staleRefreshMs = 30000;

    function defaultSortForTab(nextTab: 'ctnr' | 'img' | 'vol') {
      return nextTab === 'ctnr' ? 'status' : nextTab === 'img' ? 'created' : 'name';
    }

    function saveViewState() {
      try {
        localStorage.setItem(
          storageKey,
          JSON.stringify({
            filter,
            tab,
            autoRefreshEnabled,
            sortBy,
            search: ($('dk-search') as HTMLInputElement)?.value || '',
          }),
        );
      } catch {
        // ignore storage failures
      }
    }

    function restoreViewState() {
      try {
        const raw = localStorage.getItem(storageKey);
        if (!raw) return;
        const state = JSON.parse(raw);
        if (state.tab === 'ctnr' || state.tab === 'img' || state.tab === 'vol') {
          tab = state.tab;
        }
        if (['all', 'up', 'down', 'ports', 'issues', 'hot'].includes(state.filter)) {
          filter = state.filter;
        }
        if (typeof state.autoRefreshEnabled === 'boolean') {
          autoRefreshEnabled = state.autoRefreshEnabled;
        }
        if (['status', 'cpu', 'mem', 'name', 'ports', 'created', 'size'].includes(state.sortBy)) {
          sortBy = state.sortBy;
        }
        if (typeof state.search === 'string') {
          ($('dk-search') as HTMLInputElement).value = state.search;
        }
      } catch {
        // ignore malformed storage
      }
    }

    function fmtBytes(n: number) {
      if (n == null || !Number.isFinite(n) || n <= 0) return '—';
      let v = n;
      const u = ['B', 'KB', 'MB', 'GB', 'TB'];
      let i = 0;
      while (v >= 1024 && i < u.length - 1) {
        v /= 1024;
        i += 1;
      }
      return i === 0 ? `${Math.round(v)} ${u[i]}` : `${v < 10 ? v.toFixed(1) : Math.round(v)} ${u[i]}`;
    }

    function fmtTs(sec: number) {
      if (!sec) return '—';
      try {
        return new Date(sec * 1000).toLocaleString('es-ES', {
          dateStyle: 'short',
          timeStyle: 'short',
        });
      } catch {
        return '—';
      }
    }

    function fmtClock(ts: number) {
      if (!ts) return '—';
      try {
        return new Date(ts).toLocaleTimeString('es-ES', {
          hour: '2-digit',
          minute: '2-digit',
          second: '2-digit',
        });
      } catch {
        return '—';
      }
    }

    function fmtAge(ms: number) {
      if (!Number.isFinite(ms) || ms < 0) return 'ahora';
      const sec = Math.floor(ms / 1000);
      if (sec < 5) return 'ahora';
      if (sec < 60) return `hace ${sec}s`;
      const min = Math.floor(sec / 60);
      if (min < 60) return `hace ${min} min`;
      const hr = Math.floor(min / 60);
      return `hace ${hr} h`;
    }

    function updateFreshnessState() {
      const box = $('dk-feedback');
      if (!lastLoadedAt) {
        delete box.dataset.freshness;
        return;
      }
      const ageMs = Date.now() - lastLoadedAt;
      if (!autoRefreshEnabled) {
        box.dataset.freshness = 'paused';
        const pauseReason = hiddenAutoPause ? 'pausado por pestaña oculta' : 'auto-refresh desactivado';
        $('dk-feedback-meta').textContent = `Datos congelados ${fmtAge(ageMs)} · ${pauseReason} · última actualización ${fmtClock(lastLoadedAt)}`;
        return;
      }
      box.dataset.freshness = ageMs >= 45000 ? 'stale' : 'fresh';
      $('dk-feedback-meta').textContent = `Última actualización ${fmtClock(lastLoadedAt)} · ${fmtAge(ageMs)}`;
    }

    function updateViewHelpers() {
      syncSearchUi();
      syncFilterButtons();
      syncSortUi();
      syncAutoRefreshUi();
      syncResetViewUi();
    }

    function setFeedback(status: string, meta = '') {
      $('dk-feedback-text').textContent = status;
      $('dk-feedback-meta').textContent = meta;
      if (!meta) {
        delete $('dk-feedback').dataset.freshness;
      }
    }

    function setResults(html: string) {
      $('dk-results').innerHTML = html;
    }

    function setSummary(
      chips: Array<{ label: string; value: string | number; tone?: 'ok' | 'crit' | 'warn' | 'info'; filterKey?: string }>,
    ) {
      const box = $('dk-summary');
      if (!chips.length) {
        box.hidden = true;
        box.innerHTML = '';
        return;
      }
      box.hidden = false;
      box.innerHTML = chips
        .map((chip) => {
          const tone = chip.tone || 'info';
          const active = chip.filterKey && chip.filterKey === filter ? 'true' : 'false';
          if (chip.filterKey) {
            return `<button type="button" class="dk-summary-chip" data-tone="${tone}" data-summary-filter="${escHtml(chip.filterKey)}" data-active="${active}" title="Filtrar por ${escHtml(chip.label)}"><span class="dk-summary-chip__value">${escHtml(String(chip.value))}</span><span class="dk-summary-chip__label">${escHtml(chip.label)}</span></button>`;
          }
          return `<span class="dk-summary-chip" data-tone="${tone}"><span class="dk-summary-chip__value">${escHtml(String(chip.value))}</span><span class="dk-summary-chip__label">${escHtml(chip.label)}</span></span>`;
        })
        .join('');
