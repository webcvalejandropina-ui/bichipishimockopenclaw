    function resetView() {
      filter = 'all';
      sortBy = defaultSortForTab(tab);
      autoRefreshEnabled = true;
      const input = $('dk-search') as HTMLInputElement;
      input.value = '';
      syncSearchUi();
      syncFilterButtons();
      syncSortUi();
      syncAutoRefreshUi();
      syncResetViewUi();
      saveViewState();
      setFeedback('Vista Docker restablecida', lastLoadedAt ? `Última actualización ${fmtClock(lastLoadedAt)}` : 'Listo para volver a filtrar');
      updateFreshnessState();
      render();
    }

    function containerScoreStatus(item: any) {
      return String(item.status || '').toLowerCase().includes('up') ? 0 : 1;
    }

    function hasPorts(item: any) {
      const ports = String(item.ports || '').trim().toLowerCase();
      return ports && ports !== '—' && ports !== 'sin puertos expuestos' ? 0 : 1;
    }

    function sortContainers(items: any[]) {
      const sorted = [...items];
      sorted.sort((a: any, b: any) => {
        if (sortBy === 'cpu') return Number(b.cpu || 0) - Number(a.cpu || 0) || String(a.name || '').localeCompare(String(b.name || ''), 'es');
        if (sortBy === 'mem') return Number(b.mem || 0) - Number(a.mem || 0) || String(a.name || '').localeCompare(String(b.name || ''), 'es');
        if (sortBy === 'name') return String(a.name || '').localeCompare(String(b.name || ''), 'es');
        if (sortBy === 'ports') return hasPorts(a) - hasPorts(b) || String(a.name || '').localeCompare(String(b.name || ''), 'es');
        return containerScoreStatus(a) - containerScoreStatus(b)
          || Number(b.cpu || 0) - Number(a.cpu || 0)
          || Number(b.mem || 0) - Number(a.mem || 0)
          || String(a.name || '').localeCompare(String(b.name || ''), 'es');
      });
      return sorted;
    }

    function sortImages(items: any[]) {
      const sorted = [...items];
      sorted.sort((a: any, b: any) => {
        if (sortBy === 'name') return String(a.repo || '').localeCompare(String(b.repo || ''), 'es');
        if (sortBy === 'size') return Number(b.size || 0) - Number(a.size || 0) || String(a.repo || '').localeCompare(String(b.repo || ''), 'es');
        return Number(b.created || 0) - Number(a.created || 0) || String(a.repo || '').localeCompare(String(b.repo || ''), 'es');
      });
      return sorted;
    }

    function sortVolumes(items: any[]) {
      const sorted = [...items];
      sorted.sort((a: any, b: any) => {
        if (sortBy === 'created') return Number(b.created || 0) - Number(a.created || 0) || String(a.name || '').localeCompare(String(b.name || ''), 'es');
        return String(a.name || '').localeCompare(String(b.name || ''), 'es');
      });
      return sorted;
    }

    async function doAction(name: string, action: string) {
      if (actionInFlight) return;
      const verb = dockerActionVerbEs(action);
      const ok = await dockerModalConfirm({
        title: action === 'delete' ? 'Eliminar contenedor' : `${verb} contenedor`,
        body:
          action === 'delete'
            ? `Se eliminará de forma forzada el contenedor «${name}».`
            : `Vas a ${verb.toLowerCase()} el contenedor «${name}».`,
        detail: action === 'delete' ? 'Los procesos dentro del contenedor se detendrán de inmediato.' : undefined,
        variant: action === 'delete' ? 'danger' : 'default',
        confirmLabel: verb,
        cancelLabel: 'Cancelar',
      });
      if (!ok) return;
      actionInFlight = true;
      render();
      setFeedback(`${verb} «${name}»…`, 'Ejecutando acción sobre Docker');
      try {
        const r = await apiPostDockerCtnr(action as 'start' | 'stop' | 'restart' | 'delete', name);
        let j: { ok?: boolean; error?: string } = {};
        try {
          j = await r.json();
        } catch {
          j = { ok: false, error: r.status ? `HTTP ${r.status}` : 'Respuesta inválida' };
        }
        if (r.ok && j.ok) {
          setFeedback(`Listo: ${verb.toLowerCase()} «${name}»`, 'Recargando estado del daemon');
          await load(true);
        } else {
          const err = j.error || `HTTP ${r.status}`;
          setFeedback(`Error al ${action === 'delete' ? 'eliminar' : action} «${name}»`, err);
          await dockerModalAlert({
            title: 'No se pudo completar la acción',
            body: `Docker no aceptó la operación sobre el contenedor «${name}».`,
            detail: err,
          });
        }
      } catch (e) {
        const msg = (e as Error).message;
        setFeedback(`Error al ${action === 'delete' ? 'eliminar' : action} «${name}»`, msg);
        await dockerModalAlert({
          title: 'Error de conexión o cliente',
          body: 'No se pudo hablar con la API de métricas o la petición falló antes de llegar a Docker.',
          detail: msg,
        });
      } finally {
        actionInFlight = false;
        render();
      }
    }

