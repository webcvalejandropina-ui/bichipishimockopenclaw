---
import Layout from '../layouts/Layout.astro';
import pineappleImg from '../assets/pineapple.png';
import { getBuildBrand } from '../lib/brand';
import { iconToSvg } from '../lib/lucide-svg-string';
import {
  Cpu, MemoryStick, HardDrive, Clock, Activity,
  RefreshCw, Users, Settings, Package,
  Copy, Monitor, Server, Globe, Layers, LayoutGrid,
} from 'lucide';

const iconSm = { width: 16, height: 16, 'stroke-width': 2 };

const i = {
  cpu:     iconToSvg(Cpu,        { width: 18, height: 18 }),
  mem:     iconToSvg(MemoryStick,{ width: 18, height: 18 }),
  disk:    iconToSvg(HardDrive,  { width: 18, height: 18 }),
  load:    iconToSvg(Activity,   { width: 18, height: 18 }),
  clock:   iconToSvg(Clock,      { width: 14, height: 14 }),
  refresh: iconToSvg(RefreshCw,  { width: 20, height: 20 }),
  users:   iconToSvg(Users,      { width: 20, height: 20 }),
  settings:iconToSvg(Settings,   { width: 20, height: 20 }),
  pkg:     iconToSvg(Package,    { width: 20, height: 20 }),
  copyTip: iconToSvg(Copy,       { width: 16, height: 16, 'stroke-width': 2 }),
  sysHdr:  iconToSvg(Monitor,    { width: 18, height: 18, 'stroke-width': 2 }),
  sysDev:  iconToSvg(Monitor,    iconSm),
  sysHost: iconToSvg(Server,     iconSm),
  sysOs:   iconToSvg(Layers,     iconSm),
  sysIp:   iconToSvg(Globe,      iconSm),
  sysCpu:  iconToSvg(Cpu,        iconSm),
  sysCores: iconToSvg(LayoutGrid, iconSm),
  sysMem:  iconToSvg(MemoryStick, iconSm),
  sysDisk: iconToSvg(HardDrive,  iconSm),
};

const brand = getBuildBrand();
const avatarSrc = brand.avatarUrl || pineappleImg.src;
const customAvatarClass = brand.avatarUrl ? ' profile-card--custom-avatar' : '';
---
<Layout>
  <h1 class="sr-only">Monitor del sistema {brand.appName}</h1>

  <div class="wrapper wrapper--dashboard">
    <section class="dashboard-metrics-bar" aria-label="Resumen rápido">
      <div class="dashboard-metrics-bar__main">
      <div class="quick-badges">
        <div class="q-badge">
          <span class="q-badge-icon" set:html={i.cpu} aria-hidden="true" />
          <span class="q-badge-stack">
            <span class="q-badge-name">CPU</span>
            <strong id="qb-cpu" class="skeleton q-badge-val">&mdash;</strong>
          </span>
        </div>
        <div class="q-badge q-badge--accent">
          <span class="q-badge-icon" set:html={i.mem} aria-hidden="true" />
          <span class="q-badge-stack">
            <span class="q-badge-name">RAM</span>
            <strong id="qb-ram" class="skeleton q-badge-val">&mdash;</strong>
          </span>
        </div>
        <div class="q-badge">
          <span class="q-badge-icon" set:html={i.disk} aria-hidden="true" />
          <span class="q-badge-stack">
            <span class="q-badge-name">Disco</span>
            <strong id="qb-disk" class="skeleton q-badge-val">&mdash;</strong>
          </span>
        </div>
        <div class="q-badge">
          <span class="q-badge-icon" set:html={i.load} aria-hidden="true" />
          <span class="q-badge-stack">
            <span class="q-badge-name">Carga</span>
            <strong id="qb-load" class="skeleton q-badge-val">&mdash;</strong>
          </span>
        </div>
      </div>
      <div class="kpi-strip">
        <div class="kpi">
          <span class="kpi-icon" set:html={i.users} aria-hidden="true" />
          <div class="kpi-body">
            <div class="kpi-row-main">
              <span class="kpi-value skeleton" id="kpi-proc">&mdash;</span>
              <span class="kpi-title">Procesos</span>
            </div>
            <p class="kpi-meta" id="kpi-proc-meta"></p>
          </div>
        </div>
        <div class="kpi">
          <span class="kpi-icon" set:html={i.settings} aria-hidden="true" />
          <div class="kpi-body">
            <div class="kpi-row-main">
              <span class="kpi-value skeleton" id="kpi-svc">&mdash;</span>
              <span class="kpi-title">Servicios</span>
            </div>
          </div>
        </div>
        <div class="kpi">
          <span class="kpi-icon" set:html={i.pkg} aria-hidden="true" />
          <div class="kpi-body">
            <div class="kpi-row-main">
              <span class="kpi-value skeleton" id="kpi-ctnr">&mdash;</span>
              <span class="kpi-title">Contenedores</span>
            </div>
          </div>
        </div>
      </div>
      </div>
      <button type="button" class="dashboard-refresh-btn" id="refresh-btn" title="Actualizar métricas" aria-label="Actualizar métricas">
        <span set:html={i.refresh} aria-hidden="true" />
      </button>
    </section>

    <section
      class="dashboard-alerts-card card"
      id="dashboard-alerts-card"
      hidden
      aria-labelledby="dash-alerts-heading"
    >
      <div class="dashboard-alerts-head">
        <h2 id="dash-alerts-heading">Alertas recientes</h2>
        <a href="/alertas" class="dashboard-alerts-all">Ver todas →</a>
      </div>
      <ul class="dashboard-alerts-list" id="dash-alerts-list" aria-busy="true" aria-live="polite"></ul>
    </section>

    <div class="dashboard-grid">
      <!-- Profile Card (Pineapple) -->
      <div class={`card profile-card profile-card--loading${customAvatarClass}`} id="card-profile" aria-busy="true">
        <div class="pine-avatar-wrap" id="pine-avatar-wrap" data-mood="ok">
          <div class="pine-load-ring" aria-hidden="true"></div>
          <div class="pine-glow"></div>
          <img
            src={avatarSrc}
            alt={brand.appName}
            class="pine-avatar"
            id="pine-avatar"
            data-mood="ok"
            width="280"
            height="280"
            decoding="async"
            fetchpriority="high"
          />
          <div class="pine-mouth" id="pine-mouth" data-mood="ok">
            <svg viewBox="0 0 40 20" xmlns="http://www.w3.org/2000/svg">
              <path class="mouth-happy" d="M 8 7 Q 20 17 32 7" stroke="#5D4037" stroke-width="2.5" fill="none" stroke-linecap="round"/>
              <path class="mouth-neutral" d="M 10 11 Q 20 11 30 11" stroke="#5D4037" stroke-width="2.5" fill="none" stroke-linecap="round"/>
              <path class="mouth-sad" d="M 10 15 Q 20 7 30 15" stroke="#5D4037" stroke-width="2.5" fill="none" stroke-linecap="round"/>
            </svg>
          </div>
        </div>
        <div class="profile-info">
          <h2 class="profile-name" id="profile-name"><span class="profile-name-filler skeleton">&nbsp;</span></h2>
          <p class="profile-role profile-role--boot" id="profile-role">Sincronizando con el monitor…</p>
          <span class="profile-badge profile-badge--boot" id="profile-badge">
            <span set:html={i.clock} aria-hidden="true" />
            <span class="profile-uptime-line skeleton" id="profile-uptime">&nbsp;</span>
          </span>
        </div>
      </div>

      <!-- Progress Card (CPU bars) -->
      <div class="card progress-card">
        <a href="/rendimiento" class="progress-card-headline" aria-label="Ver rendimiento por días">
          <div class="card-header">
            <h3>Rendimiento</h3>
            <span class="card-arrow" aria-hidden="true">&#8599;</span>
          </div>
        </a>
        <div class="progress-big">
          <span class="progress-value skeleton" id="cpu-pct-val">&mdash;</span>
          <span class="progress-unit">%</span>
        </div>
        <p class="progress-subtitle">CPU por día (semana actual, datos guardados en BD/local)</p>
        <div class="bar-chart" id="cpu-bars">
          <div class="bar-col"><div class="bar-fill" style="height:20%"></div><span class="bar-label">L</span></div>
          <div class="bar-col"><div class="bar-fill" style="height:35%"></div><span class="bar-label">M</span></div>
          <div class="bar-col"><div class="bar-fill" style="height:50%"></div><span class="bar-label">X</span></div>
          <div class="bar-col"><div class="bar-fill" style="height:45%"></div><span class="bar-label">J</span></div>
          <div class="bar-col"><div class="bar-fill active" style="height:70%"><span class="bar-tooltip" id="bar-current">—</span></div><span class="bar-label">V</span></div>
          <div class="bar-col"><div class="bar-fill" style="height:30%"></div><span class="bar-label">S</span></div>
          <div class="bar-col"><div class="bar-fill" style="height:15%"></div><span class="bar-label">D</span></div>
        </div>
      </div>

      <!-- Time Tracker -->
      <div class="card tracker-card">
        <div class="card-header">
          <h3>Time tracker</h3>
        </div>
        <div class="tracker-gauge">
          <canvas id="uptime-chart" aria-hidden="true"></canvas>
        </div>
        <div class="tracker-time" id="live-clock">00:00</div>
        <p class="tracker-label">Hora del Sistema</p>
        <p class="tracker-note">
          Histórico real en servidor (SQLite, ≥7 días). <a href="/rendimiento">Ver rendimiento</a>
        </p>
      </div>

      <!-- Status Card -->
      <div class="card status-card" id="card-status">
        <div class="card-header">
          <h3>Estado</h3>
          <span class="status-pct skeleton" id="health-pct">&mdash;%</span>
        </div>
        <div class="status-bars">
          <div class="status-row">
            <span class="status-label">CPU</span>
            <div class="status-bar"><div class="status-fill" id="bar-cpu" style="width:0%;background:var(--ok)"></div></div>
            <span class="status-val" id="bar-cpu-val">&mdash;</span>
          </div>
          <div class="status-row">
            <span class="status-label">RAM</span>
            <div class="status-bar"><div class="status-fill" id="bar-mem" style="width:0%;background:var(--accent2)"></div></div>
            <span class="status-val" id="bar-mem-val">&mdash;</span>
          </div>
          <div class="status-row">
            <span class="status-label">Disco</span>
            <div class="status-bar"><div class="status-fill" id="bar-disk" style="width:0%;background:var(--warn)"></div></div>
            <span class="status-val" id="bar-disk-val">&mdash;</span>
          </div>
        </div>
        <span class="status-task-label">Sistema</span>
      </div>

      <!-- Sidebar Card (System Info) -->
      <div class="card sidebar-card" id="card-system">
        <details class="sidebar-section sidebar-section--sysinfo" open>
          <summary>
            <span class="sidebar-section__summary-lead">
              <span class="sidebar-section__summary-ico" set:html={i.sysHdr} aria-hidden="true" />
              <span>Información del Sistema</span>
            </span>
          </summary>
          <div class="section-content section-content--sysinfo">
            <p class="dash-sys-lede">Hover o foco en el valor: detalle completo y copiar · mismo criterio visual que Actividad.</p>
            <div class="dash-sys-stack">
              <div class="dash-sys-row-card">
                <div class="dash-sys-row-ico act-icon act-icon--info" set:html={i.sysDev} aria-hidden="true" />
                <div class="dash-sys-row-main">
                  <span class="dash-sys-row-label">Equipo</span>
                  <span class="dash-sys-tip" tabindex="0" data-dash-sys-tip>
                    <span class="dash-sys-val sys-val skeleton sys-val--dash-ellipsis" id="sys-device"></span>
                    <span class="dash-sys-tip__bubble" id="sys-device-tip" role="tooltip">
                      <span class="dash-sys-tip__bubble-row">
                        <span class="dash-sys-tip__bubble-text" data-dash-tip-line></span>
                        <button type="button" class="dash-sys-tip__copy" aria-label="Copiar al portapapeles" title="Copiar">
                          <span class="dash-sys-tip__copy-icon" set:html={i.copyTip} aria-hidden="true" />
                        </button>
                      </span>
                    </span>
                  </span>
                </div>
              </div>
              <div class="dash-sys-row-card">
                <div class="dash-sys-row-ico act-icon act-icon--info" set:html={i.sysHost} aria-hidden="true" />
                <div class="dash-sys-row-main">
                  <span class="dash-sys-row-label">Hostname</span>
                  <span class="dash-sys-tip" tabindex="0" data-dash-sys-tip>
                    <span class="dash-sys-val sys-val skeleton sys-val--dash-ellipsis" id="sys-host"></span>
                    <span class="dash-sys-tip__bubble" id="sys-host-tip" role="tooltip">
                      <span class="dash-sys-tip__bubble-row">
                        <span class="dash-sys-tip__bubble-text" data-dash-tip-line></span>
                        <button type="button" class="dash-sys-tip__copy" aria-label="Copiar al portapapeles" title="Copiar">
                          <span class="dash-sys-tip__copy-icon" set:html={i.copyTip} aria-hidden="true" />
                        </button>
                      </span>
                    </span>
                  </span>
                </div>
              </div>
              <div class="dash-sys-row-card">
                <div class="dash-sys-row-ico act-icon act-icon--info" set:html={i.sysOs} aria-hidden="true" />
                <div class="dash-sys-row-main">
                  <span class="dash-sys-row-label">Sistema operativo</span>
                  <span class="dash-sys-tip" tabindex="0" data-dash-sys-tip>
                    <span class="dash-sys-val sys-val skeleton sys-val--dash-ellipsis" id="sys-os"></span>
                    <span class="dash-sys-tip__bubble" id="sys-os-tip" role="tooltip">
                      <span class="dash-sys-tip__bubble-row">
                        <span class="dash-sys-tip__bubble-text" data-dash-tip-line></span>
                        <button type="button" class="dash-sys-tip__copy" aria-label="Copiar al portapapeles" title="Copiar">
                          <span class="dash-sys-tip__copy-icon" set:html={i.copyTip} aria-hidden="true" />
                        </button>
                      </span>
                    </span>
                  </span>
                </div>
              </div>
              <div class="dash-sys-row-card">
                <div class="dash-sys-row-ico act-icon act-icon--info" set:html={i.sysIp} aria-hidden="true" />
                <div class="dash-sys-row-main">
                  <span class="dash-sys-row-label">IP pública</span>
                  <span class="dash-sys-tip" tabindex="0" data-dash-sys-tip>
                    <span class="dash-sys-val sys-val skeleton sys-val--dash-ellipsis" id="sys-ipv4"></span>
                    <span class="dash-sys-tip__bubble" id="sys-ipv4-tip" role="tooltip">
                      <span class="dash-sys-tip__bubble-row">
                        <span class="dash-sys-tip__bubble-text" data-dash-tip-line></span>
                        <button type="button" class="dash-sys-tip__copy" aria-label="Copiar al portapapeles" title="Copiar">
                          <span class="dash-sys-tip__copy-icon" set:html={i.copyTip} aria-hidden="true" />
                        </button>
                      </span>
                    </span>
                  </span>
                </div>
              </div>
              <div class="dash-sys-row-card">
                <div class="dash-sys-row-ico act-icon act-icon--info" set:html={i.sysCpu} aria-hidden="true" />
                <div class="dash-sys-row-main">
                  <span class="dash-sys-row-label">CPU</span>
                  <span class="dash-sys-tip" tabindex="0" data-dash-sys-tip>
                    <span class="dash-sys-val sys-val skeleton sys-val--dash-ellipsis" id="sys-cpu-model"></span>
                    <span class="dash-sys-tip__bubble" id="sys-cpu-model-tip" role="tooltip">
                      <span class="dash-sys-tip__bubble-row">
                        <span class="dash-sys-tip__bubble-text" data-dash-tip-line></span>
                        <button type="button" class="dash-sys-tip__copy" aria-label="Copiar al portapapeles" title="Copiar">
                          <span class="dash-sys-tip__copy-icon" set:html={i.copyTip} aria-hidden="true" />
                        </button>
                      </span>
                    </span>
                  </span>
                </div>
              </div>
              <div class="dash-sys-row-card">
                <div class="dash-sys-row-ico act-icon act-icon--info" set:html={i.sysCores} aria-hidden="true" />
                <div class="dash-sys-row-main">
                  <span class="dash-sys-row-label">Núcleos</span>
                  <span class="dash-sys-tip" tabindex="0" data-dash-sys-tip>
                    <span class="dash-sys-val sys-val skeleton sys-val--dash-ellipsis" id="sys-cpu-cores"></span>
                    <span class="dash-sys-tip__bubble" id="sys-cpu-cores-tip" role="tooltip">
                      <span class="dash-sys-tip__bubble-row">
                        <span class="dash-sys-tip__bubble-text" data-dash-tip-line></span>
                        <button type="button" class="dash-sys-tip__copy" aria-label="Copiar al portapapeles" title="Copiar">
                          <span class="dash-sys-tip__copy-icon" set:html={i.copyTip} aria-hidden="true" />
                        </button>
                      </span>
                    </span>
                  </span>
                </div>
              </div>
              <div class="dash-sys-row-card">
                <div class="dash-sys-row-ico act-icon act-icon--info" set:html={i.sysMem} aria-hidden="true" />
                <div class="dash-sys-row-main">
                  <span class="dash-sys-row-label">RAM</span>
                  <span class="dash-sys-tip" tabindex="0" data-dash-sys-tip>
                    <span class="dash-sys-val sys-val skeleton sys-val--dash-ellipsis" id="sys-mem-used"></span>
                    <span class="dash-sys-tip__bubble" id="sys-mem-used-tip" role="tooltip">
                      <span class="dash-sys-tip__bubble-row">
                        <span class="dash-sys-tip__bubble-text" data-dash-tip-line></span>
                        <button type="button" class="dash-sys-tip__copy" aria-label="Copiar al portapapeles" title="Copiar">
                          <span class="dash-sys-tip__copy-icon" set:html={i.copyTip} aria-hidden="true" />
                        </button>
                      </span>
                    </span>
                  </span>
                </div>
              </div>
              <div class="dash-sys-row-card">
                <div class="dash-sys-row-ico act-icon act-icon--info" set:html={i.sysDisk} aria-hidden="true" />
                <div class="dash-sys-row-main">
                  <span class="dash-sys-row-label">Disco</span>
                  <span class="dash-sys-tip" tabindex="0" data-dash-sys-tip>
                    <span class="dash-sys-val sys-val skeleton sys-val--dash-ellipsis" id="sys-disk-used"></span>
                    <span class="dash-sys-tip__bubble" id="sys-disk-used-tip" role="tooltip">
                      <span class="dash-sys-tip__bubble-row">
                        <span class="dash-sys-tip__bubble-text" data-dash-tip-line></span>
                        <button type="button" class="dash-sys-tip__copy" aria-label="Copiar al portapapeles" title="Copiar">
                          <span class="dash-sys-tip__copy-icon" set:html={i.copyTip} aria-hidden="true" />
                        </button>
                      </span>
                    </span>
                  </span>
                </div>
              </div>
            </div>
          </div>
        </details>
        <details class="sidebar-section">
          <summary>Recursos</summary>
          <div class="section-content">
            <div class="sys-grid">
              <div class="sys-item"><span class="sys-key">Uptime</span><span class="sys-val skeleton" id="sys-uptime">&mdash;</span></div>
              <div class="sys-item"><span class="sys-key">Hora</span><span class="sys-val" id="sys-time">&mdash;</span></div>
            </div>
          </div>
        </details>
      </div>

      <!-- Tareas programadas (solo lectura; lista = fuente de verdad) -->
      <div class="card calendar-card" id="card-calendar" style="padding:20px">
        <div class="card-header cron-card-header">
          <h3>Tareas programadas</h3>
          <div class="cron-month-nav">
            <button type="button" class="card-arrow" id="cal-prev" aria-label="Mes anterior">&#8592;</button>
            <span id="cal-month-label" class="cron-month-label"></span>
            <button type="button" class="card-arrow" id="cal-next" aria-label="Mes siguiente">&#8594;</button>
          </div>
        </div>
        <p class="cron-lede">
          Solo lectura: la API muestra lo que puede leer del sistema (crontab, <code>/etc/crontab</code>, <code>CRON_EXTRA_FILE</code>).
          Con Docker Compose suele usarse <code>config/cron.extra</code>. Primero va la <strong>lista completa</strong>; el calendario indica en qué días del mes encajan las reglas (hora según el servidor).
        </p>
        <div class="cron-status-bar" id="cron-status-bar" aria-live="polite"></div>
        <div class="cron-master-list" id="cron-master-list" aria-label="Listado de tareas"></div>
        <h4 class="cron-cal-heading">Calendario del mes</h4>
        <p class="cron-cal-sub">Puntos de color = tipo de recurrencia. Toca un día para filtrar la lista de la derecha.</p>
        <div class="cron-freq-legend cron-freq-legend--compact">
          <span class="cron-freq-item"><span class="cron-freq-dot cal-dot daily"></span> Diario</span>
          <span class="cron-freq-item"><span class="cron-freq-dot cal-dot weekly"></span> Semanal</span>
          <span class="cron-freq-item"><span class="cron-freq-dot cal-dot monthly"></span> Mensual</span>
          <span class="cron-freq-item"><span class="cron-freq-dot cal-dot custom"></span> Otro</span>
        </div>
        <div class="cron-layout">
          <div class="cron-cal-wrap">
            <div class="cal-full-grid" id="cal-grid"></div>
          </div>
          <div class="cron-sidebar" id="cron-sidebar">
            <div class="cron-date-title" id="cron-date-title">Toca un día en el calendario</div>
            <div class="cron-jobs-scroll">
              <div id="cron-jobs-list"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Activity Card -->
      <div class="card activity-card" id="card-activity">
        <div class="activity-header">
          <div class="activity-header-titles">
            <h3>Actividad</h3>
            <p class="activity-host-os" id="activity-host-os" hidden></p>
          </div>
          <span class="activity-count" id="activity-count">0/0</span>
        </div>
        <div class="tabs activity-tabs-scroll" role="tablist" aria-label="Pestañas de actividad">
          <button type="button" class="tab active" data-panel="panel-proc" id="tab-proc" role="tab">Procesos</button>
          <button type="button" class="tab" data-panel="panel-svc" id="tab-svc" role="tab">Servicios</button>
          <button type="button" class="tab" data-panel="panel-ctnr" id="tab-ctnr" role="tab">Docker</button>
          <button type="button" class="tab" data-panel="panel-warn" id="tab-warn" role="tab">Alertas</button>
        </div>
        <div class="tab-panels">
          <div class="tab-panel active" id="panel-proc" role="tabpanel">
            <div class="activity-list" id="proc-list" aria-busy="true">
              <span class="sr-only">Sincronizando actividad del sistema</span>
              <div class="act-skel-row" aria-hidden="true"><div class="skeleton skeleton--activity act-skel-icon">&nbsp;</div><div class="act-skel-main"><span class="skeleton skeleton--activity act-skel-line act-skel-line--w70">&nbsp;</span><span class="skeleton skeleton--activity act-skel-line act-skel-line--w90">&nbsp;</span></div><span class="skeleton skeleton--activity act-skel-check">&nbsp;</span></div>
              <div class="act-skel-row" aria-hidden="true"><div class="skeleton skeleton--activity act-skel-icon">&nbsp;</div><div class="act-skel-main"><span class="skeleton skeleton--activity act-skel-line act-skel-line--w45">&nbsp;</span><span class="skeleton skeleton--activity act-skel-line act-skel-line--w90">&nbsp;</span></div><span class="skeleton skeleton--activity act-skel-check">&nbsp;</span></div>
              <div class="act-skel-row" aria-hidden="true"><div class="skeleton skeleton--activity act-skel-icon">&nbsp;</div><div class="act-skel-main"><span class="skeleton skeleton--activity act-skel-line act-skel-line--w70">&nbsp;</span><span class="skeleton skeleton--activity act-skel-line act-skel-line--w70">&nbsp;</span></div><span class="skeleton skeleton--activity act-skel-check">&nbsp;</span></div>
              <div class="act-skel-row" aria-hidden="true"><div class="skeleton skeleton--activity act-skel-icon">&nbsp;</div><div class="act-skel-main"><span class="skeleton skeleton--activity act-skel-line act-skel-line--w90">&nbsp;</span><span class="skeleton skeleton--activity act-skel-line act-skel-line--w45">&nbsp;</span></div><span class="skeleton skeleton--activity act-skel-check">&nbsp;</span></div>
              <div class="act-skel-row" aria-hidden="true"><div class="skeleton skeleton--activity act-skel-icon">&nbsp;</div><div class="act-skel-main"><span class="skeleton skeleton--activity act-skel-line act-skel-line--w70">&nbsp;</span><span class="skeleton skeleton--activity act-skel-line act-skel-line--w90">&nbsp;</span></div><span class="skeleton skeleton--activity act-skel-check">&nbsp;</span></div>
            </div>
          </div>
          <div class="tab-panel" id="panel-svc" role="tabpanel" hidden>
            <div class="activity-list" id="svc-list" aria-busy="true">
              <span class="sr-only">Sincronizando actividad del sistema</span>
              <div class="act-skel-row" aria-hidden="true"><div class="skeleton skeleton--activity act-skel-icon">&nbsp;</div><div class="act-skel-main"><span class="skeleton skeleton--activity act-skel-line act-skel-line--w70">&nbsp;</span><span class="skeleton skeleton--activity act-skel-line act-skel-line--w90">&nbsp;</span></div><span class="skeleton skeleton--activity act-skel-check">&nbsp;</span></div>
              <div class="act-skel-row" aria-hidden="true"><div class="skeleton skeleton--activity act-skel-icon">&nbsp;</div><div class="act-skel-main"><span class="skeleton skeleton--activity act-skel-line act-skel-line--w45">&nbsp;</span><span class="skeleton skeleton--activity act-skel-line act-skel-line--w90">&nbsp;</span></div><span class="skeleton skeleton--activity act-skel-check">&nbsp;</span></div>
              <div class="act-skel-row" aria-hidden="true"><div class="skeleton skeleton--activity act-skel-icon">&nbsp;</div><div class="act-skel-main"><span class="skeleton skeleton--activity act-skel-line act-skel-line--w70">&nbsp;</span><span class="skeleton skeleton--activity act-skel-line act-skel-line--w70">&nbsp;</span></div><span class="skeleton skeleton--activity act-skel-check">&nbsp;</span></div>
            </div>
          </div>
          <div class="tab-panel" id="panel-ctnr" role="tabpanel" hidden>
            <div class="activity-list" id="ctnr-list" aria-busy="true">
              <span class="sr-only">Sincronizando contenedores</span>
              <div class="ctnr-skel-grid" aria-hidden="true">
                <div class="ctnr-skel-card"><span class="skeleton skeleton--activity ctnr-skel-line">&nbsp;</span><span class="skeleton skeleton--activity ctnr-skel-line ctnr-skel-line--sm">&nbsp;</span></div>
                <div class="ctnr-skel-card"><span class="skeleton skeleton--activity ctnr-skel-line">&nbsp;</span><span class="skeleton skeleton--activity ctnr-skel-line ctnr-skel-line--sm">&nbsp;</span></div>
                <div class="ctnr-skel-card"><span class="skeleton skeleton--activity ctnr-skel-line">&nbsp;</span><span class="skeleton skeleton--activity ctnr-skel-line ctnr-skel-line--sm">&nbsp;</span></div>
              </div>
            </div>
          </div>
          <div class="tab-panel" id="panel-warn" role="tabpanel" hidden>
            <div class="activity-list" id="warn-list" aria-busy="true">
              <span class="sr-only">Sincronizando avisos del sistema</span>
              <div class="warn-item" aria-hidden="true"><span class="skeleton skeleton--activity warn-skel-bar warn-skel-bar--long">&nbsp;</span></div>
              <div class="warn-item" aria-hidden="true"><span class="skeleton skeleton--activity warn-skel-bar warn-skel-bar--med">&nbsp;</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    import { Chart, DoughnutController, ArcElement, Tooltip } from 'chart.js';
    import { Monitor, Settings, Package, CircleCheck, AlertTriangle, Check, X } from 'lucide';
    import { iconToSvg } from '../lib/lucide-svg-string';
    import {
      fetchMetrics,
      updateHeader,
      statusColor,
      fmtUptime,
      healthLevel,
      setAlertsBadgeCount,
      hasValidSystemUptime,
      fetchCronCalendar,
      type SystemCronJob,
    } from '../lib/metrics';
    import {
      buildDashAlertListForHome,
      countUndismissedAlertsFromMetrics,
      rememberDismissedAlertId,
      stableAlertDismissId,
    } from '../lib/alert-dismiss';
    import { processActivityDescription, serviceActivityDescription, escHtml } from '../lib/process-hints';
    import { recordPerfSample, loadPerfDailyMerged, localDateKey, type DayPerfAgg } from '../lib/perf-daily';
    import { initCopyableValues, copyTextToClipboard } from '../lib/copy-field';
    import { resolveBichiBrand, applyBichiBrandToDocument } from '../lib/brand-runtime';

    Chart.register(DoughnutController, ArcElement, Tooltip);

    const L = {
      monitorSm: iconToSvg(Monitor, { width: 16, height: 16 }),
      settingsSm: iconToSvg(Settings, { width: 16, height: 16 }),
      packageSm: iconToSvg(Package, { width: 16, height: 16 }),
      checkSm: iconToSvg(CircleCheck, { width: 16, height: 16 }),
      warnSm: iconToSvg(AlertTriangle, { width: 16, height: 16 }),
      tickSm: iconToSvg(Check, { width: 10, height: 10 }),
    };
    const dismissAlertSvg = iconToSvg(X, { width: 14, height: 14 });

    const $ = (id: string) => document.getElementById(id)!;
    let bichiCronRefresh: (() => Promise<void>) | null = null;
    let lastMetricsForAlerts: any = null;

    /* ── Clock ── */
    function updateClock() {
      const now = new Date();
      $('live-clock').textContent = now.toLocaleTimeString('es-ES', { hour: '2-digit', minute: '2-digit' });
      $('sys-time').textContent = now.toLocaleTimeString('es-ES', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
    }
    updateClock();
    setInterval(updateClock, 1000);

    /* ── Chart ── */
    function themeTrack() {
      const dark = document.documentElement.getAttribute('data-theme') === 'dark';
      return dark ? 'rgba(255,255,255,0.08)' : 'rgba(0,0,0,0.06)';
    }

    const centerTextPlugin = {
      id: 'centerText',
      afterDraw(chart: any) {
        const { ctx, chartArea } = chart;
        if (!chartArea) return;
        const cx = (chartArea.left + chartArea.right) / 2;
        const cy = (chartArea.top + chartArea.bottom) / 2;
        const value = chart._centerValue ?? chart.data.datasets[0].data[0];
        const outerR = chart._metasets?.[0]?.data?.[0]?.outerRadius;
        const size = outerR ? Math.min(outerR * 0.42, 24) : 18;
        const dark = document.documentElement.getAttribute('data-theme') === 'dark';
        ctx.save();
        ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.font = `800 ${size}px 'Plus Jakarta Sans', sans-serif`;
        ctx.fillStyle = '#F5C542'; ctx.shadowColor = 'transparent'; ctx.shadowBlur = 0;
        ctx.fillText(`${Math.round(value)}%`, cx, cy - size * 0.12);
        ctx.font = `600 ${size * 0.38}px 'Plus Jakarta Sans', sans-serif`;
        ctx.fillStyle = dark ? 'rgba(228,230,240,0.6)' : 'rgba(80,80,100,0.6)';
        ctx.shadowBlur = 0;
        ctx.fillText('Uptime', cx, cy + size * 0.5);
        ctx.restore();
      }
    };
    Chart.register(centerTextPlugin);

    let uptimeChart: Chart | null = null;

    function createUptimeChart() {
      const canvas = document.getElementById('uptime-chart') as HTMLCanvasElement | null;
      if (!canvas) return;
      const prev = Chart.getChart(canvas);
      if (prev) prev.destroy();
      uptimeChart = new Chart(canvas, {
        type: 'doughnut',
        data: { labels: ['Activo', 'Inactivo'], datasets: [{ data: [95, 5], backgroundColor: ['#F5C542', themeTrack()], borderWidth: 0, borderRadius: 6, spacing: 2 }] },
        options: { cutout: '72%', plugins: { legend: { display: false }, tooltip: { enabled: false } }, animation: { animateRotate: true, duration: 700, easing: 'easeOutCubic' as const }, responsive: true, maintainAspectRatio: true },
      });
    }

    window.addEventListener('theme-change', () => {
      requestAnimationFrame(() => {
        if (!uptimeChart?.canvas?.isConnected) return;
        const ds0 = uptimeChart.data.datasets[0];
        const bg = ds0 && typeof ds0 === 'object' && 'backgroundColor' in ds0 ? ds0.backgroundColor : null;
        if (Array.isArray(bg) && bg.length >= 2) {
          bg[1] = themeTrack();
        }
        uptimeChart.update('none');
      });
    });

    /* ── Tabs ── */
    document.querySelectorAll('.activity-card .tab').forEach(tab => {
      tab.addEventListener('click', () => {
        document.querySelectorAll('.activity-card .tab').forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
        document.querySelectorAll('.activity-card .tab-panel').forEach(p => { p.classList.remove('active'); p.setAttribute('hidden', ''); });
        tab.classList.add('active'); tab.setAttribute('aria-selected', 'true');
        const panel = $((tab as HTMLElement).dataset.panel!);
        panel.classList.add('active'); panel.removeAttribute('hidden');
      });
    });

    /* ── Semana L–D: barras desde histórico real (sin “futuro”) ── */
    function mondayOfWeekContaining(ref: Date): Date {
      const x = new Date(ref.getFullYear(), ref.getMonth(), ref.getDate());
      const dow = x.getDay();
      const monOffset = dow === 0 ? -6 : 1 - dow;
      x.setDate(x.getDate() + monOffset);
      return x;
    }

    function updateWeekCpuBars(merged: Record<string, DayPerfAgg>, liveCpu: number) {
      const bars = document.querySelectorAll('#cpu-bars .bar-fill');
      const todayKey = localDateKey();
      const mon = mondayOfWeekContaining(new Date());
      bars.forEach((bar, idx) => {
        const cell = (bar as HTMLElement).closest('.bar-col') as HTMLElement | null;
        const dayDate = new Date(mon.getFullYear(), mon.getMonth(), mon.getDate() + idx);
        const key = localDateKey(dayDate);
        const isFuture = key > todayKey;
        cell?.classList.toggle('bar-col--future', isFuture);
        const el = bar as HTMLElement;
        if (isFuture) {
          el.style.height = '5%';
          el.style.removeProperty('opacity');
          el.classList.remove('active');
          return;
        }
        el.style.removeProperty('opacity');
        const agg = merged[key];
        let h = agg && agg.samples > 0 ? agg.sumCpu / agg.samples : 0;
        if (key === todayKey) h = Math.max(h, liveCpu);
        el.style.height = `${Math.min(100, Math.max(h, 1))}%`;
        el.classList.toggle('active', key === todayKey);
      });
      const tip = document.getElementById('bar-current');
      if (tip) tip.textContent = `${Math.round(liveCpu)}%`;
    }

    /* ── Render helpers ── */

    function attrEsc(s: string) {
      return String(s).replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;');
    }

    function renderProcs(procs: any[]) {
      const el = $('proc-list');
      el.removeAttribute('aria-busy');
      if (!procs?.length) { el.innerHTML = '<div class="act-empty">Sin procesos</div>'; return; }
      el.innerHTML = procs.map((p: any, i: number) => {
        const cpu = p.cpu ?? 0;
        const ok = cpu < 60;
        let tier = 'act-cpu-ok';
        if (cpu >= 85) tier = 'act-cpu-crit';
        else if (cpu >= 60) tier = 'act-cpu-warn';
        const act = processActivityDescription(p.comm || '', p.cmd || '', p.desc);
        const actShort = act.length > 120 ? `${act.slice(0, 117)}…` : act;
        const comm = p.comm || '?';
        const cmd = p.cmd || '';
        const aria = `Proceso ${comm}, PID ${p.pid}, ${cpu.toFixed(1)} % CPU`;
        return `<div class="act-item act-item--proc" style="animation-delay:${i*25}ms" aria-label="${attrEsc(aria)}">
          <div class="act-icon ${ok ? 'act-icon--info' : 'act-icon--warn'}">${L.monitorSm}</div>
          <div class="act-info">
            <div class="act-name act-name--full js-copy-val" data-copy-text="${attrEsc(comm)}">${escHtml(comm)}</div>
            <div class="act-htop">${escHtml(actShort)}</div>
            <div class="act-desc">PID ${p.pid} · <span class="act-cpu-metric ${tier}">${cpu.toFixed(1)}%</span> · top CPU</div>
          </div>
          <div class="act-check ${ok ? 'done' : ''}">${ok ? L.tickSm : ''}</div>
        </div>`;
      }).join('');
      initCopyableValues(el);
    }

    function renderSvcs(svcs: any[]) {
      const el = $('svc-list');
      el.removeAttribute('aria-busy');
      if (!svcs?.length) { el.innerHTML = '<div class="act-empty">Sin servicios</div>'; return; }
      el.innerHTML = svcs.map((s: any, idx: number) => {
        const detail = serviceActivityDescription(s.name || '', s.desc);
        const detailShort = detail.length > 110 ? `${detail.slice(0, 107)}…` : detail;
        const nm = (s.name || '').replace(/\.service$/i, '').replace(/\.timer$/i, '');
        return `
        <div class="act-item" style="animation-delay:${idx * 25}ms">
          <div class="act-icon ${s.active ? 'act-icon--ok' : 'act-icon--crit'}">${L.settingsSm}</div>
          <div class="act-info">
            <div class="act-name">${escHtml(nm)}</div>
            <div class="act-htop">${escHtml(detailShort)}</div>
            <div class="svc-pills"><span class="svc-pill ${s.active ? 'on' : 'off'}">${s.active ? 'Activo' : 'Inactivo'}</span><span class="svc-pill ${s.running ? 'on' : 'off'}">${s.running ? 'Run' : 'Stop'}</span></div>
          </div>
          <div class="act-check ${s.running ? 'done' : ''}">${s.running ? L.tickSm : ''}</div>
        </div>`;
      }).join('');
    }

    function renderCtrs(ctrs: any[]) {
      const el = $('ctnr-list');
      el.removeAttribute('aria-busy');
      if (!ctrs?.length) { el.innerHTML = '<div class="act-empty">Sin contenedores</div>'; return; }
      el.innerHTML = `<div class="ctnr-grid">${ctrs.map((c: any, idx: number) => {
        const up = c.status?.toLowerCase().includes('up');
        return `<div class="ctnr-card-item" style="animation-delay:${idx*30}ms"><div class="ctnr-name">${c.name}</div><div class="ctnr-status${up?'':' down'}">${up?'Activo':'Detenido'}</div><div class="ctnr-ports">${c.ports||'—'}</div></div>`;
      }).join('')}</div>`;
    }

    function renderWarns(warns: string[]) {
      const el = $('warn-list');
      el.removeAttribute('aria-busy');
      if (!warns?.length) { el.innerHTML = '<div class="act-empty">Sin alertas — todo estable</div>'; return; }
      el.innerHTML = warns.map((w, idx) => {
        const crit = /error|fail|fatal|crit/i.test(w);
        return `<div class="warn-item${crit ? ' crit' : ''}" style="animation-delay:${idx * 25}ms"><div class="warn-msg">${escHtml(w)}</div></div>`;
      }).join('');
    }

    function fmtAlertAge(atMs: number) {
      const m = Math.floor((Date.now() - atMs) / 60000);
      if (m < 1) return 'Ahora';
      if (m < 60) return `Hace ${m} min`;
      const h = Math.floor(m / 60);
      return `Hace ${h} h`;
    }

    function renderDashAlerts(d: any) {
      const el = document.getElementById('dash-alerts-list');
      const card = document.getElementById('dashboard-alerts-card');
      if (!el || !card) return;
      el.setAttribute('aria-busy', 'false');
      const hideCard = () => {
        card.setAttribute('hidden', '');
        el.innerHTML = '';
      };
      if (!d) {
        hideCard();
        return;
      }
      const items = buildDashAlertListForHome(d, 6);
      if (!items.length) {
        hideCard();
        return;
      }
      card.removeAttribute('hidden');
      el.innerHTML = items
        .map((a) => {
          const sev = a.severity === 'critical' ? 'critical' : 'warning';
          const at = typeof a.at === 'number' ? a.at : Date.now();
          const src = [a.source, a.code].filter(Boolean).join(' · ');
          const meta = [src, a.host].filter(Boolean).join(' · ');
          const aid = stableAlertDismissId(a);
          return `<li class="dash-alert dash-alert--${sev}" data-alert-id="${aid.replace(/"/g, '')}">
          <div class="dash-alert-body">
            <div class="dash-alert-meta"><span class="dash-alert-src">${escHtml(meta || 'monitor')}</span><span class="dash-alert-time">${escHtml(fmtAlertAge(at))}</span></div>
            <div class="dash-alert-title">${escHtml(a.title || 'Alerta')}</div>
            <div class="dash-alert-detail">${escHtml(a.detail || '')}</div>
          </div>
          <button type="button" class="dash-alert-dismiss" aria-label="Descartar alerta" title="No volver a mostrar">${dismissAlertSvg}</button>
        </li>`;
        })
        .join('');
    }

    const DASH_SYS_FACE_MAX = 42;

    function setDashSysTip(
      faceId: string,
      tipId: string,
      faceText: string,
      tipFullLine: string,
      maxFace = DASH_SYS_FACE_MAX,
    ) {
      const face = document.getElementById(faceId);
      const tip = document.getElementById(tipId);
      const line = tip?.querySelector('[data-dash-tip-line]');
      if (!face || !tip || !line) return;
      const full = (tipFullLine || '—').trim() || '—';
      const show = (faceText || full).trim() || '—';
      face.textContent = show.length > maxFace ? `${show.slice(0, maxFace - 1)}…` : show;
      face.classList.remove('skeleton');
      line.textContent = full;
    }

    let dashSysTipsWired = false;
    function wireDashSysTips() {
      if (dashSysTipsWired) return;
      dashSysTipsWired = true;
      document.body.addEventListener('click', (e) => {
        const t = e.target as HTMLElement;
        const btn = t.closest('button.dash-sys-tip__copy');
        if (!btn || !document.getElementById('card-system')?.contains(btn)) return;
        e.preventDefault();
        e.stopPropagation();
        const row = btn.closest('.dash-sys-tip__bubble-row');
        const line = row?.querySelector('[data-dash-tip-line]');
        const text = line?.textContent?.trim() ?? '';
        void copyTextToClipboard(text).then((ok) => {
          if (ok) {
            btn.classList.add('is-copied');
            window.setTimeout(() => btn.classList.remove('is-copied'), 1200);
          }
        });
      });
    }

    /* ── Fetch metrics ── */
    let prevCpu = 0;
    let profileIntroDone = false;

    function unlockProfileCard() {
      const pc = document.getElementById('card-profile');
      if (!pc || profileIntroDone) return;
      profileIntroDone = true;
      pc.classList.remove('profile-card--loading');
      pc.classList.add('profile-card--ready');
      pc.removeAttribute('aria-busy');
    }

    async function load() {
      const btn = document.getElementById('refresh-btn');
      btn?.classList.add('spinning');
      try {
        const d = await fetchMetrics();
        lastMetricsForAlerts = d;
        updateHeader(d);

        const cpu = d.cpu, mem = d.mem, disk = d.disk;
        recordPerfSample({ cpu, mem, disk });
        let perfMerged: Record<string, DayPerfAgg> = {};
        try {
          perfMerged = await loadPerfDailyMerged();
        } catch {
          perfMerged = {};
        }
        updateWeekCpuBars(perfMerged, Number(cpu) || 0);

        const set = (id: string, v: string) => { const e = $(id); e.textContent = v; e.classList.remove('skeleton'); };

        set('qb-cpu', `${Math.round(cpu)}%`);
        set('qb-ram', `${Math.round(mem)}%`);
        set('qb-disk', `${Math.round(disk)}%`);
        set(
          'qb-load',
          Array.isArray(d.load) && d.load.length ? d.load[0].toFixed(2) : '—',
        );
        set('cpu-pct-val', String(Math.round(cpu)));
        const nTop = (d.topCpu || []).length;
        const nTot = typeof d.processCountTotal === 'number' && d.processCountTotal >= 0 ? d.processCountTotal : nTop;
        set('kpi-proc', String(nTop));
        const kpiMeta = document.getElementById('kpi-proc-meta');
        if (kpiMeta) {
          let sub = '';
          if (nTot > nTop) sub = `de ${nTot} en el host · top CPU`;
          else if (nTot) sub = `${nTot} visibles · top CPU`;
          else if (nTop) sub = `${nTop} en lista · top CPU`;
          kpiMeta.textContent = sub;
        }
        set('kpi-svc', String((d.services||[]).length));
        set('kpi-ctnr', String((d.containers||[]).length));

        // Status bars
        ($('bar-cpu') as HTMLElement).style.width = `${cpu}%`;
        ($('bar-cpu') as HTMLElement).style.background = statusColor(cpu, 'cpu');
        $('bar-cpu-val').textContent = `${Math.round(cpu)}%`;
        ($('bar-mem') as HTMLElement).style.width = `${mem}%`;
        ($('bar-mem') as HTMLElement).style.background = statusColor(mem, 'mem');
        $('bar-mem-val').textContent = `${Math.round(mem)}%`;
        ($('bar-disk') as HTMLElement).style.width = `${disk}%`;
        ($('bar-disk') as HTMLElement).style.background = statusColor(disk, 'disk');
        $('bar-disk-val').textContent = `${Math.round(disk)}%`;

        // Health pct
        const avg = Math.round(100 - (cpu + mem + disk) / 3);
        set('health-pct', `${Math.max(0, avg)}%`);

        const hostOsEl = document.getElementById('activity-host-os');
        if (hostOsEl) {
          const plat = d.platform === 'win32' ? 'Windows' : d.platform === 'darwin' ? 'macOS' : d.platform === 'linux' ? 'Linux' : (d.platform || '');
          const label = d.hostOs || plat || '';
          if (label) {
            hostOsEl.textContent = `Host API · ${label}`;
            hostOsEl.removeAttribute('hidden');
          } else {
            hostOsEl.textContent = '';
            hostOsEl.setAttribute('hidden', '');
          }
        }

        // Uptime chart
        if (uptimeChart?.canvas?.isConnected) {
          const pct = Math.min(100, Math.max(0, 100 - cpu * 0.3));
          uptimeChart.data.datasets[0].data = [pct, 100 - pct];
          uptimeChart.data.datasets[0].backgroundColor = ['#F5C542', themeTrack()];
          (uptimeChart as any)._centerValue = pct;
          uptimeChart.update('none');
        }

        // Información del sistema: valor compacto + tooltip (hover/focus) con texto completo y copiar
        const dev = typeof d.deviceName === 'string' && d.deviceName.trim() ? d.deviceName.trim() : '';
        const hostOsStr =
          typeof d.hostOs === 'string' && d.hostOs.trim() ? d.hostOs.trim() : '—';
        const ips = Array.isArray(d.hostIpv4) ? d.hostIpv4.filter((x: unknown) => typeof x === 'string' && x.trim()) : [];
        const locals = ips.join(', ');
        const pub = String(d.publicIp || '').trim();
        const ipFull =
          pub && locals
            ? `Pública: ${pub} · Locales: ${locals}`
            : pub
              ? `Pública: ${pub}`
              : locals || '—';
        const ipFace = pub || locals || '—';

        const ramStr = `${d.memUsed} / ${d.memTotal} GiB`;
        const diskTotal = typeof d.diskTotal === 'number' && d.diskTotal > 0 ? d.diskTotal : 0;
        const diskStr =
          diskTotal > 0 ? `${d.diskUsed} / ${d.diskTotal} GiB` : `${d.diskUsed} GiB usado`;

        setDashSysTip('sys-device', 'sys-device-tip', dev || d.hostname || '—', dev || d.hostname || '—');
        setDashSysTip('sys-host', 'sys-host-tip', d.hostname || '—', d.hostname || '—');
        setDashSysTip('sys-os', 'sys-os-tip', hostOsStr, hostOsStr);
        setDashSysTip('sys-ipv4', 'sys-ipv4-tip', ipFace, ipFull);
        setDashSysTip('sys-cpu-model', 'sys-cpu-model-tip', d.cpuModel || '—', d.cpuModel || '—', 30);
        setDashSysTip('sys-cpu-cores', 'sys-cpu-cores-tip', String(d.cpuCores ?? '—'), String(d.cpuCores ?? '—'));
        setDashSysTip('sys-mem-used', 'sys-mem-used-tip', ramStr, ramStr);
        setDashSysTip('sys-disk-used', 'sys-disk-used-tip', diskStr, diskStr);
        const upOk = hasValidSystemUptime(d.uptime);
        const upStr = upOk ? fmtUptime(Number(d.uptime)) : '';
        set('sys-uptime', upStr || '—');

        const pn = $('profile-name') as HTMLElement;
        const pnm = dev || d.hostname || resolveBichiBrand().appName;
        pn.textContent = pnm;
        pn.classList.add('js-copy-val');
        pn.dataset.copyText = pnm;
        pn.title = `Clic para copiar · ${pnm}`;
        const pu = $('profile-uptime') as HTMLElement;
        if (upOk) {
          pu.textContent = upStr;
          pu.removeAttribute('hidden');
        } else {
          pu.textContent = '';
          pu.setAttribute('hidden', '');
        }
        pu.classList.remove('skeleton', 'profile-uptime-line');
        $('profile-role').classList.remove('profile-role--boot');
        $('profile-badge').classList.remove('profile-badge--boot');
        unlockProfileCard();

        // Render lists
        renderProcs(d.topCpu);
        renderSvcs(d.services);
        renderCtrs(d.containers);
        renderWarns(d.warnings);
        renderDashAlerts(d);
        setAlertsBadgeCount(countUndismissedAlertsFromMetrics(d));

        const total = (d.topCpu||[]).length + (d.services||[]).length;
        const running = (d.services||[]).filter((s: any) => s.running).length + (d.topCpu||[]).length;
        $('activity-count').textContent = `${running}/${total}`;

        prevCpu = cpu;
        void bichiCronRefresh?.();
      } catch (e) {
        console.error('Metrics error', e);
        lastMetricsForAlerts = null;
        const hostOsErr = document.getElementById('activity-host-os');
        if (hostOsErr) {
          hostOsErr.textContent = '';
          hostOsErr.setAttribute('hidden', '');
        }
        unlockProfileCard();
        const pnErr = $('profile-name');
        if (pnErr.querySelector?.('.profile-name-filler')) {
          pnErr.textContent = resolveBichiBrand().appName;
        }
        const puErr = $('profile-uptime') as HTMLElement;
        puErr.classList.remove('skeleton', 'profile-uptime-line');
        puErr.textContent = '';
        puErr.setAttribute('hidden', '');
        $('profile-role').classList.remove('profile-role--boot');
        $('profile-badge').classList.remove('profile-badge--boot');
        renderDashAlerts(null);
        setAlertsBadgeCount(0);
        $('proc-list').removeAttribute('aria-busy');
        $('svc-list').removeAttribute('aria-busy');
        $('ctnr-list').removeAttribute('aria-busy');
        $('warn-list').removeAttribute('aria-busy');
        $('proc-list').innerHTML = '<div class="act-empty">Sin conexión a la API</div>';
        $('svc-list').innerHTML = '<div class="act-empty">Sin conexión a la API</div>';
        $('ctnr-list').innerHTML = '<div class="act-empty">Sin conexión a la API</div>';
        $('warn-list').innerHTML = '<div class="act-empty">Sin conexión a la API</div>';
      }
      finally {
        btn?.classList.remove('spinning');
      }
    }

    let metricsPoll: ReturnType<typeof setInterval> | null = null;

    function mountDashboardMetrics() {
      if (!document.getElementById('refresh-btn')) return;
      applyBichiBrandToDocument();
      createUptimeChart();
      if (metricsPoll) clearInterval(metricsPoll);
      wireDashSysTips();
      initCopyableValues(document.body);
      load();
      metricsPoll = setInterval(load, 12000);
    }

    document.body.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('#refresh-btn')) load();
    });

    document.getElementById('dash-alerts-list')?.addEventListener('click', (e) => {
      const t = e.target as HTMLElement;
      if (!t.closest('.dash-alert-dismiss')) return;
      const li = t.closest('[data-alert-id]');
      const id = li?.getAttribute('data-alert-id');
      if (id) rememberDismissedAlertId(id);
      if (lastMetricsForAlerts) {
        renderDashAlerts(lastMetricsForAlerts);
        setAlertsBadgeCount(countUndismissedAlertsFromMetrics(lastMetricsForAlerts));
      }
    });

    mountDashboardMetrics();

    /* ═══ CRON CALENDAR (crontab real) ═══ */
    const MONTHS = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
    const DAYS = ['Lun','Mar','Mié','Jue','Vie','Sáb','Dom'];
    let calYear: number, calMonth: number, selectedDate = '';
    let cronJobs: SystemCronJob[] = [];
    let cronDates: Record<string, string[]> = {};
    let cronHint: string | null = null;
    let cronPlatform = '';
    let cronLoadError: string | null = null;

    function fmtCronPlatform(p: string): string {
      if (p === 'win32') return 'Windows';
      if (p === 'darwin') return 'macOS';
      if (p === 'linux') return 'Linux';
      if (p === 'freebsd') return 'FreeBSD';
      return p || 'desconocido';
    }

    function cronSourceLabel(source: string): string {
      const winLabel = cronPlatform === 'win32' ? 'Tareas del programador (Windows)' : 'Programador del sistema';
      const m: Record<string, string> = {
        user: 'Crontab del usuario',
        system: '/etc/crontab',
        extra: 'Fichero extra (p. ej. cron.extra)',
        windows: winLabel,
      };
      return m[source] || source;
    }

    function renderCronMasterList() {
      const el = document.getElementById('cron-master-list');
      if (!el) return;
      if (cronLoadError) {
        el.innerHTML = '';
        return;
      }
      if (!cronJobs.length) {
        const msg = cronHint || 'No hay entradas en las fuentes que la API puede leer.';
        el.innerHTML = `<div class="cron-master-empty">${escHtml(msg)}</div>`;
        return;
      }
      const kindLabel: Record<string, string> = { daily: 'Diario', weekly: 'Semanal', monthly: 'Mensual', custom: 'Otro' };
      el.innerHTML = `<ul class="cron-master-ul">${cronJobs
        .map(
          (j) => `<li class="cron-master-item">
          <div class="cron-master-row">
            <span class="cron-master-src">${escHtml(cronSourceLabel(j.source))}</span>
            <span class="cron-master-kind">${escHtml(kindLabel[j.kind] || j.kind)}</span>
          </div>
          <code class="cron-master-sched">${escHtml(j.schedule)}</code>
          ${j.user ? `<div class="cron-master-user">${escHtml(j.user)}</div>` : ''}
          <div class="cron-master-cmd">${escHtml(j.command || '—')}</div>
        </li>`,
        )
        .join('')}</ul>`;
    }

    function updateCronChrome() {
      const bar = document.getElementById('cron-status-bar');
      if (!bar) return;
      if (cronLoadError) {
        bar.innerHTML = `<span class="cron-status cron-status--err">${escHtml(cronLoadError)} · comprueba la API y el proxy <code>/api/cron</code>.</span>`;
        return;
      }
      const pl = fmtCronPlatform(cronPlatform);
      const extra =
        cronHint && !cronJobs.length ? ` <span class="cron-status-hint">${escHtml(cronHint)}</span>` : '';
      bar.innerHTML = `<span class="cron-status cron-status--ok"><strong>${escHtml(pl)}</strong> · <strong>${cronJobs.length}</strong> tarea(s) cargadas.${extra}</span>`;
    }

    function fmtCal(d: Date): string {
      return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
    }

    function jobsForCronDate(ds: string): SystemCronJob[] {
      const ids = cronDates[ds] || [];
      const m = new Map(cronJobs.map(j => [j.id, j]));
      return ids.map(id => m.get(id)).filter(Boolean) as SystemCronJob[];
    }

    async function refreshCronCalendar() {
      if (!document.getElementById('cal-grid')) return;
      try {
        const data = await fetchCronCalendar(calYear, calMonth + 1);
        cronLoadError = null;
        cronJobs = data.jobs;
        cronDates = data.dates;
        cronHint = data.hint ?? null;
        cronPlatform = data.platform || '';
      } catch {
        cronLoadError = 'No se pudo cargar /api/cron';
        cronJobs = [];
        cronDates = {};
        cronHint = null;
        cronPlatform = '';
      }
      updateCronChrome();
      renderCronMasterList();
      renderCal();
    }

    function initCal() {
      const now = new Date();
      calYear = now.getFullYear();
      calMonth = now.getMonth();
      selectedDate = fmtCal(now);
      bichiCronRefresh = refreshCronCalendar;
      void refreshCronCalendar();
    }

    function renderCal() {
      if (!document.getElementById('cal-grid')) return;
      $('cal-month-label').textContent = `${MONTHS[calMonth]} ${calYear}`;

      const firstDay = new Date(calYear, calMonth, 1);
      const lastDay = new Date(calYear, calMonth + 1, 0);
      let startDow = firstDay.getDay() - 1;
      if (startDow < 0) startDow = 6;

      const today = fmtCal(new Date());

      let html = DAYS.map(d => `<div class="cal-full-header">${d}</div>`).join('');

      const prevLast = new Date(calYear, calMonth, 0);
      for (let i = startDow - 1; i >= 0; i--) {
        const day = prevLast.getDate() - i;
        const d = new Date(calYear, calMonth - 1, day);
        const ds = fmtCal(d);
        const jobs = jobsForCronDate(ds);
        html += `<div class="cal-cell other-month" data-date="${ds}">
          <div class="cal-cell-date">${day}</div>
          ${renderDots(jobs)}
        </div>`;
      }

      for (let day = 1; day <= lastDay.getDate(); day++) {
        const d = new Date(calYear, calMonth, day);
        const ds = fmtCal(d);
        const isToday = ds === today;
        const isSel = ds === selectedDate;
        const jobs = jobsForCronDate(ds);
        html += `<div class="cal-cell${isToday?' today':''}${isSel?' selected':''}" data-date="${ds}">
          <div class="cal-cell-date">${day}</div>
          ${renderDots(jobs)}
        </div>`;
      }

      const totalCells = startDow + lastDay.getDate();
      const remaining = (7 - (totalCells % 7)) % 7;
      for (let day = 1; day <= remaining; day++) {
        const d = new Date(calYear, calMonth + 1, day);
        const ds = fmtCal(d);
        const jobs = jobsForCronDate(ds);
        html += `<div class="cal-cell other-month" data-date="${ds}">
          <div class="cal-cell-date">${day}</div>
          ${renderDots(jobs)}
        </div>`;
      }

      $('cal-grid').innerHTML = html;

      document.querySelectorAll('.cal-cell').forEach(cell => {
        cell.addEventListener('click', () => {
          selectedDate = (cell as HTMLElement).dataset.date!;
          document.querySelectorAll('.cal-cell').forEach(c => c.classList.remove('selected'));
          cell.classList.add('selected');
          renderCronSidebar();
        });
      });

      renderCronSidebar();
    }

    function renderDots(jobs: SystemCronJob[]): string {
      if (!jobs.length) return '';
      const kinds = new Set(jobs.map(j => j.kind));
      const dots = [...kinds].slice(0, 4).map(k => `<span class="cal-dot ${k}"></span>`).join('');
      return `<div class="cal-cell-dots">${dots}</div>`;
    }

    function renderCronSidebar() {
      if (!selectedDate || !document.getElementById('cron-jobs-list')) return;
      const d = new Date(selectedDate + 'T12:00:00');
      const dayName = d.toLocaleDateString('es-ES', { weekday: 'long', day: 'numeric', month: 'long' });
      $('cron-date-title').textContent = dayName.charAt(0).toUpperCase() + dayName.slice(1);

      const jobs = jobsForCronDate(selectedDate);
      const el = $('cron-jobs-list');

      if (!jobs.length) {
        const msg =
          cronHint && !cronJobs.length
            ? cronHint
            : 'Ninguna de las tareas cargadas coincide con este día en el calendario (revisa la expresión o el mes).';
        el.innerHTML = `<div class="cron-sidebar-empty">${escHtml(msg)}</div>`;
        return;
      }

      const srcLabel: Record<string, string> = {
        user: 'Crontab usuario',
        system: '/etc/crontab',
        extra: 'Fichero extra',
        windows: cronPlatform === 'win32' ? 'Tareas programadas' : 'Programador del SO',
      };
      const kindLabel: Record<string, string> = { daily: 'Diario', weekly: 'Semanal', monthly: 'Mensual', custom: 'Otro' };
      el.innerHTML = jobs.map(j => `
        <div class="cron-job-item" data-id="${j.id}">
          <div class="cron-job-body">
            <div class="cron-job-top">
              <span class="cron-job-name">${escHtml(srcLabel[j.source] || j.source)}</span>
              <span class="cron-job-freq">${escHtml(kindLabel[j.kind] || j.kind)}</span>
            </div>
            <div class="cron-job-meta"><code style="font-size:11px;word-break:break-all;opacity:.9">${escHtml(j.schedule)}</code>${j.user ? ` · <span style="opacity:.85">${escHtml(j.user)}</span>` : ''}</div>
            <div class="cron-job-cmd">${escHtml(j.command)}</div>
          </div>
        </div>
      `).join('');
    }

    document.getElementById('cal-prev')?.addEventListener('click', () => {
      calMonth--;
      if (calMonth < 0) { calMonth = 11; calYear--; }
      void refreshCronCalendar();
    });
    document.getElementById('cal-next')?.addEventListener('click', () => {
      calMonth++;
      if (calMonth > 11) { calMonth = 0; calYear++; }
      void refreshCronCalendar();
    });

    initCal();
  </script>
</Layout>
