---
import Layout from '../layouts/Layout.astro';
import SistemaSectionTabs from '../components/SistemaSectionTabs.astro';
import { iconToSvg } from '../lib/lucide-svg-string';
import { Settings, RefreshCw } from 'lucide';

const iRefresh = iconToSvg(RefreshCw, { width: 16, height: 16 });
const iPageTitle = iconToSvg(Settings, { width: 22, height: 22 });
---
<Layout activePage="servicios">
  <div class="wrapper dk-page">
    <span class="page-header__watermark" set:html={iPageTitle} aria-hidden="true" />
    <div class="page-header">
      <div class="dk-page-title-row">
        <div>
          <h2 class="page-title">Servicios</h2>
          <p class="page-desc">
            Datos reales del host: <strong>Linux</strong> (systemctl), <strong>Windows</strong> (PowerShell Start/Stop/Restart-Service), <strong>macOS/BSD</strong> (lista
            heurística; las acciones de servicio suelen no aplicar). Puedes iniciar, detener o reiniciar con confirmación. Personaliza con
            <code>BICHI_SERVICES</code> y <code>BICHI_SERVICES_MAX</code> en la API. Si defines token en el servidor, la petición debe incluir la misma cabecera que en ajustes.
          </p>
        </div>
      </div>
    </div>

    <SistemaSectionTabs active="servicios" />

    <div class="page-toolbar">
      <input type="text" class="page-search" id="svc-search" placeholder="Buscar servicio..." />
      <button type="button" class="page-filter-btn active" data-filter="all">Todos</button>
      <button type="button" class="page-filter-btn" data-filter="active">Activos</button>
      <button type="button" class="page-filter-btn" data-filter="inactive">Inactivos</button>
      <button
        type="button"
        class="page-icon-btn"
        id="svc-refresh"
        aria-label="Actualizar servicios"
        title="Volver a cargar servicios desde la API"
      >
        <span set:html={iRefresh} aria-hidden="true" />
      </button>
    </div>

    <div class="page-stat-strip" id="svc-stats">
      <div class="page-stat"><span class="page-stat-value skeleton" id="ss-total">—</span><span class="page-stat-label">Total</span></div>
      <div class="page-stat"><span class="page-stat-value skeleton" id="ss-active">—</span><span class="page-stat-label">Activos</span></div>
      <div class="page-stat"><span class="page-stat-value skeleton" id="ss-running">—</span><span class="page-stat-label">Ejecutando</span></div>
      <div class="page-stat"><span class="page-stat-value skeleton" id="ss-stopped">—</span><span class="page-stat-label">Detenidos</span></div>
    </div>

    <div class="svc-fallback-note" id="svc-fallback-note" hidden></div>

    <div class="card-grid card-grid--svc" id="svc-grid" aria-busy="true">
      <span class="sr-only">Obteniendo servicios del sistema</span>
      {[1, 2, 3, 4].map(() => (
        <div class="info-card info-card--skel" aria-hidden="true">
          <div class="info-card-header">
            <span class="skeleton info-card-skel-icon">&nbsp;</span>
            <div class="info-card-skel-lines">
              <span class="skeleton info-card-skel-line">&nbsp;</span>
              <span class="skeleton info-card-skel-line info-card-skel-line--sm">&nbsp;</span>
            </div>
          </div>
          <span class="skeleton info-card-skel-body">&nbsp;</span>
          <div class="info-card-skel-pills">
            <span class="skeleton info-card-skel-pill">&nbsp;</span>
            <span class="skeleton info-card-skel-pill">&nbsp;</span>
          </div>
        </div>
      ))}
    </div>

    <div
      class="dk-modal"
      id="svc-modal"
      role="dialog"
      aria-modal="true"
      aria-labelledby="svc-modal-title"
      aria-hidden="true"
      hidden
    >
      <div class="dk-modal__backdrop" tabindex="-1" aria-hidden="true"></div>
      <div class="dk-modal__panel">
        <h3 class="dk-modal__title" id="svc-modal-title"></h3>
        <p class="dk-modal__body" id="svc-modal-body"></p>
        <pre class="dk-modal__detail" id="svc-modal-detail" hidden></pre>
        <div class="dk-modal__actions">
          <button type="button" class="dk-modal__btn dk-modal__btn--ghost" id="svc-modal-cancel">Cancelar</button>
          <button type="button" class="dk-modal__btn dk-modal__btn--primary" id="svc-modal-confirm">Confirmar</button>
        </div>
      </div>
    </div>
  </div>

  <script>
    import { fetchMetrics, updateHeader, metricsRepresentHost, apiPostHost } from '../lib/metrics';
    import { escHtml, serviceCatalogHint, isBoilerplateServiceDesc } from '../lib/process-hints';
    import { iconToSvg } from '../lib/lucide-svg-string';
    import { Play, Square, RotateCw, Copy, Terminal, ChevronDown, Activity, CircleDot, Circle, Info } from 'lucide';

    const iSvcActiveOn = iconToSvg(CircleDot, { width: 10, height: 10, 'stroke-width': 2 });
    const iSvcActiveOff = iconToSvg(Circle, { width: 10, height: 10, 'stroke-width': 1.65 });
    const iSvcRun = iconToSvg(Activity, { width: 12, height: 12, 'stroke-width': 2 });
    const iSvcStopped = iconToSvg(Square, { width: 10, height: 10, 'stroke-width': 2 });
    const iPlay = iconToSvg(Play, { width: 18, height: 18 });
    const iStop = iconToSvg(Square, { width: 18, height: 18 });
    const iRestart = iconToSvg(RotateCw, { width: 18, height: 18 });
    const iCopyCli = iconToSvg(Copy, { width: 16, height: 16 });
    const iOpenTerm = iconToSvg(Terminal, { width: 16, height: 16 });
    const iChevDown = iconToSvg(ChevronDown, { width: 14, height: 14, 'stroke-width': 2 });
    const iSvcDesc = iconToSvg(Info, { width: 12, height: 12, 'stroke-width': 2 });
    const $ = (id: string) => document.getElementById(id)!;
    let allSvcs: any[] = [];
    let filter = 'all';
    let dataLoaded = false;
    let lastPlatform = '';
    let lastSvcHost: {
      service?: {
        mode?: string;
        hint?: string;
        cliStopTemplate?: string;
        cliStartTemplate?: string;
        cliRestartTemplate?: string;
        cliNote?: string;
        openTerminal?: string;
        openTerminalHelp?: string;
      };
    } | null = null;
    let svcModalResolve: ((v: 'confirm' | 'cancel') => void) | null = null;
    let svcModalPrevFocus: HTMLElement | null = null;
    let svcModalKeyHandler: ((e: KeyboardEvent) => void) | null = null;
    let svcActionInFlight = false;

    function svcModalDetachKeys() {
      if (svcModalKeyHandler) {
        document.removeEventListener('keydown', svcModalKeyHandler);
        svcModalKeyHandler = null;
      }
    }

    function svcModalClose(result: 'confirm' | 'cancel') {
      const root = $('svc-modal');
      root.hidden = true;
      root.setAttribute('aria-hidden', 'true');
      document.body.classList.remove('dk-modal-open');
      svcModalDetachKeys();
      const r = svcModalResolve;
      svcModalResolve = null;
      try {
        svcModalPrevFocus?.focus();
      } catch {
        /* ignore */
      }
      svcModalPrevFocus = null;
      r?.(result);
    }

    function initSvcModal() {
      const root = $('svc-modal');
      if ((root as HTMLElement & { _bichiInit?: boolean })._bichiInit) return;
      (root as HTMLElement & { _bichiInit?: boolean })._bichiInit = true;
      $('svc-modal-confirm').addEventListener('click', () => svcModalClose('confirm'));
      $('svc-modal-cancel').addEventListener('click', () => svcModalClose('cancel'));
      root.querySelector('.dk-modal__backdrop')?.addEventListener('click', () => svcModalClose('cancel'));
    }

    function svcModalOpen(opts: {
      mode: 'confirm' | 'alert';
      title: string;
      body: string;
      detail?: string;
      variant?: 'default' | 'danger';
      confirmLabel?: string;
      cancelLabel?: string;
    }): Promise<'confirm' | 'cancel'> {
      initSvcModal();
      return new Promise((resolve) => {
        svcModalResolve = resolve;
        svcModalPrevFocus = document.activeElement as HTMLElement;
        const root = $('svc-modal');
        root.dataset.mode = opts.mode;
        root.dataset.variant = opts.variant || 'default';
        $('svc-modal-title').textContent = opts.title;
        $('svc-modal-body').textContent = opts.body;
        const det = $('svc-modal-detail');
        if (opts.detail) {
          det.textContent = opts.detail;
          det.hidden = false;
        } else {
          det.textContent = '';
          det.hidden = true;
        }
        const cancelBtn = $('svc-modal-cancel') as HTMLButtonElement;
        const confirmBtn = $('svc-modal-confirm') as HTMLButtonElement;
        cancelBtn.hidden = opts.mode === 'alert';
        confirmBtn.textContent = opts.confirmLabel || (opts.mode === 'alert' ? 'Entendido' : 'Confirmar');
        cancelBtn.textContent = opts.cancelLabel || 'Cancelar';
        root.hidden = false;
        root.setAttribute('aria-hidden', 'false');
        document.body.classList.add('dk-modal-open');
        svcModalKeyHandler = (ev: KeyboardEvent) => {
          if (ev.key !== 'Escape') return;
          ev.preventDefault();
          svcModalClose(opts.mode === 'alert' ? 'confirm' : 'cancel');
        };
        document.addEventListener('keydown', svcModalKeyHandler);
        confirmBtn.focus();
      });
    }

    async function svcModalConfirm(opts: {
      title: string;
      body: string;
      detail?: string;
      variant?: 'default' | 'danger';
      confirmLabel?: string;
      cancelLabel?: string;
    }): Promise<boolean> {
      const r = await svcModalOpen({ ...opts, mode: 'confirm' });
      return r === 'confirm';
    }

    async function svcModalAlert(opts: { title: string; body: string; detail?: string }) {
      await svcModalOpen({
        mode: 'alert',
        variant: 'default',
        title: opts.title,
        body: opts.body,
        detail: opts.detail,
        confirmLabel: 'Entendido',
      });
    }

    function attrEsc(s: string) {
      return String(s).replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;');
    }

    function quoteSvcName(name: string) {
      if (lastPlatform === 'win32') return "'" + String(name).replace(/'/g, "''") + "'";
      return "'" + String(name).replace(/'/g, "'\\''") + "'";
    }

    function buildSvcCliCommands(rawName: string, running: boolean) {
      const svc = lastSvcHost?.service;
      if (!svc?.cliStopTemplate || !svc.cliStartTemplate) return '';
      const q = quoteSvcName(rawName);
      const stop = svc.cliStopTemplate.replace(/\{\{name\}\}/g, q);
      const start = svc.cliStartTemplate.replace(/\{\{name\}\}/g, q);
      const restart = (svc.cliRestartTemplate || '').replace(/\{\{name\}\}/g, q);
      if (running) {
        return restart ? `${stop}\n# o reiniciar:\n${restart}` : stop;
      }
      return start;
    }

    async function load() {
      try {
        const d = await fetchMetrics();
        updateHeader(d);
        lastPlatform = String(d.platform || '');
        lastSvcHost = d.hostActions && typeof d.hostActions === 'object' ? d.hostActions : null;
        if (!metricsRepresentHost(d)) {
          $('svc-grid').removeAttribute('aria-busy');
          const note =
            typeof d.hostMetricsNote === 'string' && d.hostMetricsNote.trim()
              ? d.hostMetricsNote.trim()
              : 'Con la API en contenedor sin datos del equipo no listamos servicios del host. Usa bun run deploy.';
          $('svc-grid').innerHTML = `<div class="page-empty" style="white-space:pre-line">${escHtml(note)}</div>`;
          dataLoaded = false;
          updateSvcFallbackNote();
          return;
        }
        allSvcs = d.services || [];

        const set = (id: string, v: string) => { const e = $(id); e.textContent = v; e.classList.remove('skeleton'); };
        set('ss-total', String(allSvcs.length));
        set('ss-active', String(allSvcs.filter((s: any) => s.active).length));
        set('ss-running', String(allSvcs.filter((s: any) => s.running).length));
        set('ss-stopped', String(allSvcs.filter((s: any) => !s.running).length));

        dataLoaded = true;
        render();
      } catch (e) {
        console.error(e);
        $('svc-grid').removeAttribute('aria-busy');
        $('svc-grid').innerHTML =
          '<div class="page-empty">No se pudieron cargar los servicios (¿API en marcha?)</div>';
        dataLoaded = false;
        updateSvcFallbackNote();
      }
    }

    function serviceActionsAvailable() {
      const m = lastSvcHost?.service?.mode;
      return m === 'systemd' || m === 'windows';
    }

    function updateSvcFallbackNote() {
      const fn = $('svc-fallback-note');
      if (!dataLoaded) {
        fn.hidden = true;
        fn.innerHTML = '';
        return;
      }
      const cliNote = String(lastSvcHost?.service?.cliNote || '').trim();
      if (!serviceActionsAvailable() && cliNote) {
        fn.hidden = false;
        fn.innerHTML = `<p class="svc-fallback-note__text">${escHtml(cliNote)}</p>`;
      } else {
        fn.hidden = true;
        fn.innerHTML = '';
      }
    }

    function render() {
      updateSvcFallbackNote();
      if (!dataLoaded) return;
      $('svc-grid').removeAttribute('aria-busy');
      const search = ($('svc-search') as HTMLInputElement).value.toLowerCase();
      let filtered = allSvcs.filter((s: any) => (s.name || '').toLowerCase().includes(search));
      if (filter === 'active') filtered = filtered.filter((s: any) => s.active);
      if (filter === 'inactive') filtered = filtered.filter((s: any) => !s.active);

      if (!filtered.length) {
        $('svc-grid').innerHTML = '<div class="page-empty">Sin servicios encontrados</div>';
        return;
      }

      const ctlOk = serviceActionsAvailable();
      const hint = lastSvcHost?.service?.hint || '';

      $('svc-grid').innerHTML = filtered.map((s: any, i: number) => {
        const title = (s.name || '').replace(/\.service$/i, '').replace(/\.timer$/i, '');
        const descRaw = String(s.desc || '').trim();
        const catalogHint = serviceCatalogHint(s.name || '');
        const subText = descRaw && !isBoilerplateServiceDesc(descRaw) ? descRaw : '';
        let mergedDesc = '';
        if (catalogHint) mergedDesc = catalogHint;
        else if (subText) mergedDesc = subText;
        else if (descRaw && !isBoilerplateServiceDesc(descRaw)) mergedDesc = descRaw;
        const rawName = String(s.name || '');
        const enc = encodeURIComponent(rawName);
        const dis = svcActionInFlight ? 'disabled' : '';
        const cmdPreview = buildSvcCliCommands(rawName, !!s.running);
        const otHelp = lastSvcHost?.service?.openTerminalHelp || '';
        const runFlag = s.running ? '1' : '0';
        const actions = ctlOk
          ? `<div class="info-card-actions dk-card-actions" role="group" aria-label="Acciones del servicio">
              ${s.running
                ? `<button type="button" class="card-action-btn card-action-btn--stop" title="Detener servicio" aria-label="Detener servicio" data-svc-action="stop" data-svc-name="${enc}" ${dis}>${iStop}</button>
                   <button type="button" class="card-action-btn card-action-btn--restart" title="Reiniciar servicio" aria-label="Reiniciar servicio" data-svc-action="restart" data-svc-name="${enc}" ${dis}>${iRestart}</button>`
                : `<button type="button" class="card-action-btn card-action-btn--start" title="Iniciar servicio" aria-label="Iniciar servicio" data-svc-action="start" data-svc-name="${enc}" ${dis}>${iPlay}</button>`}
            </div>`
          : cmdPreview
            ? ''
            : `<div class="info-card-actions dk-card-actions"><span class="info-card-svc-hint">${escHtml(hint || 'Sin comandos')}</span></div>`;
        const cliToggleBtn = cmdPreview
          ? `<button type="button" class="svc-cli-toggle" data-svc-cli-toggle aria-expanded="false" aria-label="Mostrar comando de referencia" title="Comando de referencia" ${dis}>
              <span class="svc-cli-toggle__chev" aria-hidden="true">${iChevDown}</span>
            </button>`
          : '';
        const cliPanelHtml = cmdPreview
          ? `<div class="svc-cli-panel" hidden data-svc-cli-panel>
              <pre class="svc-cli-snippet">${escHtml(cmdPreview)}</pre>
              <div class="svc-cli-fallback__toolbar">
                <button type="button" class="card-action-btn svc-cli-icon-btn" data-svc-copy-cli data-svc-name="${enc}" data-svc-running="${runFlag}" aria-label="Copiar comando" title="Copiar comando" ${dis}>${iCopyCli}</button>
                <button type="button" class="card-action-btn svc-cli-icon-btn" data-svc-open-terminal ${dis} aria-label="Abrir consola" title="${attrEsc(otHelp)}">${iOpenTerm}</button>
              </div>
            </div>`
          : '';
        const descBlock = mergedDesc
          ? `<div class="info-card-svc-desc"><span class="info-card-svc-desc__icon" aria-hidden="true">${iSvcDesc}</span><span class="info-card-svc-desc__txt">${escHtml(mergedDesc)}</span></div>`
          : `<div class="info-card-svc-desc info-card-svc-desc--empty" role="note" aria-label="Sin descripción adicional"><span class="info-card-svc-desc__icon" aria-hidden="true">${iSvcDesc}</span></div>`;
        const runLabel = s.running ? 'Ejecutando' : 'Detenido';
        const actLabel = s.active ? 'Activo' : 'Inactivo';
        const runIcon = s.running ? iSvcRun : iSvcStopped;
        const activeIcon = s.active ? iSvcActiveOn : iSvcActiveOff;
        return `
        <div class="info-card info-card--svc" style="animation:listSlideIn 0.3s ease ${i * 30}ms both">
          <div class="info-card-header info-card-header--svc">
            <div class="info-card-svc-top">
              <div class="info-card-svc-text">
                <div class="info-card-title">${escHtml(title)}</div>
                ${descBlock}
              </div>
              <div class="info-card-svc-meta" role="group" aria-label="${actLabel}, ${runLabel}">
                <span class="svc-status-active ${s.active ? 'svc-status-active--on' : 'svc-status-active--off'}" title="${actLabel}" aria-label="${actLabel}" role="status">${activeIcon}</span>
                <span class="svc-status-run ${s.running ? 'svc-status-run--on' : 'svc-status-run--off'}" title="${runLabel}" aria-label="${runLabel}" role="status">${runIcon}</span>
                ${cliToggleBtn}
              </div>
            </div>
          </div>
          ${cliPanelHtml}
          ${actions}
        </div>`;
      }).join('');
    }

    async function runSvcAction(action: 'start' | 'stop' | 'restart', name: string) {
      if (svcActionInFlight || !serviceActionsAvailable()) return;
      const verb =
        action === 'start' ? 'Iniciar' : action === 'stop' ? 'Detener' : 'Reiniciar';
      const ok = await svcModalConfirm({
        title: `${verb} servicio`,
        body: `Vas a ${verb.toLowerCase()} el servicio «${name}» en el host donde corre la API.`,
        detail:
          action === 'stop'
            ? 'Los clientes que dependan de este servicio pueden dejar de responder hasta que vuelva a iniciarse.'
            : undefined,
        variant: action === 'stop' ? 'danger' : 'default',
        confirmLabel: verb,
      });
      if (!ok) return;
      svcActionInFlight = true;
      render();
      try {
        const r = await apiPostHost('/api/host/service/action', { name, action });
        let j: { ok?: boolean; error?: string } = {};
        try {
          j = await r.json();
        } catch {
          j = { ok: false, error: r.status ? `HTTP ${r.status}` : 'Respuesta inválida' };
        }
        if (r.ok && j.ok) {
          await load();
        } else {
          await svcModalAlert({
            title: 'No se pudo completar',
            body: 'El sistema rechazó la operación (permisos, nombre de unidad, políticas).',
            detail: j.error || `HTTP ${r.status}`,
          });
        }
      } catch (e) {
        await svcModalAlert({
          title: 'Error de red',
          body: 'No se pudo contactar con la API de métricas.',
          detail: (e as Error).message,
        });
      } finally {
        svcActionInFlight = false;
        render();
      }
    }

    $('svc-grid').addEventListener('click', (ev) => {
      const cliTgl = (ev.target as HTMLElement).closest('[data-svc-cli-toggle]') as HTMLButtonElement | null;
      if (cliTgl && !svcActionInFlight) {
        ev.preventDefault();
        const card = cliTgl.closest('.info-card--svc');
        const panel = card?.querySelector('[data-svc-cli-panel]') as HTMLElement | null;
        if (!panel) return;
        const willOpen = panel.hidden;
        panel.hidden = !willOpen;
        cliTgl.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
        cliTgl.classList.toggle('is-open', willOpen);
        cliTgl.setAttribute(
          'aria-label',
          willOpen ? 'Ocultar comando de referencia' : 'Mostrar comando de referencia',
        );
        return;
      }
      const termBtn = (ev.target as HTMLElement).closest('[data-svc-open-terminal]') as HTMLButtonElement | null;
      if (termBtn && !svcActionInFlight) {
        ev.preventDefault();
        const line = String(lastSvcHost?.service?.openTerminal || '').trim();
        const help = String(lastSvcHost?.service?.openTerminalHelp || '').trim();
        void (async () => {
          try {
            if (line) await navigator.clipboard.writeText(line);
            await svcModalAlert({
              title: 'Abrir Terminal',
              body:
                help ||
                (line
                  ? 'Se copió en el portápapeles un comando para lanzar el terminal. Pégalo donde puedas ejecutarlo (Spotlight, otra consola, etc.).'
                  : 'Abre la aplicación Terminal desde el sistema y ejecuta manualmente el comando del servicio.'),
              detail: line || undefined,
            });
          } catch {
            await svcModalAlert({
              title: 'Terminal',
              body: 'No se pudo usar el portapapeles; copia manualmente el comando mostrado en la tarjeta.',
              detail: line || undefined,
            });
          }
        })();
        return;
      }
      const copyBtn = (ev.target as HTMLElement).closest('[data-svc-copy-cli]') as HTMLButtonElement | null;
      if (copyBtn && !svcActionInFlight) {
        ev.preventDefault();
        const encN = copyBtn.dataset.svcName || '';
        const running = copyBtn.dataset.svcRunning === '1';
        const name = decodeURIComponent(encN);
        const txt = buildSvcCliCommands(name, running);
        if (!txt) return;
        void navigator.clipboard.writeText(txt).then(() => {
          copyBtn.classList.add('is-copied');
          copyBtn.setAttribute('aria-label', 'Copiado');
          window.setTimeout(() => {
            copyBtn.classList.remove('is-copied');
            copyBtn.setAttribute('aria-label', 'Copiar comando');
          }, 1600);
        });
        return;
      }
      const btn = (ev.target as HTMLElement).closest('[data-svc-action]') as HTMLButtonElement | null;
      if (!btn || svcActionInFlight) return;
      const action = btn.dataset.svcAction as 'start' | 'stop' | 'restart';
      const enc = btn.dataset.svcName || '';
      if (!action || !enc) return;
      ev.preventDefault();
      const name = decodeURIComponent(enc);
      void runSvcAction(action, name);
    });

    $('svc-search').addEventListener('input', render);
    $('svc-refresh').addEventListener('click', load);

    document.querySelectorAll('[data-filter]').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('[data-filter]').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        filter = (btn as HTMLElement).dataset.filter!;
        render();
      });
    });

    load();
  </script>
</Layout>
