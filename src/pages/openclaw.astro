  <script>
    import { escHtml } from '../lib/process-hints';
    import { iconToSvg } from '../lib/lucide-svg-string';
    import {
      Activity,
      Box,
      CalendarClock,
      CalendarDays,
      CircleEllipsis,
      FolderOpen,
      Network,
      Package,
      Plug,
      Radio,
      Shield,
      Terminal,
      UserRound,
      Users,
    } from 'lucide';
    import {
      apiFetch,
      fetchMetrics,
      updateHeader,
      fmtUptime,
      hasValidSystemUptime,
      metricsRepresentHost,
    } from '../lib/metrics';
    import { resolveBichiBrand } from '../lib/brand-runtime';

    const $ = (id: string) => document.getElementById(id)!;

    const OC_PROBE_ICON = { width: 18, height: 18, 'stroke-width': 2 };
    const OC_HDR_ICON = { width: 20, height: 20, 'stroke-width': 2 };

    const OC_CARD_ICON = {
      install: iconToSvg(FolderOpen, OC_HDR_ICON),
      profile: iconToSvg(UserRound, OC_HDR_ICON),
      cronHost: iconToSvg(CalendarDays, OC_HDR_ICON),
    };

    const OC_SECTION_ICON_SVG: Record<string, string> = {
      'Núcleo y diagnóstico': iconToSvg(Activity, OC_HDR_ICON),
      Skills: iconToSvg(Package, OC_HDR_ICON),
      Agentes: iconToSvg(Users, OC_HDR_ICON),
      'Gateway y nodos': iconToSvg(Network, OC_HDR_ICON),
      'Canales, modelos y memoria': iconToSvg(Radio, OC_HDR_ICON),
      'Plugins, MCP y hooks': iconToSvg(Plug, OC_HDR_ICON),
      'OpenClaw: cron y tareas': iconToSvg(CalendarClock, OC_HDR_ICON),
      'Sandbox, pairing y aprobaciones': iconToSvg(Box, OC_HDR_ICON),
      Seguridad: iconToSvg(Shield, OC_HDR_ICON),
      'Otras sondas': iconToSvg(CircleEllipsis, OC_HDR_ICON),
    };

    const OC_MOCK_OUTPUT_ICON = iconToSvg(Terminal, OC_PROBE_ICON);

    const OC_FILL_DISMISS_LS = 'openclaw.fill.dismiss.v1';

    type OcDismissState = { agents: string[]; skills: string[]; installSkills: string[] };

    function loadOcDismiss(): OcDismissState {
      try {
        const raw = localStorage.getItem(OC_FILL_DISMISS_LS);
        if (!raw) return { agents: [], skills: [], installSkills: [] };
        const o = JSON.parse(raw) as Partial<OcDismissState>;
        return {
          agents: Array.isArray(o.agents) ? o.agents : [],
          skills: Array.isArray(o.skills) ? o.skills : [],
          installSkills: Array.isArray(o.installSkills) ? o.installSkills : [],
        };
      } catch {
        return { agents: [], skills: [], installSkills: [] };
      }
    }

    function saveOcDismiss(s: OcDismissState) {
      try {
        localStorage.setItem(OC_FILL_DISMISS_LS, JSON.stringify(s));
      } catch {
        /* ignore */
      }
    }

    function ocDismissSets() {
      const s = loadOcDismiss();
      return {
        agents: new Set(s.agents),
        skills: new Set(s.skills),
        installSkills: new Set(s.installSkills),
      };
    }

    function ocAgentRowId(a: { id?: string; label?: string }) {
      return `a:${String(a.id || '').trim() || String(a.label || '').trim() || '—'}`;
    }

    function ocSkillRowId(s: { name?: string; path?: string }) {
      return `s:${String(s.name || '').trim()}|${String(s.path || '').trim()}`;
    }

    function ocInstallSkillRowId(dir: string) {
      return `i:${String(dir || '').trim()}`;
    }

    function clearOcDismiss() {
      saveOcDismiss({ agents: [], skills: [], installSkills: [] });
    }

    function addOcDismiss(kind: string, id: string) {
      const s = loadOcDismiss();
      if (kind === 'agent') {
        if (!s.agents.includes(id)) s.agents.push(id);
      } else if (kind === 'skill') {
        if (!s.skills.includes(id)) s.skills.push(id);
      } else if (kind === 'install-skill') {
        if (!s.installSkills.includes(id)) s.installSkills.push(id);
      }
      saveOcDismiss(s);
    }

    let ocLastSnapshot: Record<string, unknown> | null = null;

    function summarizePathsFromInstall(il: unknown): Record<string, unknown> | null {
      if (!il || typeof il !== 'object') return null;
      const o = il as Record<string, unknown>;
      if (o.disabled) return { disabled: true, message: o.message };
      return {
        roots: o.roots ?? null,
        hasRealWorkspaceContent: o.hasRealWorkspaceContent,
        error: o.error,
      };
    }

    function buildOpenClawCloneBundle(snapshot: Record<string, unknown>, mode: 'profile' | 'full') {
      const exportedAt = new Date().toISOString();
      const source = {
        capturedAt: snapshot.at,
        available: snapshot.available,
        binary: snapshot.binary,
        mockMode: snapshot.mockMode,
      };
      if (mode === 'profile') {
        return {
          format: 'openclaw-system-clone',
          version: 1,
          exportedAt,
          mode: 'profile',
          description:
            'Personalidad, agentes, skills, estilo y workspace (openclawFill). Incluye rutas base del disco sin el contenido pesado de los ficheros.',
          source,
          openclawFill: snapshot.openclawFill ?? null,
          paths: summarizePathsFromInstall(snapshot.installLayout),
        };
      }
      return {
        format: 'openclaw-system-clone',
        version: 1,
        exportedAt,
        mode: 'full',
        description:
          'Snapshot amplio para replicar o auditar: perfil, lectura de disco de la API, sondas CLI y cron del host.',
        source,
        openclawFill: snapshot.openclawFill ?? null,
        installLayout: snapshot.installLayout ?? null,
        cronSystem: snapshot.cronSystem ?? null,
        probes: snapshot.probes ?? null,
        suppressDemoFill: snapshot.suppressDemoFill,
        message: snapshot.message,
        disabled: snapshot.disabled,
      };
    }

    function setOcCloneButtonsEnabled(on: boolean) {
      const p = document.getElementById('oc-clone-profile') as HTMLButtonElement | null;
      const f = document.getElementById('oc-clone-full') as HTMLButtonElement | null;
      if (p) p.disabled = !on;
      if (f) f.disabled = !on;
    }

    let ocCloneFeedbackTimer: ReturnType<typeof setTimeout> | null = null;
    function showCloneFeedback(msg: string, kind: 'ok' | 'err' = 'ok') {
      const el = document.getElementById('oc-clone-feedback');
      if (!el) return;
      el.textContent = msg;
      el.hidden = false;
      el.classList.toggle('oc-clone-feedback--err', kind === 'err');
      if (ocCloneFeedbackTimer) clearTimeout(ocCloneFeedbackTimer);
      ocCloneFeedbackTimer = setTimeout(() => {
        el.hidden = true;
        el.textContent = '';
        el.classList.remove('oc-clone-feedback--err');
        ocCloneFeedbackTimer = null;
      }, 4500);
    }

    async function syncDashboardProfile() {
      try {
        const d = await fetchMetrics();
        updateHeader(d);
        const pc = document.getElementById('card-profile');
        if (pc) {
          pc.classList.remove('profile-card--loading');
          pc.classList.add('profile-card--ready');
          pc.removeAttribute('aria-busy');
        }
        const hostOk = metricsRepresentHost(d);
        const openclaw =
          d && typeof d.openclawAvailable === 'boolean' ? d.openclawAvailable : false;
        const pn = document.getElementById('profile-name');
        if (pn) {
          const dev = typeof d.deviceName === 'string' && d.deviceName.trim() ? d.deviceName.trim() : '';
          const hn = typeof d.hostname === 'string' && d.hostname.trim() ? d.hostname.trim() : '';
          const sameAsHost = hn && dev.toLowerCase() === hn.toLowerCase();
          /* Sin CLI: solo guion. Con CLI: solo un nombre distinto del hostname (nunca hostname ni marca de la app). */
          if (!openclaw) {
            pn.textContent = '-';
          } else if (dev && !sameAsHost) {
            pn.textContent = dev;
          } else {
            pn.textContent = '-';
          }
          pn.classList.remove('skeleton');
        }
        const pr = document.getElementById('profile-role');
        if (pr) {
          if (!hostOk) {
            pr.textContent =
              'Métricas sin identidad de host (p. ej. API en contenedor). OpenClaw sigue pudiendo sondearse si configuras el binario.';
          } else if (openclaw) {
            pr.textContent = 'Host monitorizado · CLI OpenClaw disponible en la API';
          } else {
            pr.textContent =
              'Host monitorizado · OpenClaw por API (CLI no en PATH o sin binario; revisa OPENCLAW_BIN)';
          }
          pr.classList.remove('profile-role--boot');
        }
        const pu = document.getElementById('profile-uptime');
        if (pu) {
          if (hasValidSystemUptime(d.uptime)) pu.textContent = fmtUptime(Number(d.uptime));
          else pu.textContent = '—';
          pu.classList.remove('skeleton');
        }
        const pb = document.getElementById('profile-badge');
        if (pb) pb.classList.remove('profile-badge--boot');

        const meta = document.getElementById('openclaw-profile-meta');
        const hh = document.getElementById('oc-profile-host');
        const ho = document.getElementById('oc-profile-os');
        const hip = document.getElementById('oc-profile-ipv4');
        if (meta && hh && ho && hip) {
          if (hostOk) {
            meta.removeAttribute('hidden');
            const h = typeof d.hostname === 'string' && d.hostname.trim() ? d.hostname.trim() : '—';
            const osStr = typeof d.hostOs === 'string' && d.hostOs.trim() ? d.hostOs.trim() : '—';
            const ips = Array.isArray(d.hostIpv4)
              ? d.hostIpv4.filter((x: unknown) => typeof x === 'string' && x.trim())
              : [];
            hh.textContent = h;
            ho.textContent = osStr;
            hip.textContent = ips.length ? ips.join(', ') : '—';
            hh.classList.remove('skeleton');
            ho.classList.remove('skeleton');
            hip.classList.remove('skeleton');
          } else {
            meta.setAttribute('hidden', '');
          }
        }
      } catch {
        const pn = document.getElementById('profile-name');
        if (pn) {
          pn.textContent = '-';
          pn.classList.remove('skeleton');
        }
      }
    }

    function ocLoadingMarkup(): string {
      return `<div class="oc-bento-tile oc-bento-tile--full"><div class="card openclaw-loading-card" aria-hidden="true">
        <span class="skeleton openclaw-loading-line"></span>
        <span class="skeleton openclaw-loading-block"></span>
      </div></div>`;
    }

    const LABELS: Record<string, string> = {
      version: 'Versión CLI',
      status: 'Estado (status)',
      health: 'Salud (health)',
      directory: 'Directorio / árbol',
      skills_list: 'Skills — listado',
      skills_check: 'Skills — comprobación',
      agents_list: 'Agentes — listado',
      agents_bindings: 'Agentes — bindings',
      plugins_list: 'Plugins',
      channels_list: 'Canales — listado',
      channels_status: 'Canales — estado',
      cron_status: 'OpenClaw cron — estado',
      cron_list: 'OpenClaw cron — listado',
      tasks_list: 'Tareas',
      tasks_flow: 'Tareas — flows',
      gateway_status: 'Gateway — estado',
      gateway_health: 'Gateway — salud',
      gateway_probe: 'Gateway — probe',
      models_list: 'Modelos',
      memory_status: 'Memoria (índice)',
      mcp_list: 'MCP',
      hooks_list: 'Hooks',
      nodes: 'Nodos',
      devices_list: 'Dispositivos',
      pairing_list: 'Pairing',
      approvals_get: 'Aprobaciones',
      sandbox_list: 'Sandbox',
      config_file: 'Ruta de configuración',
      config_validate: 'Validación de config',
      security_audit: 'Auditoría de seguridad',
      doctor: 'Doctor (no interactivo)',
    };

    function renderFill(fill: any): string {
      if (!fill || typeof fill !== 'object') return '';
      const dismiss = ocDismissSets();
      const p = fill.personality;
      const agentsRaw = Array.isArray(fill.agentsPreview) ? fill.agentsPreview : [];
      const skillsRaw = Array.isArray(fill.skillsPreview) ? fill.skillsPreview : [];
      const agents = agentsRaw.filter((a: any) => !dismiss.agents.has(ocAgentRowId(a)));
      const skills = skillsRaw.filter((s: any) => !dismiss.skills.has(ocSkillRowId(s)));
      const ws = fill.workspace;
      const st = fill.style;
      const isLegacyDemo = !!fill.legacyDemo;
      const stDismiss = loadOcDismiss();
      const nHidden = stDismiss.agents.length + stDismiss.skills.length + stDismiss.installSkills.length;
      const note = fill.note ? `<p class="dash-sys-lede openclaw-lede">${escHtml(fill.note)}</p>` : '';
      const syntheticNote =
        !isLegacyDemo && fill.syntheticNote
          ? `<p class="openclaw-fill-synthetic-note" role="status">${escHtml(fill.syntheticNote)}</p>`
          : '';

      let personaBlock = '';
      let personaSummary = '';
      if (p && typeof p === 'object') {
        const traits = Array.isArray(p.traits) ? p.traits : [];
        const quirks = Array.isArray(p.quirks) ? p.quirks : [];
        const bounds = Array.isArray(p.boundaries) ? p.boundaries : [];
        const dn = p.displayName || '—';
        const roleFull = typeof p.role === 'string' ? p.role : '';
        personaSummary = `${escHtml(dn)}${roleFull ? ` · ${escHtml(roleFull)}` : ''}`;
        const traitChips = traits.length
          ? `<div class="openclaw-chip-row" aria-label="Rasgos">${traits.map((t: string) => `<span class="openclaw-chip">${escHtml(t)}</span>`).join('')}</div>`
          : '';
        const personaRows: string[] = [
          `<tr><th scope="row">Nombre</th><td>${escHtml(p.displayName || '—')}</td></tr>`,
          `<tr><th scope="row">Locale</th><td>${escHtml(p.locale || '—')}</td></tr>`,
          `<tr><th scope="row">Rol</th><td>${escHtml(p.role || '—')}</td></tr>`,
          `<tr><th scope="row">Tono</th><td>${escHtml(p.tone || '—')}</td></tr>`,
          `<tr><th scope="row">Voz</th><td>${escHtml(p.voice || '—')}</td></tr>`,
        ];
        if (traitChips) personaRows.push(`<tr><th scope="row">Rasgos</th><td>${traitChips}</td></tr>`);
        if (quirks.length)
          personaRows.push(
            `<tr><th scope="row">Manías</th><td>${quirks.map((t: string) => escHtml(t)).join(' · ')}</td></tr>`,
          );
        if (bounds.length)
          personaRows.push(
            `<tr><th scope="row">Límites</th><td>${bounds.map((t: string) => escHtml(t)).join(' · ')}</td></tr>`,
          );
        const promptBlock = p.systemPromptPreview
          ? `<details class="openclaw-fill-inline-details oc-chevron-disclosure"><summary><span class="oc-chevron-disclosure__lead">System prompt (vista previa)</span></summary><pre class="oc-pre oc-pre--tight">${escHtml(p.systemPromptPreview)}</pre></details>`
          : '';
        const personaMockHint =
          p.mock && !isLegacyDemo
            ? `<p class="oc-muted openclaw-fill-mock-hint" role="note">Simulación plausible: no se encontraron AGENTS.md / SOUL.md / IDENTITY.md con contenido en el workspace.</p>`
            : '';
        personaBlock = `${personaMockHint}<div class="openclaw-fs-table-wrap"><table class="openclaw-fill-table openclaw-fill-kv"><tbody>${personaRows.join('')}</tbody></table></div>${promptBlock}`;
      }

      const dismissBtn = (kind: string, id: string) =>
        `<td class="oc-oc-actions"><button type="button" class="oc-oc-dismiss" data-oc-dismiss="${escHtml(kind)}" data-oc-id="${escHtml(encodeURIComponent(id))}">Quitar</button></td>`;

      const agentsAllHidden =
        agentsRaw.length > 0 && agents.length === 0
          ? '<tr><td colspan="6" class="oc-muted">Todas las filas están ocultas. Usa <strong>Mostrar quitados</strong> arriba para recuperarlas.</td></tr>'
          : '';
      const agentsEmptyMsg = isLegacyDemo
        ? ''
        : '<tr><td colspan="6" class="oc-muted">Sin filas desde <code>agents list --json</code> (o JSON no reconocido). Detalle en la sección «Agentes».</td></tr>';
      const agentRows =
        agents.length > 0
          ? agents
              .map((a: any) => {
                const rowId = ocAgentRowId(a);
                const clsAttr = a.mock ? ' class="openclaw-fill-row--mock"' : '';
                const title = a.mock ? ' title="Vista de catálogo / sin CLI"' : '';
                const led = a.mock ? 'oc-oc-led oc-oc-led--ref' : 'oc-oc-led oc-oc-led--ok';
                const ledTxt = a.mock ? 'Referencia' : 'Activo';
                return `<tr${clsAttr}${title}>
            <td><span class="${led}">${escHtml(ledTxt)}</span></td>
            <td>${escHtml(a.label || a.id || '—')}</td>
            <td><code>${escHtml(String(a.id || '—'))}</code></td>
            <td class="oc-td-cmd">${escHtml(String(a.binding || '—'))}</td>
            <td>${escHtml(String(a.persona || '—'))}</td>
            ${dismissBtn('agent', rowId)}
          </tr>`;
              })
              .join('')
          : agentsAllHidden || agentsEmptyMsg;
      const agentsBlock = `<div class="openclaw-fs-table-wrap"><table class="openclaw-fill-table openclaw-fill-grid openclaw-fill-table--interactive">
          <thead><tr><th scope="col">Estado</th><th scope="col">Agente</th><th scope="col">ID</th><th scope="col">Binding</th><th scope="col">Persona</th><th scope="col" class="oc-oc-actions"> </th></tr></thead>
          <tbody>${agentRows}</tbody>
        </table></div>`;

      const skillsAllHidden =
        skillsRaw.length > 0 && skills.length === 0
          ? '<tr><td colspan="5" class="oc-muted">Todas las skills están ocultas. Pulsa <strong>Mostrar quitados</strong> para volver a verlas.</td></tr>'
          : '';
      const skillsEmptyMsg = isLegacyDemo
        ? '<tr><td colspan="5" class="oc-muted">Modo OPENCLAW_DEMO_FILL=1: usa la sección «Skills» para el listado de sondas.</td></tr>'
        : '<tr><td colspan="5" class="oc-muted">Sin skills desde <code>skills list --json</code> ni carpetas con SKILL.md en la ruta de skills del layout.</td></tr>';
      const skillRows =
        skills.length > 0
          ? skills
              .map((s: any) => {
                const rowId = ocSkillRowId(s);
                let ledClass = 'oc-oc-led oc-oc-led--ref';
                let ledTxt = 'Referencia';
                let pill = '<span class="oc-oc-pill oc-oc-pill--cat">Catálogo</span>';
                if (s.source === 'disk') {
                  pill = '<span class="oc-oc-pill oc-oc-pill--disk">Disco</span>';
                  if (s.hasSkillMd === true) {
                    ledClass = 'oc-oc-led oc-oc-led--ok';
                    ledTxt = 'En catálogo';
                  } else if (s.hasSkillMd === false) {
                    ledClass = 'oc-oc-led oc-oc-led--warn';
                    ledTxt = 'Incompleto';
                  } else {
                    ledTxt = 'En disco';
                  }
                } else if (s.source === 'cli') {
                  ledClass = 'oc-oc-led oc-oc-led--ok';
                  ledTxt = 'Registrada';
                  pill = '<span class="oc-oc-pill oc-oc-pill--cli">CLI</span>';
                }
                const clsAttrSk = s.source === 'mock' ? ' class="openclaw-fill-row--mock"' : '';
                const titleSk = s.source === 'mock' ? ' title="Entrada de catálogo (sin CLI o sin disco)"' : '';
                return `<tr${clsAttrSk}${titleSk}>
            <td><span class="${ledClass}">${escHtml(ledTxt)}</span></td>
            <td><span class="openclaw-fill-skill-name">${escHtml(String(s.name || '—'))}</span></td>
            <td class="openclaw-fill-td-path"><code>${escHtml(String(s.path || '—'))}</code></td>
            <td>${pill}</td>
            ${dismissBtn('skill', rowId)}
          </tr>`;
              })
              .join('')
          : skillsAllHidden || skillsEmptyMsg;
      const skillsBlock = `<div class="openclaw-fs-table-wrap"><table class="openclaw-fill-table openclaw-fill-grid openclaw-fill-table--interactive">
          <thead><tr><th scope="col">Estado</th><th scope="col">Skill</th><th scope="col">Ruta</th><th scope="col">Origen</th><th scope="col" class="oc-oc-actions"> </th></tr></thead>
          <tbody>${skillRows}</tbody>
        </table></div>`;

      let wsBlock = '';
      if (ws && typeof ws === 'object') {
        const wsMockHint =
          ws.mock && !isLegacyDemo
            ? `<p class="oc-muted openclaw-fill-mock-hint" role="note">Rutas simuladas plausibles (OPENCLAW_* / valores por defecto): la tarjeta «Instalación en disco» confirma lo legible.</p>`
            : '';
        const dirs = Array.isArray(ws.skillsDirs) ? ws.skillsDirs : [];
        const mem = Array.isArray(ws.memoryFiles) ? ws.memoryFiles : [];
        const wsRows: string[] = [
          `<tr><th scope="row">Ruta</th><td class="openclaw-fill-td-path"><code>${escHtml(ws.path || '—')}</code></td></tr>`,
        ];
        if (dirs.length)
          wsRows.push(
            `<tr><th scope="row">Dirs. skills</th><td>${dirs.map((t: string) => `<code>${escHtml(t)}</code>`).join(' · ')}</td></tr>`,
          );
        if (mem.length)
          wsRows.push(
            `<tr><th scope="row">Memoria</th><td>${mem.map((t: string) => `<code>${escHtml(t)}</code>`).join(' · ')}</td></tr>`,
          );
        if (!mem.length && !isLegacyDemo)
          wsRows.push(
            `<tr><th scope="row">Memoria</th><td class="oc-muted">Sin entradas listadas (revisa <code>memory/</code> en la tarjeta de instalación).</td></tr>`,
          );
        wsBlock = `${wsMockHint}<div class="openclaw-fs-table-wrap"><table class="openclaw-fill-table openclaw-fill-kv"><tbody>${wsRows.join('')}</tbody></table></div>`;
      }

      let styleBlock = '';
      if (st && typeof st === 'object') {
        styleBlock = `<dl class="openclaw-style-dl">
          <div><dt>Markdown</dt><dd>${escHtml(st.markdown || '—')}</dd></div>
          <div><dt>Citas</dt><dd>${escHtml(st.citations || '—')}</dd></div>
        </dl>`;
      }

      const personaNoteExtra = p && (p as any).mock && !isLegacyDemo ? ' · simulación plausible' : '';
      const agentsAllMock = agentsRaw.length > 0 && agentsRaw.every((a: any) => a.mock);
      const skillsAllMock = skillsRaw.length > 0 && skillsRaw.every((s: any) => s.source === 'mock');
      const agT = agentsRaw.length;
      const agV = agents.length;
      const skT = skillsRaw.length;
      const skV = skills.length;
      const agPanelNote = agentsAllMock
        ? `${agV} · catálogo`
        : agV
          ? agT > agV
            ? `${agV} en vista · ${agT} total`
            : `${agV} activos`
          : 'CLI';
      const skPanelNote = skillsAllMock
        ? `${skV} · catálogo`
        : skV
          ? skT > skV
            ? `${skV} en vista · ${skT} total`
            : `${skV} en lista`
          : 'CLI + disco';
      const wsPanelNote = ws && (ws as any).mock && !isLegacyDemo ? 'simulación plausible' : 'rutas API';

      const panels: string[] = [];
      if (personaBlock) {
        panels.push(`<details class="openclaw-fill-panel oc-chevron-disclosure" open>
      <summary><span class="oc-chevron-disclosure__lead">Personalidad <span class="openclaw-fill-panel-note">${personaSummary}${personaNoteExtra}</span></span></summary>
      <div class="openclaw-fill-panel-body">${personaBlock}</div>
    </details>`);
      }
      panels.push(`<details class="openclaw-fill-panel oc-chevron-disclosure"${agentsRaw.length ? ' open' : ''}>
      <summary><span class="oc-chevron-disclosure__lead">Agentes <span class="openclaw-fill-panel-note">${agPanelNote}</span></span></summary>
      <div class="openclaw-fill-panel-body">${agentsBlock}</div>
    </details>`);
      panels.push(`<details class="openclaw-fill-panel oc-chevron-disclosure"${skillsRaw.length ? ' open' : ''}>
      <summary><span class="oc-chevron-disclosure__lead">Skills <span class="openclaw-fill-panel-note">${skPanelNote}</span></span></summary>
      <div class="openclaw-fill-panel-body">${skillsBlock}</div>
    </details>`);
      if (wsBlock) {
        panels.push(`<details class="openclaw-fill-panel oc-chevron-disclosure" open>
      <summary><span class="oc-chevron-disclosure__lead">Workspace <span class="openclaw-fill-panel-note">${wsPanelNote}</span></span></summary>
      <div class="openclaw-fill-panel-body">${wsBlock}</div>
    </details>`);
      }
      if (styleBlock) {
        panels.push(`<details class="openclaw-fill-panel oc-chevron-disclosure">
      <summary><span class="oc-chevron-disclosure__lead">Estilo de respuesta</span></summary>
      <div class="openclaw-fill-panel-body">${styleBlock}</div>
    </details>`);
      }

      if (!panels.length) return '';

      const dek = isLegacyDemo
        ? 'Contenido ilustrativo (OPENCLAW_DEMO_FILL=1). Cada bloque se pliega por separado.'
        : 'Vista tipo consola: estado por fila, orígenes con etiquetas y acciones rápidas. Quitar solo oculta en este navegador.';
      const restoreBtn = `<button type="button" class="oc-oc-restore" id="oc-fill-restore-dismissed"${nHidden ? '' : ' disabled'}>Mostrar quitados${nHidden ? ` (${nHidden})` : ''}</button>`;
      const fillToolbar = `<div class="openclaw-fill-actions">
        <p class="oc-muted openclaw-fill-actions-hint">Quitar oculta la fila aquí (local). No modifica el servidor ni el disco.</p>
        ${restoreBtn}
      </div>`;
      return `<div class="card openclaw-fill-card">
        <div class="card-header oc-card-header--icon">
          <span class="oc-card-header__ico" aria-hidden="true">${OC_CARD_ICON.profile}</span>
          <h3>Perfil, agentes y estilo</h3>
        </div>
        <p class="openclaw-fill-dek">${escHtml(dek)}</p>
        ${note}${syntheticNote}
        ${fillToolbar}
        <div class="openclaw-fill-stack">${panels.join('')}</div>
      </div>`;
    }

    type OcSection = { title: string; keys: string[]; probeLayout?: 'twoCol' | 'threeCol' };

    const SECTIONS: OcSection[] = [
      { title: 'Núcleo y diagnóstico', keys: ['version', 'config_file', 'config_validate', 'status', 'health', 'doctor'] },
      { title: 'Skills', keys: ['skills_list', 'skills_check'] },
      { title: 'Agentes', keys: ['agents_list', 'agents_bindings'] },
      { title: 'Gateway y nodos', keys: ['gateway_status', 'gateway_health', 'gateway_probe', 'nodes', 'devices_list', 'directory'] },
      {
        title: 'Canales, modelos y memoria',
        keys: ['channels_list', 'channels_status', 'models_list', 'memory_status'],
        probeLayout: 'twoCol',
      },
      { title: 'Plugins, MCP y hooks', keys: ['plugins_list', 'mcp_list', 'hooks_list'] },
      { title: 'OpenClaw: cron y tareas', keys: ['cron_status', 'cron_list', 'tasks_list', 'tasks_flow'] },
      {
        title: 'Sandbox, pairing y aprobaciones',
        keys: ['sandbox_list', 'pairing_list', 'approvals_get'],
        probeLayout: 'threeCol',
      },
      { title: 'Seguridad', keys: ['security_audit'] },
    ];

    /** Ancho del bloque en la rejilla bento (12 col). */
    function ocBentoSectionClass(title: string): string {
      const full = new Set([
        'Núcleo y diagnóstico',
        'Gateway y nodos',
        'Canales, modelos y memoria',
        'Plugins, MCP y hooks',
        'OpenClaw: cron y tareas',
        'Sandbox, pairing y aprobaciones',
        'Seguridad',
      ]);
      return full.has(title) ? 'oc-bento-tile--full' : 'oc-bento-tile--half';
    }

    function fmtTime(ts: number) {
      if (!ts) return '—';
      try {
        return new Date(ts).toLocaleString('es-ES', { dateStyle: 'short', timeStyle: 'medium' });
      } catch {
        return '—';
      }
    }

    const OC_WF_ORDER = ['AGENTS', 'SOUL', 'USER', 'IDENTITY', 'TOOLS', 'MEMORY', 'HEARTBEAT'];

    function fmtBytes(n: number | undefined | null) {
      if (n == null || Number.isNaN(n)) return '—';
      if (n < 1024) return `${n} B`;
      if (n < 1024 * 1024) return `${(n / 1024).toFixed(1)} KiB`;
      return `${(n / (1024 * 1024)).toFixed(1)} MiB`;
    }

    /** Contenido leído del disco: workspace, memory/, skills, docs, media (API installLayout). */
    function renderInstallLayout(il: any): string {
      if (!il || typeof il !== 'object') return '';

      if (il.disabled) {
        return `<div class="card openclaw-install-card">
        <div class="card-header oc-card-header--icon"><span class="oc-card-header__ico" aria-hidden="true">${OC_CARD_ICON.install}</span><h3>Instalación en disco</h3></div>
        <p class="oc-muted openclaw-install-lede">Lectura del sistema de archivos desactivada: <code>${escHtml(il.message || 'OPENCLAW_FS_DISABLE')}</code></p>
      </div>`;
      }

      const roots = il.roots && typeof il.roots === 'object' ? il.roots : {};
      const rootsRows = ['workspace', 'docs', 'skills', 'mediaInbound']
        .map((k) => {
          const p = roots[k];
          if (!p) return '';
          const label =
            k === 'mediaInbound' ? 'Media inbound' : k === 'docs' ? 'Docs (npm)' : k === 'skills' ? 'Skills (npm)' : 'Workspace';
          return `<tr><td>${escHtml(label)}</td><td class="oc-td-cmd">${escHtml(String(p))}</td></tr>`;
        })
        .filter(Boolean)
        .join('');

      const topErr = il.error ? `<p class="oc-err-note">${escHtml(String(il.error))}</p>` : '';

      const wf = il.workspaceFiles || {};
      const wsDetails = OC_WF_ORDER.map((key) => {
        const f = wf[key];
        if (!f) return '';
        const name = f.name || `${key}.md`;
        let meta = '—';
        if (f.exists && f.content) {
          meta = `${fmtBytes(f.size)}${f.truncated ? ' · truncado' : ''}`;
        } else if (f.error) {
          meta = String(f.error);
        }
        const body =
          f.exists && f.content
            ? `<pre class="oc-pre oc-pre--probe">${escHtml(f.content)}</pre>`
            : f.error
              ? `<p class="oc-muted" style="margin:8px 0 0">${escHtml(String(f.error))}</p>`
              : '<p class="oc-muted">(vacío)</p>';
        const pathLine = f.path
          ? `<p class="oc-muted" style="margin:0 0 8px;font-size:11px;font-family:ui-monospace,monospace">${escHtml(f.path)}</p>`
          : '';
        return `<details class="openclaw-details oc-chevron-disclosure"><summary><span class="oc-chevron-disclosure__lead">${escHtml(name)} <span class="oc-fs-meta">${escHtml(meta)}</span></span></summary>${pathLine}${body}</details>`;
      }).join('');
      const wsN = OC_WF_ORDER.filter((k) => wf[k]).length;
      const wsRollup = wsDetails.trim()
        ? `<details class="openclaw-details openclaw-fs-rollup oc-chevron-disclosure"><summary><span class="oc-chevron-disclosure__lead"><span class="openclaw-fs-rollup-title">Ficheros MD del workspace</span> <span class="oc-fs-meta">${wsN} bloques</span></span></summary><div class="openclaw-fs-rollup-body">${wsDetails}</div></details>`
        : '';

      const mem = il.memory || {};
      let memBlock = '';
      if (mem.error) {
        memBlock = `<p class="oc-err-note">${escHtml(String(mem.error))}</p>`;
      } else {
        const entries = Array.isArray(mem.entries) ? mem.entries : [];
        const memList = entries
          .map((e: any) => {
            const meta =
              e.content != null
                ? `${fmtBytes(e.size)}${e.truncated ? ' · truncado' : ''} · ${fmtTime(e.mtimeMs)}`
                : e.error || '—';
            const body =
              e.content != null
                ? `<pre class="oc-pre">${escHtml(e.content)}</pre>`
                : e.error
                  ? `<p class="oc-muted">${escHtml(String(e.error))}</p>`
                  : '';
            const pathLine = e.path
              ? `<p class="oc-muted" style="margin:0 0 8px;font-size:11px;font-family:ui-monospace,monospace">${escHtml(e.path)}</p>`
              : '';
            return `<details class="openclaw-details oc-chevron-disclosure"><summary><span class="oc-chevron-disclosure__lead">${escHtml(e.name || '—')} <span class="oc-fs-meta">${escHtml(meta)}</span></span></summary>${pathLine}${body}</details>`;
          })
          .join('');
        const memN = entries.length;
        memBlock = `<details class="openclaw-details openclaw-fs-rollup oc-chevron-disclosure"><summary><span class="oc-chevron-disclosure__lead"><span class="openclaw-fs-rollup-title">Carpeta memory/</span> <span class="oc-fs-meta">${mem.exists ? 'accesible' : 'no accesible'} · ${memN} .md</span></span></summary>
      <div class="openclaw-fs-rollup-body">
      <p class="oc-muted openclaw-install-section-meta">${mem.exists ? 'Existe' : 'No accesible'} · <code>${escHtml(mem.dir || '')}</code></p>
      ${memList || '<p class="oc-muted">Sin entradas .md listadas.</p>'}
      </div></details>`;
      }

      const sk = il.skills || {};
      let skillsBlock = '';
      if (sk.error) {
        skillsBlock = `<p class="oc-err-note">${escHtml(String(sk.error))}</p>`;
      } else {
        const dismissSk = ocDismissSets().installSkills;
        const itemsAll = Array.isArray(sk.items) ? sk.items : [];
        const items = itemsAll.filter((s: any) => !dismissSk.has(ocInstallSkillRowId(s.skillDir)));
        const skillList = items
          .map((s: any) => {
            const rowId = ocInstallSkillRowId(s.skillDir);
            const meta = s.exists && s.content ? `${fmtBytes(s.size)}${s.truncated ? ' · truncado' : ''}` : s.error || '—';
            const body =
              s.exists && s.content
                ? `<pre class="oc-pre">${escHtml(s.content)}</pre>`
                : s.error
                  ? `<p class="oc-muted">${escHtml(String(s.error))}</p>`
                  : '';
            const pathLine = s.skillMdPath
              ? `<p class="oc-muted" style="margin:0 0 8px;font-size:11px;font-family:ui-monospace,monospace">${escHtml(s.skillMdPath)}</p>`
              : '';
            return `<details class="openclaw-details oc-chevron-disclosure"><summary><span class="oc-chevron-disclosure__lead oc-install-skill-head"><span>${escHtml(s.skillDir || 'skill')} · SKILL.md <span class="oc-fs-meta">${escHtml(meta)}</span></span><button type="button" class="oc-oc-dismiss" data-oc-dismiss="install-skill" data-oc-id="${escHtml(encodeURIComponent(rowId))}">Quitar</button></span></summary>${pathLine}${body}</details>`;
          })
          .join('');
        const visNote =
          itemsAll.length && !items.length
            ? '<p class="oc-muted">Todas las carpetas están ocultas en esta vista. Pulsa <strong>Mostrar quitados</strong> en la tarjeta de perfil.</p>'
            : '';
        const rollupMeta =
          itemsAll.length && items.length < itemsAll.length
            ? `${items.length} visibles · ${itemsAll.length} en disco`
            : `${itemsAll.length} carpetas`;
        skillsBlock = `<details class="openclaw-details openclaw-fs-rollup oc-chevron-disclosure"><summary><span class="oc-chevron-disclosure__lead"><span class="openclaw-fs-rollup-title">Skills instaladas</span> <span class="oc-fs-meta">${escHtml(rollupMeta)}</span></span></summary>
      <div class="openclaw-fs-rollup-body">
      <p class="oc-muted openclaw-install-section-meta">${sk.exists ? 'Directorio local' : 'No accesible'} · <code>${escHtml(sk.dir || '')}</code></p>
      ${visNote || skillList || '<p class="oc-muted">Sin carpetas de skill.</p>'}
      </div></details>`;
      }

      const docs = il.docs || {};
      let docsBlock = '';
      if (docs.error) {
        docsBlock = `<p class="oc-err-note">${escHtml(String(docs.error))}</p>`;
      } else {
        const files = Array.isArray(docs.files) ? docs.files : [];
        const docRows = files
          .map(
            (f: any) =>
              `<tr>
            <td class="openclaw-fill-td-path">${escHtml(f.path || '—')}</td>
            <td>${escHtml(fmtBytes(f.size))}</td>
            <td>${escHtml(fmtTime(f.mtimeMs))}</td>
          </tr>`,
          )
          .join('');
        const docCount = docs.fileCount || 0;
        docsBlock = `<details class="openclaw-details openclaw-fs-rollup oc-chevron-disclosure"><summary><span class="oc-chevron-disclosure__lead"><span class="openclaw-fs-rollup-title">Documentación (índice)</span> <span class="oc-fs-meta">${docCount} ficheros${docs.capped ? ' · tope' : ''}</span></span></summary>
      <div class="openclaw-fs-rollup-body">
      <p class="oc-muted openclaw-install-section-meta">${docs.exists ? `${docCount} ficheros` : 'No accesible'}${docs.capped ? ' (tope alcanzado)' : ''} · <code>${escHtml(docs.dir || '')}</code></p>
      ${
        files.length
          ? `<div class="openclaw-fs-table-wrap"><table class="openclaw-fill-table openclaw-fill-grid">
        <thead><tr><th scope="col">Ruta relativa</th><th scope="col">Tamaño</th><th scope="col">Modificación</th></tr></thead>
        <tbody>${docRows}</tbody>
      </table></div>`
          : '<p class="oc-muted">Sin ficheros indexados.</p>'
      }
      </div></details>`;
      }

      const media = il.mediaInbound || {};
      let mediaBlock = '';
      if (media.error) {
        mediaBlock = `<p class="oc-err-note">${escHtml(String(media.error))}</p>`;
      } else {
        const sample = Array.isArray(media.sample) ? media.sample : [];
        const mediaN = media.fileCount ?? 0;
        mediaBlock = `<details class="openclaw-details openclaw-fs-rollup oc-chevron-disclosure"><summary><span class="oc-chevron-disclosure__lead"><span class="openclaw-fs-rollup-title">Media entrante</span> <span class="oc-fs-meta">${media.exists ? `${mediaN} ficheros` : 'no accesible'}</span></span></summary>
      <div class="openclaw-fs-rollup-body">
      <p class="oc-muted openclaw-install-section-meta">${media.exists ? `${mediaN} ficheros` : 'No accesible'} · <code>${escHtml(media.dir || '')}</code></p>
      ${
        sample.length
          ? `<p class="oc-muted openclaw-install-section-meta openclaw-install-section-meta--tight">Muestra: ${sample.map((n: string) => `<code>${escHtml(n)}</code>`).join(', ')}</p>`
          : ''
      }
      </div></details>`;
      }

      const subs = il.workspaceSubdirs || {};
      const subKeys = ['memory', 'logs', 'proyectos'];
      const subRows = subKeys
        .map((k) => {
          const s = subs[k];
          if (!s) return '';
          const st = s.exists && s.isDirectory ? `${s.entryCount ?? 0} entradas` : s.exists ? '—' : 'no existe';
          return `<tr><td>${escHtml(k)}</td><td class="oc-td-cmd">${escHtml(s.path || '—')}</td><td>${escHtml(st)}</td></tr>`;
        })
        .filter(Boolean)
        .join('');

      const subBlock = subRows
        ? `<details class="openclaw-details openclaw-fs-rollup oc-chevron-disclosure"><summary><span class="oc-chevron-disclosure__lead"><span class="openclaw-fs-rollup-title">Subcarpetas del workspace</span> <span class="oc-fs-meta">${subKeys.filter((k) => subs[k]).length} rutas</span></span></summary>
      <div class="openclaw-fs-rollup-body">
      <div class="openclaw-fs-table-wrap"><table class="openclaw-fill-table openclaw-fill-grid">
        <thead><tr><th scope="col">Nombre</th><th scope="col">Ruta</th><th scope="col">Estado</th></tr></thead>
        <tbody>${subRows}</tbody>
      </table></div>
      </div></details>`
        : '';

      const badge = il.hasRealWorkspaceContent
        ? '<span class="oc-badge oc-badge--ok">Contenido real</span>'
        : '<span class="oc-badge oc-badge--mock">Sin MD de workspace</span>';

      return `<div class="card openclaw-install-card">
    <div class="card-header oc-card-header--icon oc-card-header--spread">
      <span class="oc-card-header__ico" aria-hidden="true">${OC_CARD_ICON.install}</span>
      <h3>Instalación en disco</h3>
      ${badge}
    </div>
    <p class="oc-muted openclaw-install-lede">Rutas configurables con <code>OPENCLAW_WORKSPACE</code>, <code>OPENCLAW_DOCS</code>, <code>OPENCLAW_SKILLS</code>, <code>OPENCLAW_MEDIA_INBOUND</code>.</p>
    ${topErr}
    <h4 class="openclaw-fs-sub openclaw-install-fs-sub">Rutas base</h4>
    <div class="openclaw-fs-table-wrap openclaw-install-rutas-wrap">
      <table class="openclaw-fill-table openclaw-fill-grid">
        <thead><tr><th scope="col">Ámbito</th><th scope="col">Ruta</th></tr></thead>
        <tbody>${rootsRows || '<tr><td colspan="2" class="oc-muted">Sin rutas</td></tr>'}</tbody>
      </table>
    </div>
    ${wsRollup || '<p class="oc-muted openclaw-install-empty">Sin datos de workspace.</p>'}
    ${memBlock}
    ${skillsBlock}
    ${docsBlock}
    ${mediaBlock}
    ${subBlock}
  </div>`;
    }

    function renderProbe(key: string, pr: any): string {
      const label = LABELS[key] || key;
      const cmd = pr && pr.cmd ? String(pr.cmd) : `openclaw … ${key}`;
      const ok = !!(pr && pr.ok && pr.error !== 'ENOENT');
      const isMock = !!(pr && pr.mock);
      const badge = ok ? 'oc-badge--ok' : 'oc-badge--bad';
      const badgeLabel = ok ? 'OK' : 'Error';
      const exit = pr && typeof pr.exitCode === 'number' ? pr.exitCode : '—';
      const badgeText = `${badgeLabel} · ${String(exit)}`;
      const enoent =
        pr && pr.error === 'ENOENT'
          ? '<p class="oc-err-note">No se encontró el ejecutable en PATH. Define <code>OPENCLAW_BIN</code> en el entorno de la API.</p>'
          : '';

      let body = '';
      if (pr && pr.parsed != null) {
        body = `<pre class="oc-pre oc-pre--probe oc-pre--json">${escHtml(JSON.stringify(pr.parsed, null, 2))}</pre>`;
      } else if (pr && pr.stdout) {
        body = `<pre class="oc-pre oc-pre--probe">${escHtml(pr.stdout)}</pre>`;
      } else {
        body = '<p class="oc-muted">(sin salida en stdout)</p>';
      }

      const err =
        pr && pr.stderr
          ? `<pre class="oc-pre oc-pre--probe oc-pre--err">${escHtml(pr.stderr)}</pre>`
          : '';

      const rawOut = `${body}${err}`;

      const headHtml = `<div class="oc-probe-head">
          <strong>${escHtml(label)}</strong>
          <code class="oc-cmd">${escHtml(cmd)}</code>
          ${isMock ? '' : `<span class="oc-badge ${badge}">${escHtml(badgeText)}</span>`}
        </div>`;

      if (isMock) {
        return `<div class="oc-probe oc-probe--mock">
        <details class="oc-probe-output sidebar-section oc-probe-output--mock-row">
        <summary class="oc-probe-mock-summary" aria-label="Mostrar u ocultar salida simulada">
          <span class="oc-probe-mock-summary__main">
            <span class="sidebar-section__summary-ico" aria-hidden="true">${OC_MOCK_OUTPUT_ICON}</span>
            <strong>${escHtml(label)}</strong>
            <code class="oc-cmd oc-probe-mock-summary__cmd">${escHtml(cmd)}</code>
          </span>
        </summary>
        ${enoent}
        <div class="oc-probe-output-inner">${rawOut}</div>
      </details>
      </div>`;
      }

      return `<div class="oc-probe">
        ${headHtml}
        ${enoent}
        ${rawOut}
      </div>`;
    }

    function renderCronHost(cs: any): string {
      const jobs = cs && Array.isArray(cs.jobs) ? cs.jobs : [];
      const hint = cs && cs.hint ? `<p class="oc-muted" style="margin:0 0 12px">${escHtml(cs.hint)}</p>` : '';
      if (!jobs.length) {
        return `${hint}<p class="oc-muted">Sin entradas de cron/tareas programadas en este host (revisa la API y el SO).</p>`;
      }
      const rows = jobs
        .map(
          (j: any) =>
            `<tr>
            <td>${escHtml(String(j.source || '—'))}</td>
            <td>${escHtml(String(j.kind || '—'))}</td>
            <td>${escHtml(String(j.schedule || '—'))}</td>
            <td class="oc-td-cmd">${escHtml(String(j.command || '—'))}</td>
          </tr>`,
        )
        .join('');
      return `${hint}<div class="oc-cron-wrap"><table class="oc-cron-table">
        <thead><tr><th>Origen</th><th>Tipo</th><th>Planificación</th><th>Comando</th></tr></thead>
        <tbody>${rows}</tbody>
      </table></div>`;
    }

    function renderAll(data: any) {
      const probes = (data && data.probes) || {};
      const el = $('oc-sections');
      el.removeAttribute('aria-busy');
      el.classList.remove('oc-sections--loading');

      if (data && data.disabled) {
        el.classList.remove('oc-sections--loading');
        el.innerHTML = `<div class="oc-bento-tile oc-bento-tile--full"><div class="card"><p class="oc-muted">${escHtml(data.message || 'Snapshot desactivado.')}</p></div></div>`;
        return;
      }

      const parts: string[] = [];

      const installHtml = renderInstallLayout(data.installLayout);
      if (installHtml) parts.push(`<div class="oc-bento-tile oc-bento-tile--full">${installHtml}</div>`);

      const suppressDemo = !!(data && data.suppressDemoFill);
      const fillHtml = !suppressDemo ? renderFill(data.openclawFill) : '';
      const cronHostCard = `<div class="card">
        <div class="card-header oc-card-header--icon">
          <span class="oc-card-header__ico" aria-hidden="true">${OC_CARD_ICON.cronHost}</span>
          <h3>Cron y tareas del host (sistema)</h3>
        </div>
        ${renderCronHost(data.cronSystem)}
      </div>`;
      if (fillHtml) {
        parts.push(`<div class="oc-bento-tile oc-bento-tile--half">${fillHtml}</div>`);
        parts.push(`<div class="oc-bento-tile oc-bento-tile--half">${cronHostCard}</div>`);
      } else {
        parts.push(`<div class="oc-bento-tile oc-bento-tile--full">${cronHostCard}</div>`);
      }

      for (const sec of SECTIONS) {
        const inner = sec.keys.map((k) => (probes[k] ? renderProbe(k, probes[k]) : '')).filter(Boolean).join('');
        if (!inner) continue;
        const span = ocBentoSectionClass(sec.title);
        const gridClass =
          sec.probeLayout === 'twoCol'
            ? 'oc-probe-grid oc-probe-grid--2col'
            : sec.probeLayout === 'threeCol'
              ? 'oc-probe-grid oc-probe-grid--3col'
              : '';
        const gridOpen = gridClass ? `<div class="${gridClass}">` : '';
        const gridClose = gridClass ? '</div>' : '';
        const hdrIco = OC_SECTION_ICON_SVG[sec.title] || '';
        parts.push(`<div class="oc-bento-tile ${span}"><div class="card"><div class="card-header oc-card-header--icon">${hdrIco ? `<span class="oc-card-header__ico" aria-hidden="true">${hdrIco}</span>` : ''}<h3>${escHtml(sec.title)}</h3></div>${gridOpen}${inner}${gridClose}</div></div>`);
      }

      const covered = new Set<string>();
      for (const sec of SECTIONS) for (const k of sec.keys) covered.add(k);
      const extraKeys = Object.keys(probes).filter((k) => !covered.has(k));
      if (extraKeys.length) {
        const inner = extraKeys.map((k) => renderProbe(k, probes[k])).join('');
        parts.push(`<div class="oc-bento-tile oc-bento-tile--full"><div class="card"><div class="card-header oc-card-header--icon"><span class="oc-card-header__ico" aria-hidden="true">${OC_SECTION_ICON_SVG['Otras sondas']}</span><h3>Otras sondas</h3></div>${inner}</div></div>`);
      }

      el.innerHTML =
        parts.join('') ||
        '<div class="oc-bento-tile oc-bento-tile--full"><div class="card"><p class="oc-muted">Sin datos de sondas.</p></div></div>';
    }

    function updateOpenClawKpis(data: any) {
      const elWs = document.getElementById('oc-kpi-ws');
      const elSk = document.getElementById('oc-kpi-skills');
      const elDoc = document.getElementById('oc-kpi-docs');
      const metaWs = document.getElementById('oc-kpi-ws-meta');
      const metaSk = document.getElementById('oc-kpi-skills-meta');
      const metaDoc = document.getElementById('oc-kpi-docs-meta');
      if (!elWs || !elSk || !elDoc) return;

      const clearSk = (el: HTMLElement) => el.classList.remove('skeleton');
      const il = data && data.installLayout;

      if (!il || typeof il !== 'object' || il.disabled) {
        elWs.textContent = '—';
        elSk.textContent = '—';
        elDoc.textContent = '—';
        if (metaWs) metaWs.textContent = il && il.disabled ? 'Lectura FS desactivada' : 'Sin datos de instalación';
        if (metaSk) metaSk.textContent = '—';
        if (metaDoc) metaDoc.textContent = '—';
        clearSk(elWs);
        clearSk(elSk);
        clearSk(elDoc);
        return;
      }

      const wf = il.workspaceFiles || {};
      const nWs = Object.keys(wf).filter((k) => wf[k] && wf[k].exists && wf[k].content).length;
      elWs.textContent = `${nWs}/7`;
      if (metaWs) metaWs.textContent = 'MD con contenido (canónicos)';

      const skillItems = il.skills && Array.isArray(il.skills.items) ? il.skills.items : [];
      elSk.textContent = String(skillItems.length);
      const withSkillMd = skillItems.filter((s: any) => s.exists && s.content).length;
      if (metaSk)
        metaSk.textContent = skillItems.length ? `${withSkillMd} con SKILL.md leído` : 'Sin carpetas';

      const docN = il.docs && typeof il.docs.fileCount === 'number' ? il.docs.fileCount : 0;
      elDoc.textContent = String(docN);
      if (metaDoc) metaDoc.textContent = il.docs && il.docs.capped ? 'Índice (tope alcanzado)' : 'Ficheros en docs/';

      clearSk(elWs);
      clearSk(elSk);
      clearSk(elDoc);
    }

    async function load() {
      setOcCloneButtonsEnabled(false);
      const msgBox = $('oc-global-msg');
      const msgText = $('oc-global-msg-text');
      const el = $('oc-sections');
      el.setAttribute('aria-busy', 'true');
      el.classList.add('oc-sections--loading');
      el.innerHTML = ocLoadingMarkup();
      msgBox.classList.add('openclaw-banner--hidden');
      msgText.textContent = '';

      void syncDashboardProfile();

      try {
        const r = await apiFetch('/api/openclaw');
        if (!r.ok) throw new Error('HTTP ' + r.status);
        const data = await r.json();

        const av = $('ocm-available');
        av.textContent = data.available ? 'Sí' : 'No';
        av.classList.remove('skeleton');

        const bin = $('ocm-binary');
        bin.textContent = data.binary || 'openclaw';
        bin.title = data.binary || '';
        bin.classList.remove('skeleton');

        const at = $('ocm-at');
        at.textContent = fmtTime(data.at);
        at.classList.remove('skeleton');

        const cj = $('ocm-cron');
        const n = data.cronSystem && Array.isArray(data.cronSystem.jobs) ? data.cronSystem.jobs.length : 0;
        cj.textContent = String(n);
        cj.classList.remove('skeleton');

        updateOpenClawKpis(data);
        ocLastSnapshot = data;

        if (data.message && data.disabled) {
          msgText.textContent = data.message;
          msgBox.classList.remove('openclaw-banner--hidden');
        } else if (data.degraded) {
          const snapErr =
            typeof (data as { snapshotError?: unknown }).snapshotError === 'string'
              ? (data as { snapshotError: string }).snapshotError
              : '';
          msgText.textContent = String(
            data.message || snapErr || 'Snapshot degradado: el servidor no pudo ejecutar todas las comprobaciones.',
          );
          msgBox.classList.remove('openclaw-banner--hidden');
        } else if (data.mockMode) {
          msgText.textContent =
            'OpenClaw no está en PATH en la API: todas las sondas muestran JSON de vista previa (agentes, skills/permisos, MCP, gateway, aprobaciones, sandbox, seguridad…). La instalación en disco y el cron del host siguen siendo lecturas reales donde aplique.';
          msgBox.classList.remove('openclaw-banner--hidden');
        } else {
          msgBox.classList.add('openclaw-banner--hidden');
        }

        renderAll(data);
        setOcCloneButtonsEnabled(true);
      } catch (e) {
        console.error(e);
        ocLastSnapshot = null;
        setOcCloneButtonsEnabled(false);
        msgBox.classList.add('openclaw-banner--hidden');
        updateOpenClawKpis({});
        el.removeAttribute('aria-busy');
        el.classList.remove('oc-sections--loading');
        el.innerHTML = `<div class="oc-bento-tile oc-bento-tile--full"><div class="card"><p class="oc-err-note">${escHtml(
          'No se pudo conectar con el servicio de métricas. Comprueba que la API esté en marcha y vuelve a intentarlo.',
        )}</p></div></div>`;
      }
    }

    function ensureOcDismissWire() {
      const el = $('oc-sections');
      if ((el as HTMLElement).dataset.ocDismissBound) return;
      (el as HTMLElement).dataset.ocDismissBound = '1';
      el.addEventListener('click', (e: Event) => {
        const ev = e as MouseEvent;
        const t = ev.target as HTMLElement | null;
        if (!t) return;
        const restore = t.closest('#oc-fill-restore-dismissed') as HTMLButtonElement | null;
        if (restore) {
          ev.preventDefault();
          if (restore.disabled) return;
          clearOcDismiss();
          if (ocLastSnapshot) renderAll(ocLastSnapshot as Record<string, unknown>);
          return;
        }
        const btn = t.closest('[data-oc-dismiss]') as HTMLElement | null;
        if (!btn || !el.contains(btn)) return;
        const kind = btn.getAttribute('data-oc-dismiss');
        const idRaw = btn.getAttribute('data-oc-id');
        if (!kind || !idRaw) return;
        let id: string;
        try {
          id = decodeURIComponent(idRaw);
        } catch {
          id = idRaw;
        }
        ev.preventDefault();
        ev.stopPropagation();
        addOcDismiss(kind, id);
        if (ocLastSnapshot) renderAll(ocLastSnapshot as Record<string, unknown>);
      });
    }

    $('oc-snap-refresh').addEventListener('click', load);
    ensureOcDismissWire();

    document.getElementById('oc-clone-profile')?.addEventListener('click', async () => {
      if (!ocLastSnapshot) {
        showCloneFeedback('Sin datos: pulsa actualizar primero.', 'err');
        return;
      }
      const bundle = buildOpenClawCloneBundle(ocLastSnapshot, 'profile');
      try {
        await navigator.clipboard.writeText(JSON.stringify(bundle, null, 2));
        showCloneFeedback('Perfil copiado al portapapeles (JSON).', 'ok');
      } catch {
        showCloneFeedback('No se pudo copiar. Revisa permisos del portapapeles o usa Descargar sistema.', 'err');
      }
    });

    document.getElementById('oc-clone-full')?.addEventListener('click', () => {
      if (!ocLastSnapshot) {
        showCloneFeedback('Sin datos: pulsa actualizar primero.', 'err');
        return;
      }
      const bundle = buildOpenClawCloneBundle(ocLastSnapshot, 'full');
      const json = JSON.stringify(bundle, null, 2);
      const blob = new Blob([json], { type: 'application/json;charset=utf-8' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      const stamp = new Date().toISOString().replace('T', '_').replace(/:/g, '-').slice(0, 19);
      a.download = `openclaw-sistema-${stamp}.json`;
      a.href = url;
      a.rel = 'noopener';
      document.body.appendChild(a);
      a.click();
      a.remove();
      URL.revokeObjectURL(url);
      showCloneFeedback('Archivo JSON del sistema descargado.', 'ok');
    });

    load();
  </script>
</Layout>
