---
import Layout from '../layouts/Layout.astro';
import pineappleImg from '../assets/pineapple.png';
import { getBuildBrand } from '../lib/brand';
import { iconToSvg } from '../lib/lucide-svg-string';
import { RefreshCw, Clock, Terminal, Braces, CalendarDays, Files, Package, BookOpen, Sparkles } from 'lucide';

const brand = getBuildBrand();
const avatarSrc = brand.avatarUrl || pineappleImg.src;
const customAvatarClass = brand.avatarUrl ? ' profile-card--custom-avatar' : '';

const iRefresh = iconToSvg(RefreshCw, { width: 20, height: 20 });
const iClock = iconToSvg(Clock, { width: 14, height: 14 });
const iTerm = iconToSvg(Terminal, { width: 18, height: 18 });
const iBrace = iconToSvg(Braces, { width: 18, height: 18 });
const iClockBadge = iconToSvg(Clock, { width: 18, height: 18 });
const iCal = iconToSvg(CalendarDays, { width: 18, height: 18 });
const iKpiWs = iconToSvg(Files, { width: 20, height: 20 });
const iKpiSkills = iconToSvg(Package, { width: 20, height: 20 });
const iKpiDocs = iconToSvg(BookOpen, { width: 20, height: 20 });
const iPageTitle = iconToSvg(Sparkles, { width: 22, height: 22 });
---
<Layout activePage="openclaw">
  <div class="wrapper wrapper--dashboard openclaw-page">
    <span class="page-header__watermark" set:html={iPageTitle} aria-hidden="true" />
    <div class="page-header openclaw-page__title">
      <div class="dk-page-title-row">
        <div>
          <h1 class="page-title">OpenClaw</h1>
          <p class="page-desc">Instalación, perfil y recursos del agente en el host de la API.</p>
        </div>
      </div>
    </div>

    <div id="oc-chrome">
      <section class="dashboard-metrics-bar" aria-label="Resumen OpenClaw">
        <div class="dashboard-metrics-bar__main">
          <div class="quick-badges" id="oc-meta">
            <div class="q-badge q-badge--accent">
              <span class="q-badge-icon" set:html={iTerm} aria-hidden="true" />
              <span class="q-badge-stack">
                <span class="q-badge-name">CLI</span>
                <strong id="ocm-available" class="skeleton q-badge-val">—</strong>
              </span>
            </div>
            <div class="q-badge">
              <span class="q-badge-icon" set:html={iBrace} aria-hidden="true" />
              <span class="q-badge-stack">
                <span class="q-badge-name">Binario</span>
                <strong id="ocm-binary" class="skeleton q-badge-val oc-meta-bin">—</strong>
              </span>
            </div>
            <div class="q-badge">
              <span class="q-badge-icon" set:html={iClockBadge} aria-hidden="true" />
              <span class="q-badge-stack">
                <span class="q-badge-name">Captura</span>
                <strong id="ocm-at" class="skeleton q-badge-val">—</strong>
              </span>
            </div>
            <div class="q-badge">
              <span class="q-badge-icon" set:html={iCal} aria-hidden="true" />
              <span class="q-badge-stack">
                <span class="q-badge-name">Cron host</span>
                <strong id="ocm-cron" class="skeleton q-badge-val">—</strong>
              </span>
            </div>
          </div>
          <div class="kpi-strip" id="oc-kpi-strip" aria-label="Resumen instalación en disco">
            <div class="kpi">
              <span class="kpi-icon" set:html={iKpiWs} aria-hidden="true" />
              <div class="kpi-body">
                <div class="kpi-row-main">
                  <span class="kpi-value skeleton" id="oc-kpi-ws">—</span>
                  <span class="kpi-title">Workspace MD</span>
                </div>
                <p class="kpi-meta" id="oc-kpi-ws-meta">Con contenido / total</p>
              </div>
            </div>
            <div class="kpi">
              <span class="kpi-icon" set:html={iKpiSkills} aria-hidden="true" />
              <div class="kpi-body">
                <div class="kpi-row-main">
                  <span class="kpi-value skeleton" id="oc-kpi-skills">—</span>
                  <span class="kpi-title">Skills</span>
                </div>
                <p class="kpi-meta" id="oc-kpi-skills-meta">Carpetas en skills/</p>
              </div>
            </div>
            <div class="kpi">
              <span class="kpi-icon" set:html={iKpiDocs} aria-hidden="true" />
              <div class="kpi-body">
                <div class="kpi-row-main">
                  <span class="kpi-value skeleton" id="oc-kpi-docs">—</span>
                  <span class="kpi-title">Docs</span>
                </div>
                <p class="kpi-meta" id="oc-kpi-docs-meta">Ficheros indexados</p>
              </div>
            </div>
          </div>
        </div>
        <div class="dashboard-refresh-tools">
          <div class="oc-clone-actions" role="group" aria-label="Clonar sistema OpenClaw">
            <button
              type="button"
              class="oc-clone-btn"
              id="oc-clone-profile"
              disabled
              title="Copiar al portapapeles: personalidad, agentes, skills, estilo y workspace (JSON)"
            >
              Copiar perfil
            </button>
            <button
              type="button"
              class="oc-clone-btn"
              id="oc-clone-full"
              disabled
              title="Descargar JSON: perfil, instalación en disco, sondas CLI y cron del host"
            >
              Descargar sistema
            </button>
          </div>
          <button type="button" class="dashboard-refresh-btn" id="oc-snap-refresh" title="Actualizar snapshot" aria-label="Actualizar snapshot">
            <span set:html={iRefresh} aria-hidden="true" />
          </button>
        </div>
      </section>
      <p class="oc-clone-feedback" id="oc-clone-feedback" hidden aria-live="polite"></p>

      <div class="card dashboard-alerts-card openclaw-banner openclaw-banner--hidden" id="oc-global-msg" role="status">
        <div class="dash-alert dash-alert--warning openclaw-banner-inner">
          <span class="openclaw-banner-dot" aria-hidden="true"></span>
          <p class="dash-alert-detail openclaw-banner-text" id="oc-global-msg-text"></p>
        </div>
      </div>

      <div class="dashboard-grid openclaw-bento-hero">
        <div class={`card profile-card profile-card--loading${customAvatarClass}`} id="card-profile" aria-busy="true">
          <div class="pine-avatar-wrap" id="pine-avatar-wrap" data-mood="ok">
            <div class="pine-load-ring" aria-hidden="true"></div>
            <div class="pine-glow"></div>
            <img
              src={avatarSrc}
              data-bichi-build-src={avatarSrc}
              alt={brand.appName}
              class="pine-avatar"
              id="pine-avatar"
              data-mood="ok"
              width="280"
              height="280"
              decoding="async"
              fetchpriority="high"
            />
            <div class="pine-mouth" id="pine-mouth" data-mood="ok">
              <svg viewBox="0 0 40 20" xmlns="http://www.w3.org/2000/svg">
                <path class="mouth-happy" d="M 8 7 Q 20 17 32 7" stroke="#5D4037" stroke-width="2.5" fill="none" stroke-linecap="round"></path>
                <path class="mouth-neutral" d="M 10 11 Q 20 11 30 11" stroke="#5D4037" stroke-width="2.5" fill="none" stroke-linecap="round"></path>
                <path class="mouth-sad" d="M 10 15 Q 20 7 30 15" stroke="#5D4037" stroke-width="2.5" fill="none" stroke-linecap="round"></path>
              </svg>
            </div>
          </div>
          <div class="profile-info">
            <h2 class="profile-name" id="profile-name"><span class="profile-name-filler skeleton">&nbsp;</span></h2>
            <p class="profile-role profile-role--boot" id="profile-role">Sincronizando con el monitor…</p>
            <dl class="openclaw-profile-meta" id="openclaw-profile-meta" hidden>
              <div class="openclaw-profile-meta__row">
                <dt>Hostname</dt>
                <dd id="oc-profile-host" class="skeleton">—</dd>
              </div>
              <div class="openclaw-profile-meta__row">
                <dt>Sistema</dt>
                <dd id="oc-profile-os" class="skeleton">—</dd>
              </div>
              <div class="openclaw-profile-meta__row">
                <dt>IPv4</dt>
                <dd id="oc-profile-ipv4" class="skeleton">—</dd>
              </div>
            </dl>
            <span class="profile-badge profile-badge--boot" id="profile-badge">
              <span set:html={iClock} aria-hidden="true" />
              <span class="profile-uptime-line skeleton" id="profile-uptime">&nbsp;</span>
            </span>
          </div>
        </div>

        <div class="card openclaw-bento-tile openclaw-bento-tile--snapshot">
          <div class="card-header">
            <h3>Snapshot CLI</h3>
          </div>
          <p class="progress-subtitle openclaw-bento-snapshot-lede">
            Vista alineada con el dashboard: CLI, binario, instantánea y cron del host en la barra superior; aquí el detalle y las sondas.
          </p>
          <p class="tracker-note openclaw-bento-snapshot-note">
            Usa el botón de <strong>refrescar</strong> para repetir <code>openclaw … --json</code> y releer disco.
          </p>
        </div>

        <div class="card openclaw-bento-tile openclaw-bento-tile--disco">
          <div class="card-header">
            <h3>Disco local</h3>
          </div>
          <p class="progress-subtitle">Los KPI de workspace, skills y docs están en la franja superior.</p>
          <ul class="openclaw-bento-mini-list">
            <li>MD canónicos del workspace</li>
            <li><code>memory/</code>, <code>skills/</code>, índice <code>docs</code></li>
            <li>Tablas y detalle en el panel inferior</li>
          </ul>
        </div>

        <div class="card openclaw-bento-tile openclaw-bento-tile--env">
          <div class="card-header">
            <h3>Variables API</h3>
          </div>
          <ul class="openclaw-env-chips" aria-label="Variables de entorno relevantes">
            <li><code>OPENCLAW_WORKSPACE</code></li>
            <li><code>OPENCLAW_DOCS</code></li>
            <li><code>OPENCLAW_SKILLS</code></li>
            <li><code>OPENCLAW_MEDIA_INBOUND</code></li>
            <li><code>OPENCLAW_BIN</code></li>
            <li><code>OPENCLAW_FS_DISABLE</code></li>
          </ul>
        </div>

        <div class="card openclaw-bento-index">
          <div class="card-header openclaw-bento-index__head">
            <h3>Índice del panel</h3>
            <nav class="openclaw-quick-links" aria-label="Enlaces rápidos">
              <a href="/logs">Registros</a>
              <a href="/configuracion">Monitor</a>
              <a href="/">Dashboard</a>
            </nav>
          </div>
          <p class="dash-sys-lede" style="margin-top:0">
            Abajo, rejilla tipo bento: instalación en disco (ancho completo), personalidad demo y cron del host en paralelo, y bloques de sondas agrupadas.
          </p>
          <ul class="openclaw-index-list">
            <li><strong>Instalación</strong> — rutas visibles; memory/skills/docs/media en secciones plegables.</li>
            <li><strong>Perfil / agentes</strong> — acordeón: tablas de personalidad, agentes y workspace; estilo en lista.</li>
            <li><strong>Cron del SO</strong> — misma fuente que el calendario del dashboard.</li>
            <li><strong>Sondas CLI</strong> — núcleo, gateway, canales+modelos, plugins, cron; simuladas en una fila: icono, título, comando y flecha para la salida.</li>
          </ul>
          <p class="openclaw-index-hint">
            Sin <code>openclaw</code> en PATH de la API: define <code>OPENCLAW_BIN</code> en el entorno del servicio de métricas.
          </p>
        </div>
      </div>
    </div>

    <div id="oc-sections" class="openclaw-bento-main oc-sections--loading" aria-busy="true">
      <div class="oc-bento-tile oc-bento-tile--full" aria-hidden="true">
        <div class="card openclaw-loading-card">
          <span class="skeleton openclaw-loading-line"></span>
          <span class="skeleton openclaw-loading-block"></span>
        </div>
      </div>
    </div>
  </div>

  <style>
    .openclaw-page #oc-chrome {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .openclaw-page .oc-clone-actions {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 8px;
    }
    .openclaw-page .oc-clone-btn {
      margin: 0;
      padding: 5px 11px;
      font-size: 11px;
      font-weight: 600;
      border-radius: 999px;
      border: 1px solid var(--border);
      background: var(--bg-subtle);
      color: var(--text-soft);
      cursor: pointer;
      transition: border-color 0.2s, color 0.2s, background 0.2s;
    }
    .openclaw-page .oc-clone-btn:hover:not(:disabled) {
      border-color: rgba(250, 204, 21, 0.35);
      color: var(--accent);
      background: var(--toggle-hover);
    }
    .openclaw-page .oc-clone-btn:disabled {
      opacity: 0.45;
      cursor: not-allowed;
    }
    .openclaw-page .oc-clone-feedback {
      margin: 4px 0 0;
      font-size: 12px;
      font-weight: 600;
      color: var(--ok, #15803d);
    }
    .openclaw-page .oc-clone-feedback.oc-clone-feedback--err {
      color: var(--crit, #c53b37);
    }
    .openclaw-page .oc-clone-feedback[hidden] {
      display: none !important;
    }
    @media (min-width: 1100px) {
      .openclaw-page .dashboard-grid.openclaw-bento-hero {
        grid-template-columns: 260px 1fr 1fr 280px;
        grid-template-rows: auto minmax(0, auto);
        align-items: stretch;
        gap: 16px;
      }
    }
    /* Hero bento: misma plantilla que el dashboard (≥1100px en global.css) */
    .openclaw-page .openclaw-bento-hero .profile-card {
      grid-column: 1;
      grid-row: 1 / 3;
    }
    .openclaw-page .openclaw-bento-hero .openclaw-bento-tile--snapshot {
      grid-column: 2;
      grid-row: 1;
    }
    .openclaw-page .openclaw-bento-hero .openclaw-bento-tile--disco {
      grid-column: 3;
      grid-row: 1;
    }
    .openclaw-page .openclaw-bento-hero .openclaw-bento-tile--env {
      grid-column: 4;
      grid-row: 1;
    }
    .openclaw-page .openclaw-bento-hero .openclaw-bento-index {
      grid-column: 2 / 5;
      grid-row: 2;
      min-height: 0;
    }
    .openclaw-bento-tile,
    .openclaw-bento-index {
      padding: 20px;
      min-width: 0;
    }
    .openclaw-bento-tile .card-header,
    .openclaw-bento-index .card-header {
      margin-bottom: 10px;
    }
    .openclaw-bento-snapshot-lede {
      margin: 0 0 8px;
    }
    .openclaw-bento-snapshot-note {
      margin: 0;
      text-align: left;
      max-width: none;
    }
    .openclaw-bento-mini-list {
      margin: 0;
      padding-left: 18px;
      font-size: 12px;
      line-height: 1.5;
      color: var(--muted);
      font-weight: 600;
    }
    .openclaw-bento-mini-list code {
      font-size: 0.9em;
    }
    .openclaw-env-chips {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .openclaw-env-chips li {
      margin: 0;
    }
    .openclaw-env-chips code {
      font-size: 10px;
      padding: 4px 8px;
      border-radius: 8px;
      background: var(--bg-subtle);
      border: 1px solid var(--border);
      display: inline-block;
      max-width: 100%;
      overflow-wrap: anywhere;
    }
    .openclaw-bento-index .openclaw-bento-index__head.card-header {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      gap: 10px 14px;
    }
    .openclaw-quick-links {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      align-items: center;
    }
    .openclaw-quick-links a {
      font-size: 11px;
      font-weight: 600;
      padding: 5px 10px;
      border-radius: 999px;
      text-decoration: none;
      color: var(--text-soft);
      background: var(--bg-subtle);
      border: 1px solid var(--border);
    }
    .openclaw-quick-links a:hover {
      color: var(--accent);
      border-color: rgba(250, 204, 21, 0.35);
    }
    .openclaw-profile-meta {
      margin: 10px 0 12px;
      padding: 8px 0 8px 12px;
      border-radius: 0;
      background: transparent;
      border: none;
      border-left: 2px solid var(--border);
      display: grid;
      gap: 8px;
    }
    .openclaw-profile-meta__row {
      display: grid;
      grid-template-columns: 72px 1fr;
      gap: 10px;
      align-items: baseline;
      font-size: 11px;
      line-height: 1.4;
    }
    .openclaw-profile-meta dt {
      margin: 0;
      font-weight: 800;
      font-family: var(--font-display);
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--muted);
      font-size: 9px;
    }
    .openclaw-profile-meta dd {
      margin: 0;
      font-weight: 600;
      color: var(--text-soft);
      overflow-wrap: anywhere;
      word-break: break-word;
    }
    .openclaw-index-list {
      margin: 0;
      padding-left: 18px;
      font-size: 12px;
      line-height: 1.55;
      color: var(--text-soft);
    }
    .openclaw-index-list strong {
      color: var(--text);
    }
    .openclaw-index-hint {
      margin: 14px 0 0;
      padding-top: 12px;
      border-top: 1px solid var(--border);
      font-size: 11px;
      line-height: 1.45;
      color: var(--muted);
    }
    .openclaw-index-hint code {
      font-size: 10px;
    }
    /* Panel inferior: rejilla 12 columnas (bento). Sin .openclaw-detail { flex }: rompía el grid. */
    .openclaw-bento-main {
      display: grid;
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap: 16px;
      margin-top: 16px;
      min-width: 0;
    }
    .openclaw-page .wrapper--dashboard > .openclaw-bento-main {
      flex-shrink: 0;
    }
    .openclaw-bento-main :global(.oc-bento-tile) {
      min-width: 0;
      display: flex;
      flex-direction: column;
    }
    .openclaw-bento-main :global(.oc-bento-tile) > :global(.card) {
      flex: 1;
      min-height: 0;
      display: flex;
      flex-direction: column;
      margin: 0;
      padding: 18px 20px 20px;
      border-radius: 24px;
    }
    .openclaw-bento-main :global(.oc-bento-tile) > :global(.card) > :global(.card-header) {
      flex-shrink: 0;
    }
    .openclaw-bento-main :global(.oc-bento-tile--full) > :global(.card) :global(.openclaw-fill-stack),
    .openclaw-bento-main :global(.oc-bento-tile--half) > :global(.card) :global(.openclaw-fill-stack),
    .openclaw-bento-main :global(.oc-bento-tile--full) > :global(.card) > :global(.openclaw-fs-table-wrap),
    .openclaw-bento-main :global(.oc-bento-tile--full) > :global(.card) > :global(.oc-muted) {
      min-width: 0;
    }
    .openclaw-bento-main > :global(.oc-bento-tile--full) {
      grid-column: 1 / -1;
      min-width: 0;
    }
    .openclaw-bento-main > :global(.oc-bento-tile--half) {
      grid-column: span 6;
      min-width: 0;
    }
    .openclaw-bento-main > :global(.oc-bento-tile--half:only-child) {
      grid-column: 1 / -1;
    }
    @media (max-width: 1099px) {
      .openclaw-bento-main > :global(.oc-bento-tile--half) {
        grid-column: 1 / -1;
      }
    }
    @media (min-width: 768px) and (max-width: 1099px) {
      .openclaw-page .openclaw-bento-hero .profile-card {
        grid-column: 1;
        grid-row: 1;
      }
      .openclaw-page .openclaw-bento-hero .openclaw-bento-tile--snapshot {
        grid-column: 2;
        grid-row: 1;
      }
      .openclaw-page .openclaw-bento-hero .openclaw-bento-tile--disco {
        grid-column: 1;
        grid-row: 2;
      }
      .openclaw-page .openclaw-bento-hero .openclaw-bento-tile--env {
        grid-column: 2;
        grid-row: 2;
      }
      .openclaw-page .openclaw-bento-hero .openclaw-bento-index {
        grid-column: 1 / -1;
        grid-row: 3;
      }
    }
    @media (max-width: 767px) {
      .openclaw-page .openclaw-bento-hero .profile-card,
      .openclaw-page .openclaw-bento-hero .openclaw-bento-tile--snapshot,
      .openclaw-page .openclaw-bento-hero .openclaw-bento-tile--disco,
      .openclaw-page .openclaw-bento-hero .openclaw-bento-tile--env,
      .openclaw-page .openclaw-bento-hero .openclaw-bento-index {
        grid-column: 1 / -1;
        grid-row: auto;
      }
    }
    .openclaw-page .oc-meta-bin {
      display: block;
      max-width: 100%;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      font-size: inherit !important;
    }
    .openclaw-banner {
      margin: 0;
      padding: 12px 16px;
    }
    .openclaw-banner--hidden {
      display: none !important;
    }
    .openclaw-banner-inner {
      align-items: center;
    }
    .openclaw-banner-dot {
      flex-shrink: 0;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--accent);
      box-shadow: 0 0 0 3px rgba(250, 204, 21, 0.2);
    }
    .openclaw-banner-text {
      margin: 0;
      font-size: 13px;
      font-weight: 600;
      line-height: 1.45;
      color: var(--text-soft);
    }
    .oc-sections--loading {
      min-height: 120px;
    }
    .openclaw-loading-line {
      display: block !important;
      height: 14px;
      width: min(240px, 45%);
      border-radius: 8px;
    }
    .openclaw-loading-block {
      display: block !important;
      height: min(160px, 28vh);
      width: 100%;
      border-radius: 14px;
    }
  </style>

  <style is:global>
    /* HTML generado en cliente (innerHTML): sin data-astro-cid, el scope no aplicaba. */
    .openclaw-page .openclaw-loading-card {
      display: flex;
      flex-direction: column;
      gap: 12px;
      padding: 20px !important;
    }
    .openclaw-page .openclaw-details {
      margin-bottom: 10px;
      padding: 10px 12px;
      border-radius: 12px;
      border: 1px solid var(--border);
      background: var(--bg-subtle);
    }
    /* Flecha a la derecha (misma lógica que .sidebar-section en global.css). */
    .openclaw-page .oc-chevron-disclosure > summary {
      cursor: pointer;
      list-style: none;
      display: flex;
